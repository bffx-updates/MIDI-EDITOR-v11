 function getCC_AMPEROST2_Name(v) {
    switch(v) {
        case 7:  return "Patch Volume";
        case 11: return "Expression Pedal";
        case 13: return "EXP 1/2 Switch";
        case 16: return "Quick Access Para 1";
        case 17: return "Quick Access Para 1 ajuste";
        case 18: return "Quick Access Para 2";
        case 19: return "Quick Access Para 2 ajuste";
        case 20: return "Quick Access Para 3";
        case 21: return "Quick Access Para 3 ajuste";
        case 22: return "Bank -";
        case 23: return "Bank +";
        case 24: return "Pre-Select Menu";
        case 25: return "Seleção de cenas 1–4";
        case 26: return "Patch -";
        case 27: return "Patch +";
        case 28: return "Unit Mode";
        case 29: return "Main Display Mode";
        case 36: return "Drum Machine Menu On/Off";
        case 37: return "Drum Machine Play/Stop";
        case 38: return "Drum Machine Rhythm Type";
        case 39: return "Drum Machine Volume";

        case 48: return "Slot A1 On/Off";
        case 49: return "Slot A2 On/Off";
        case 50: return "Slot A3 On/Off";
        case 51: return "Slot A4 On/Off";
        case 52: return "Slot A5 On/Off";
        case 53: return "Slot A6 On/Off";

        case 54: return "Slot B1 On/Off";
        case 55: return "Slot B2 On/Off";
        case 56: return "Slot B3 On/Off";
        case 57: return "Slot B4 On/Off";
        case 58: return "Slot B5 On/Off";
        case 59: return "Slot B6 On/Off";

        case 60: return "Tuner On/Off";

        case 62: return "Looper Menu On/Off";
        case 63: return "Looper Rec/Overdub";
        case 64: return "Looper Play/Stop";
        case 65: return "Looper Speed";
        case 66: return "Looper Playback";
        case 67: return "Looper Undo/Redo";
        case 68: return "Looper Clear";
        case 69: return "Looper Rec Level";
        case 70: return "Looper Loop Level";
        case 71: return "Looper Pre/Post";
        case 72: return "Looper A/B Chain";

        case 74: return "Tempo MSB";
        case 75: return "Tempo LSB";
        case 76: return "Tap Tempo";
        case 77: return "Screen Lock/Unlock";
        case 78: return "Unit Engage/Bypass";
