                                    <span class="power-btn-label">PREVIEW<br>ON</span>
                                </button>
                                <button type="button" id="fxModeToggle1" class="fx-mode-toggle" data-mode="sigla" onclick="toggleFxMode(1)">SIGLA</button>
                                <button type="button" id="fxModeToggle2" class="fx-mode-toggle" data-mode="sigla" onclick="toggleFxMode(2)" style="display:none;">SIGLA</button>
                            </div>
