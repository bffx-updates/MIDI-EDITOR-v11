            function appendKemperSpecialCCGroups(selectEl, normalizedValue) {
                kemperSpecialCCs.forEach(item => {
                    const option = document.createElement('option');
                    option.value = item.value;
                    option.textContent = item.label;
                    if (item.disabled) option.disabled = true;
                    if (item.value === normalizedValue) option.selected = true;
                    selectEl.appendChild(option);
                });
            }

            // Kemper TRANSPOSE values (28-100) with musical labels
            const kemperTransposeLabels = {
                28: "-3 Oitavas",
                29: "-2 Oit + 11 Semi",
                30: "-2 Oit + 10 Semi",
                31: "-2 Oit + 9 Semi",
                32: "-2 Oit + 8 Semi",
                33: "-2 Oit + 7 Semi",
                34: "-2 Oit + 6 Semi",
                35: "-2 Oit + 5 Semi",
                36: "-2 Oit + 4 Semi",
                37: "-2 Oit + 3 Semi",
                38: "-2 Oit + 2 Semi",
                39: "-2 Oit + 1 Semi",
                40: "-2 Oitavas",
                41: "-1 Oit + 11 Semi",
                42: "-1 Oit + 10 Semi",
                43: "-1 Oit + 9 Semi",
                44: "-1 Oit + 8 Semi",
                45: "-1 Oit + 7 Semi",
                46: "-1 Oit + 6 Semi",
                47: "-1 Oit + 5 Semi",
                48: "-1 Oit + 4 Semi",
                49: "-1 Oit + 3 Semi",
                50: "-1 Oit + 2 Semi",
                51: "-1 Oit + 1 Semi",
                52: "-1 Oitava",
                53: "-5 Tons + 1 Semi",
                54: "-5 Tons",
                55: "-4 Tons + 1 Semi",
                56: "-4 Tons",
                57: "-3 Tons + 1 Semi",
                58: "-3 Tons",
                59: "-2 Tons + 1 Semi",
                60: "-2 Tons",
                61: "-1 Tom + 1 Semi",
                62: "-1 Tom",
                63: "-1 Semitom",
                64: "ORIGINAL (ZERO)",
                65: "+1 Semitom",
                66: "+1 Tom",
                67: "+1 Tom + 1 Semi",
                68: "+2 Tons",
                69: "+2 Tons + 1 Semi",
                70: "+3 Tons",
                71: "+3 Tons + 1 Semi",
                72: "+4 Tons",
                73: "+4 Tons + 1 Semi",
                74: "+5 Tons",
                75: "+5 Tons + 1 Semi",
                76: "+1 Oitava",
                77: "+1 Oit + 1 Semi",
                78: "+1 Oit + 1 Tom",
                79: "+1 Oit + 1T + 1S",
                80: "+1 Oit + 2 Tons",
                81: "+1 Oit + 2T + 1S",
                82: "+1 Oit + 3 Tons",
                83: "+1 Oit + 3T + 1S",
                84: "+1 Oit + 4 Tons",
                85: "+1 Oit + 4T + 1S",
                86: "+1 Oit + 5 Tons",
                87: "+1 Oit + 5T + 1S",
                88: "+2 Oitavas",
                89: "+2 Oit + 1 Semi",
                90: "+2 Oit + 1 Tom",
                91: "+2 Oit + 1T + 1S",
                92: "+2 Oit + 2 Tons",
                93: "+2 Oit + 2T + 1S",
                94: "+2 Oit + 3 Tons",
                95: "+2 Oit + 3T + 1S",
                96: "+2 Oit + 4 Tons",
                97: "+2 Oit + 4T + 1S",
                98: "+2 Oit + 5 Tons",
                99: "+2 Oit + 5T + 1S",
                100: "+3 Oitavas"
            };

            const kemperCustomLabels = {
                // Post/Pre Position (Ducking Position)
                293: { min: 0, max: 1, labels: { 0: "Pre", 1: "Post" } },
                
                // On/Off (Tempo Sync, Freeze)
                289: { min: 0, max: 1, labels: { 0: "Off", 1: "On" } },
                291: { min: 0, max: 1, labels: { 0: "Off", 1: "On" } },

                // Cut Character
                292: { min: 0, max: 2, labels: { 0: "Normal", 1: "Analog", 2: "Tape" } },

                // Note Values 1 & 2
                294: { min: 0, max: 20, labels: {
                    0: "1/32", 1: "1/16", 2: "2/16", 3: "3/16", 4: "4/16",
                    5: "5/16", 6: "6/16 Dotted", 7: "7/16", 8: "8/16", 9: "9/16",
                    10: "10/16", 11: "11/16", 12: "12/16 Dotted", 13: "13/16", 14: "14/16",
                    15: "15/16", 16: "16/16 (1 bar)", 17: "1/16 Triplet", 18: "1/8 Triplet",
                    19: "1/4 Triplet", 20: "1/2 Triplet"
                }},
                295: { min: 0, max: 20, labels: {
                    0: "1/32", 1: "1/16", 2: "2/16", 3: "3/16", 4: "4/16",
                    5: "5/16", 6: "6/16 Dotted", 7: "7/16", 8: "8/16", 9: "9/16",
                    10: "10/16", 11: "11/16", 12: "12/16 Dotted", 13: "13/16", 14: "14/16",
                    15: "15/16", 16: "16/16 (1 bar)", 17: "1/16 Triplet", 18: "1/8 Triplet",
                    19: "1/4 Triplet", 20: "1/2 Triplet"
                }},

                // ---- REVERB PARAMETERS ----
                
                // Position / Ducking Position (Pre/Post)
                297: { min: 0, max: 1, labels: { 0: "Pre", 1: "Post" } },
                302: { min: 0, max: 1, labels: { 0: "Pre", 1: "Post" } },

                // On/Off (Tempo Sync, Freeze, Infinity, Reverse)
                298: { min: 0, max: 1, labels: { 0: "Off", 1: "On" } },
                299: { min: 0, max: 1, labels: { 0: "Off", 1: "On" } },
                300: { min: 0, max: 1, labels: { 0: "Off", 1: "On" } },
                301: { min: 0, max: 1, labels: { 0: "Off", 1: "On" } },

                // Predelay Note Value
                303: { min: 0, max: 15, labels: {
                    0: "1/64", 1: "1/32", 2: "1/16", 3: "1/8", 4: "1/4", 5: "1/2", 6: "1/1",
                    7: "1/64 Dotted", 8: "1/32 Dotted", 9: "1/16 Dotted", 10: "1/8 Dotted", 11: "1/4 Dotted",
                    12: "1/64 Triplet", 13: "1/32 Triplet", 14: "1/16 Triplet", 15: "1/8 Triplet"
                }},

            };

            function isChannelSelectId(id) {
                const lower = (id || '').toLowerCase();
                return lower.includes('channel') || lower.includes('_ch');
            }

            function populateNumericSelect(id, min, max, def, modeOverride) {
                const sel = document.getElementById(id);
                sel.innerHTML = '';
                sel.dataset.dirty = '1';
                const normalizedDef = parseInt(def, 10);
                const isChannelSelect = isChannelSelectId(id);
                const resolvedMode = modeOverride || getEffectiveMidiMode();

                // Add Kemper special options before CC 0 for CC selects
                if (!isChannelSelect && id.toLowerCase().includes('cc') && resolvedMode === "KEMPER PLAYER") {
                    appendKemperSpecialCCGroups(sel, normalizedDef);
                }

                for (let i = min; i <= max; i++) {
                    const opt = document.createElement('option');
                    opt.value = i;
                    let txt = i;
                    if (isChannelSelect && i === 0) {
                        txt = 'X';
                    } else if (isChannelSelect && i > 0) {
                        const cellMode = typeof getModeForChannel === 'function' ? getModeForChannel(i) : undefined;
                        if (cellMode && cellMode !== "GLOBAL") {
                            txt = `${i} - ${cellMode}`;
                        }
                    } else if (!isChannelSelect && id.toLowerCase().includes('cc')) {
                        let lbl = "?";
                        const ccMode = resolvedMode;
                        if (ccMode === "AMPERO AS2" || ccMode === "A. STAGE 2" || ccMode === "AMPERO MP350") {
                            lbl = getCC_AMPEROST2_Name(i);
                        } else if (ccMode === "AMPERO MINI") {
                            lbl = getCC_AMPERO_MINI_Names(i);
                        } else if (ccMode === "MX5") {
                            lbl = getCC_MX5_Names(i);
                        } else if (ccMode === "GP-200LT") {
                            lbl = getCC_GP200LT_Names(i);
                        } else if (ccMode === "POCKET MASTER") {
                            lbl = getCC_POCKET_MASTER_Names(i);
                        } else if (ccMode === "KEMPER PLAYER") {
                            lbl = getCC_KEMPER_PLAYER_Names(i);
                        } else if (ccMode === "TONEX") {
                            lbl = getCC_TONEX_Name(i);
                        } else if (ccMode === "VALETON GP5") {
                            lbl = getCC_VALETON_GP5_Names(i);
                        } else if (ccMode === "NANO CORTEX") {
                            lbl = getCC_NANO_CORTEX_Names(i);
                        } else if (ccMode === "QUAD CORTEX") {
                            lbl = getCC_QUAD_CORTEX_Names(i);
                        } else if (ccMode === "HX STOMP") {
                            lbl = getCC_HX_STOMP_Names(i);
                        } else if (ccMode === "SYNERGY AMPS") {
                            lbl = getCC_SYN2_Names(i);
                        } else if (ccMode === "BigSky") {
                            lbl = getCC_BIGSKY_Names(i);
                        } else if (ccMode === "BlueSky") {
                            lbl = (typeof getCC_BLUESKY_Names === 'function') ? getCC_BLUESKY_Names(i) : "?";
                        } else if (ccMode === "TimeLine") {
                            lbl = getCC_TIMELINE_Names(i);
                        } else if (ccMode === "ELCAPISTAN") {
                            lbl = getCC_ELCAPISTAN_Names(i);
                        } else if (ccMode === "FLINT") {
                            lbl = getCC_FLINT_Names(i);
                        } else if (ccMode === "HX-ONE") {
                            lbl = getCC_HXONE_Names(i);
                        } else if (ccMode === "VTR NARCISO") {
                            lbl = getCC_VTR_NARCISO_Names(i);
                        } else if (ccMode === "VTR LOKI") {
                            lbl = getCC_VTR_LOKI_Names(i);
                        } else if (ccMode === "VTR KAILANI") {
                            lbl = getCC_KAILANI_Names(i);
                        }
                        if (lbl !== "?") txt = `${i} - ${lbl}`;
                    } else if (!isChannelSelect && (id.toLowerCase().includes('pc') || id.toLowerCase().includes('bank'))) {
                        let lbl;
                        const ccMode = resolvedMode;
                        if (ccMode === "AMPERO AS2") lbl = typeof bank_AS2_Names !== 'undefined' ? bank_AS2_Names[i] : undefined;
                        else if (ccMode === "HX STOMP") lbl = typeof bank_HX_STOMP_Names !== 'undefined' ? bank_HX_STOMP_Names[i] : undefined;
                        else if (ccMode === "AMPERO MINI") lbl = typeof bank_AMPERO_MINI_Names !== 'undefined' ? bank_AMPERO_MINI_Names[i] : undefined;
                        else if (ccMode === "A. STAGE 2") lbl = typeof bank_ASTG2_Names !== 'undefined' ? bank_ASTG2_Names[i] : undefined;
                        else if (ccMode === "GP-200LT") lbl = typeof bank_GP200LT_Names !== 'undefined' ? bank_GP200LT_Names[i] : undefined;
                        else if (ccMode === "VALETON GP5") lbl = typeof bank_VALETON_GP5_Names !== 'undefined' ? bank_VALETON_GP5_Names[i] : undefined;
                        else if (ccMode === "POCKET MASTER") lbl = typeof bank_POCKET_MASTER_Names !== 'undefined' ? bank_POCKET_MASTER_Names[i] : undefined;
                        else if (ccMode === "KEMPER PLAYER") lbl = typeof bank_KEMPER_PLAYER_Names !== 'undefined' ? bank_KEMPER_PLAYER_Names[i] : undefined;
                        else if (ccMode === "TONEX") lbl = typeof bank_TONEX_Names !== 'undefined' ? bank_TONEX_Names[i] : undefined;
                        else if (ccMode === "AMPERO MP350") lbl = typeof bank_AMPERO_MP350_Names !== 'undefined' ? bank_AMPERO_MP350_Names[i] : undefined;
                        else if (ccMode === "BigSky") lbl = typeof bank_BIGSKY_Names !== 'undefined' ? bank_BIGSKY_Names[i] : undefined;
                        else if (ccMode === "BlueSky") lbl = typeof bank_BLUESKY_Names !== 'undefined' ? bank_BLUESKY_Names[i] : undefined;
                        else if (ccMode === "TimeLine") lbl = typeof bank_TIMELINE_Names !== 'undefined' ? bank_TIMELINE_Names[i] : undefined;
                        if (lbl !== undefined) txt = `${i} - ${lbl}`;
                    }
                    opt.textContent = txt;
                    if (i === normalizedDef) opt.selected = true;
                    sel.appendChild(opt);
                }
            }

            function getSelectNumericValue(id) {
                const el = document.getElementById(id);
                if (!el) return null;
                const v = parseInt(el.value, 10);
                return Number.isNaN(v) ? null : v;
            }

            function isValueSelectId(id) {
                return /^(spinV\d+_|customOn_|customOff_|macro_on_|macro_off_|dsCC1|dsCC2)/.test(id);
            }

            function getValueSelectCcValue(selectId) {
                if (!selectId) return null;
                if (selectId.startsWith('spinV') ||
                    selectId.startsWith('customOn_') ||
                    selectId.startsWith('customOff_') ||
                    selectId.startsWith('dsCC1')) {
                    return getSelectNumericValue('switchCC');
                }
                if (selectId.startsWith('dsCC2')) {
                    return getSelectNumericValue('switchCC2');
                }
                const macroMatch = selectId.match(/^macro_(?:on|off)_(\d+)_(\d+)$/);
                if (macroMatch) {
                    return getSelectNumericValue(`macro_cc_${macroMatch[1]}_${macroMatch[2]}`);
                }
                return null;
            }

            function getKemperLabelForValueSelect(selectEl) {
                if (!selectEl || getEffectiveMidiMode() !== "KEMPER PLAYER") return '';
                const ccVal = getValueSelectCcValue(selectEl.id);
                if (ccVal === null || ccVal === undefined) return '';
                const rawVal = parseInt(selectEl.value, 10);
                if (Number.isNaN(rawVal)) return '';
                if (ccVal === 208 && typeof kemperTransposeLabels !== 'undefined') {
                    return kemperTransposeLabels[rawVal] || '';
                }
                if (typeof kemperCustomLabels !== 'undefined' && kemperCustomLabels[ccVal]) {
                    const customDef = kemperCustomLabels[ccVal];
                    if (customDef && customDef.labels && customDef.labels[rawVal] !== undefined) {
                        return customDef.labels[rawVal];
                    }
                }
                return '';
            }

            // Repopulate value selects when CC changes (for Kemper labeled values)
            function repopulateValueSelectsForCC() {
                if (getEffectiveMidiMode() !== "KEMPER PLAYER") return;

                // Find all value selects that need repopulation
                document.querySelectorAll('.original-select').forEach(sel => {
                    const id = sel.id || '';
                    if (!isValueSelectId(id)) return;

                    const ccVal = getValueSelectCcValue(id);
                    if (ccVal === null || ccVal === undefined) return;

                    const currentValue = parseInt(sel.value, 10);
                    sel.innerHTML = '';
                    sel.dataset.dirty = '1';

                    if (ccVal === 208) {
                        // Range 28-100 with musical labels
                        const baseValue = Number.isNaN(currentValue) ? 64 : currentValue;
                        const adjustedValue = Math.max(28, Math.min(100, baseValue));
                        for (let i = 28; i <= 100; i++) {
                            const opt = document.createElement('option');
                            opt.value = i;
                            const label = (typeof kemperTransposeLabels !== 'undefined' && kemperTransposeLabels[i]) ? kemperTransposeLabels[i] : i.toString();
                            opt.textContent = `${i} - ${label}`;
                            if (i === adjustedValue) opt.selected = true;
                            sel.appendChild(opt);
                        }
                    } else if (kemperCustomLabels && kemperCustomLabels[ccVal]) {
                        // Custom Kemper Range & Labels
                        const customDef = kemperCustomLabels[ccVal];
                        const min = customDef.min !== undefined ? customDef.min : 0;
                        const max = customDef.max !== undefined ? customDef.max : 127;
                        const baseValue = Number.isNaN(currentValue) ? min : currentValue;
                        const adjustedValue = Math.max(min, Math.min(max, baseValue));

                        for (let i = min; i <= max; i++) {
                            const opt = document.createElement('option');
                            opt.value = i;
                            const label = (customDef.labels && customDef.labels[i]) ? customDef.labels[i] : i.toString();
                            opt.textContent = `${i} - ${label}`;
                            if (i === adjustedValue) opt.selected = true;
                            sel.appendChild(opt);
                        }
                    } else {
                        // Normal range 0-127
                        const baseValue = Number.isNaN(currentValue) ? 0 : currentValue;
                        const adjustedValue = Math.max(0, Math.min(127, baseValue));
                        for (let i = 0; i <= 127; i++) {
                            const opt = document.createElement('option');
                            opt.value = i;
                            opt.textContent = i;
                            if (i === adjustedValue) opt.selected = true;
                            sel.appendChild(opt);
                        }
                    }

                    // Update custom select UI if exists
                    if (typeof updateCustomSelect === 'function') {
                        updateCustomSelect(id);
                    }
                });

                initCustomSelects();
            }

            function populatePresetChannelSelect(id, def) {
                const sel = document.getElementById(id);
                sel.innerHTML = '';
                sel.dataset.dirty = '1';
                const normalizedDef = parseInt(def, 10);
                // Adiciona opcao X (valor 0) para suprimir envio de bank MIDI
                const optX = document.createElement('option');
                optX.value = 0;
                optX.textContent = 'X';
                if (normalizedDef === 0) optX.selected = true;
                sel.appendChild(optX);
                // Adiciona canais 1-16
                for (let i = 1; i <= 16; i++) {
                    const opt = document.createElement('option');
                    opt.value = i;
                    let txt = i;
                    if (globalMidiMode === "MODO AVANCADO") {
                        const cellMode = typeof getModeForChannel === 'function' ? getModeForChannel(i) : undefined;
                        if (cellMode && cellMode !== "GLOBAL") {
                            txt = `${i} - ${cellMode}`;
                        }
                    }
                    opt.textContent = txt;
                    if (i === normalizedDef) opt.selected = true;
                    sel.appendChild(opt);
                }
            }

            function populateBankLabels(id, arr, def) {
                const sel = document.getElementById(id);
                sel.innerHTML = '';
                const normalizedDef = parseInt(def, 10);
                arr.forEach((lbl, idx) => {
                    const opt = document.createElement('option');
                    opt.value = idx; opt.textContent = lbl;
                    if (idx === normalizedDef) opt.selected = true;
                    sel.appendChild(opt);
                });
            }

            function setStompAuxLedPreviewVisual(previewId, boxId, hex) {
                const hexColor = `#${hex.toString(16).padStart(6, '0')}`;
                const preview = document.getElementById(previewId);
                if (preview) preview.style.setProperty('--led-preview-color', hexColor);
                const box = document.getElementById(boxId);
                if (box) applyColorPreview(box, hex, 'bar');
            }

            function initializeColorPickers() { 
                const createPanel = (overlayId, panelId, previewElementId, callback, colors = PERFIS_CORES_LED_WEB, options = {}) => {
                    const overlay = document.getElementById(overlayId);
                    const panel = document.getElementById(panelId);
                    if (!overlay || !panel) return;
                    createColorOptionsPanel(panelId, colors, callback, options);
                    document.getElementById(previewElementId)?.addEventListener('click', () => overlay.classList.add('active'));
                    overlay.addEventListener('click', e => { if (e.target === overlay) overlay.classList.remove('active'); });
                };
                createPanel('colorPanelOverlay_Led', 'colorPanel_Led', 'selectedLedColorPreview', (hex, idx, color) => {
                    setStompAuxLedPreviewVisual('selectedLedColorPreview', 'selectedLedColorPreviewBox', color || hex);
                    document.getElementById('switchLedColorValue').value = idx;
                    updateSwitchLedColorData(idx); updateLocalPresetDataFromUI();
                    try { updateAllFootButtonsUI(); } catch(_) {}
                }, PERFIS_CORES_LED_WEB);

                createPanel('colorPanelOverlay_PresetName', 'colorPanel_PresetName', 'selectedPresetNameColorPreview', (colorValue, idx, color) => {
                    const box = document.getElementById('selectedPresetNameColorPreviewBox');
                    applyColorPreview(box, color || colorValue, 'bar');
                    updatePresetNameColorData(colorValue); updateLocalPresetDataFromUI();
                }, PRESET_DIRECT_COLORS_WEB, { gradientPalette: true });

                createPanel('colorPanelOverlay_PresetBgColor', 'colorPanel_PresetBgColor', 'selectedPresetBgColorPreview', (colorValue, idx, color) => {
                    const box = document.getElementById('selectedPresetBgColorPreviewBox');
                    applyColorPreview(box, color || colorValue, 'bar');
                    updatePresetBgColorData(colorValue); updateLocalPresetDataFromUI();
                }, PRESET_DIRECT_COLORS_WEB, { gradientPalette: true });

                createPanel('colorPanelOverlay_BackTagColor', 'colorPanel_BackTagColor', 'selectedBackTagColorPreview', (colorValue, idx, color) => {
                    const box = document.getElementById('selectedBackTagColorPreviewBox');
                    applyColorPreview(box, color || colorValue, 'bar');
                    updateBackTagColorData(colorValue); updateLocalPresetDataFromUI();
                }, PRESET_DIRECT_COLORS_WEB, { gradientPalette: true });

                createPanel('colorPanelOverlay_Led2', 'colorPanel_Led2', 'selectedLed2ColorPreview', (hex, idx, color) => {
                    setStompAuxLedPreviewVisual('selectedLed2ColorPreview', 'selectedLed2ColorPreviewBox', color || hex);
                    document.getElementById('switchLed2ColorValue').value = idx;
                    updateSwitchLed2ColorData(idx);
                    updateLocalPresetDataFromUI();
                    try { updateAllFootButtonsUI(); } catch(_) {}
                }, PERFIS_CORES_LED_WEB);

                // HOLD color picker (for SPIN HOLD long-press pixel color)
                createPanel('colorPanelOverlay_Hold', 'colorPanel_Hold', 'selectedHoldColorPreview', (hex, idx, color) => {
                    const box = document.getElementById('selectedHoldColorPreviewBox');
                    applyColorPreview(box, color || hex, 'bar');
                    const hidden = document.getElementById('switchHoldColorValue');
                    if (hidden) hidden.value = idx;
                    updateSwitchHoldColorData(idx);
                    updateLocalPresetDataFromUI();
                    try { updateAllFootButtonsUI(); } catch(_) {}
                }, PERFIS_CORES_LED_WEB);

                // LED3 color picker (for RECLICK)
                createPanel('colorPanelOverlay_Led3', 'colorPanel_Led3', 'selectedLed3ColorPreview', (hex, idx, color) => {
                    setStompAuxLedPreviewVisual('selectedLed3ColorPreview', 'selectedLed3ColorPreviewBox', color || hex);
                    document.getElementById('switchLed3ColorValue').value = idx;
                    updateSwitchLed3ColorData(idx);
                    updateLocalPresetDataFromUI();
                    try { updateAllFootButtonsUI(); } catch(_) {}
                }, PERFIS_CORES_LED_WEB);

            }

            function createColorOptionsPanel(panelId, colors, cb, options = {}) { 
                const panel = document.getElementById(panelId);
                if (!panel) return;
                
                const isSegmented = colors.some(c => c && c.type === 'ui_tabs');

                if (!isSegmented) {
                    panel.classList.toggle('gradient-palette', !!options.gradientPalette);
                    panel.innerHTML = '<div class="color-options-panel-title">Escolha uma Cor</div>';
                    colors.forEach((color, index) => {
                        if (color && color.type === 'section') {
                            const sectionTitle = document.createElement('div');
                            sectionTitle.className = 'color-options-section-title';
                            sectionTitle.textContent = color.title;
                            panel.appendChild(sectionTitle);
                            return;
                        }
                        const swatch = document.createElement('div');
                        swatch.className = 'color-swatch';
                        const hex = getColorHex(color);
                        const storedIndex = (typeof color.actualIndex === 'number') ? color.actualIndex : index;
                        const storedValue = (color && color.storedValue !== undefined) ? color.storedValue : color.value;
                        if (color && typeof color === 'object' && color.swatchCss) {
                            swatch.style.background = color.swatchCss;
                        } else {
                            swatch.style.background = hex;
                        }
                        swatch.title = color.name;
                        swatch.addEventListener('click', () => {
                            cb(storedValue, storedIndex, color);
                            panel.closest('.color-options-panel-overlay')?.classList.remove('active');
                        });
                        panel.appendChild(swatch);
                    });
                    return;
                }

                panel.classList.remove('gradient-palette');
                panel.classList.add('segmented-color-panel');

                panel.innerHTML = `
                    <div class="color-options-panel-title">${options.panelTitle || 'TRANSPARÊNCIA'}</div>
                    <div class="color-options-top-row">
                        <div class="color-swatch transparent-swatch" id="segTransparentBtn-${panelId}" title="Sem Cor" style="background: var(--transparent-swatch-bg, transparent);"></div>
                        <div class="segmented-control">
                            <button class="seg-btn active" data-target="seg-solid">SOLID</button>
                            <button class="seg-btn" data-target="seg-grad1">GRADIENT 1</button>
                            <button class="seg-btn" data-target="seg-grad2">GRADIENT 2</button>
                            <button class="seg-btn" data-target="seg-custom">CUSTOM</button>
                            <button class="seg-btn" data-target="seg-misc">MISC</button>
                        </div>
                    </div>
                `;

                const transparentBtn = panel.querySelector('#segTransparentBtn-' + panelId);
                transparentBtn.style.background = TRANSPARENT_SWATCH_CSS;
                transparentBtn.addEventListener('click', () => {
                    const tcolor = colors.find(c => isTransparentColorRef(c));
                    if(tcolor) {
                        cb(tcolor.storedValue !== undefined ? tcolor.storedValue : tcolor.value, tcolor.actualIndex, tcolor);
                        panel.closest('.color-options-panel-overlay')?.classList.remove('active');
                    }
                });

                const gridsContainer = document.createElement('div');
                gridsContainer.className = 'seg-grids-container';
                panel.appendChild(gridsContainer);

                let currentGrid = null;
                colors.forEach((color, index) => {
                    if (color && color.type === 'ui_tabs') return;
                    if (isTransparentColorRef(color)) return; 

                    if (color && color.type === 'section') {
                        let targetId = '';
                        if (color.title.includes('SOLID')) targetId = 'seg-solid';
                        else if (color.title.includes('GRADIENT 1')) targetId = 'seg-grad1';
                        else if (color.title.includes('GRADIENT 2')) targetId = 'seg-grad2';
                        else if (color.title.includes('CUSTOM')) targetId = 'seg-custom';
                        else targetId = 'seg-misc';

                        currentGrid = gridsContainer.querySelector('#' + targetId + '-' + panelId);
                        if (!currentGrid) {
                            currentGrid = document.createElement('div');
                            currentGrid.id = targetId + '-' + panelId;
                            currentGrid.className = 'color-options-grid';
                            if (targetId !== 'seg-solid') currentGrid.style.display = 'none';
                            gridsContainer.appendChild(currentGrid);
                        }

                        if (targetId === 'seg-misc') {
                            const sectionTitle = document.createElement('div');
                            sectionTitle.className = 'color-options-section-title';
                            sectionTitle.textContent = color.title;
                            sectionTitle.style.gridColumn = '1 / -1';
                            currentGrid.appendChild(sectionTitle);
                        }
                        return;
                    }

                    if (currentGrid) {
                        const swatch = document.createElement('div');
                        swatch.className = 'color-swatch new-color-swatch'; 
                        const hex = getColorHex(color);
                        const storedIndex = (typeof color.actualIndex === 'number') ? color.actualIndex : index;
                        const storedValue = (color && color.storedValue !== undefined) ? color.storedValue : color.value;
                        if (color && typeof color === 'object' && color.swatchCss) {
                            swatch.style.background = color.swatchCss;
                        } else {
                            swatch.style.background = hex;
                        }
                        swatch.title = color.name;
                        swatch.addEventListener('click', () => {
                            cb(storedValue, storedIndex, color);
                            panel.closest('.color-options-panel-overlay')?.classList.remove('active');
                        });
                        currentGrid.appendChild(swatch);
                    }
                });

                const segButtons = panel.querySelectorAll('.seg-btn');
                segButtons.forEach(btn => {
                    btn.addEventListener('click', () => {
                        segButtons.forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        gridsContainer.querySelectorAll('.color-options-grid').forEach(g => g.style.display = 'none');
                        const targetId = btn.getAttribute('data-target') + '-' + panelId;
                        const targetGrid = gridsContainer.querySelector('#' + targetId);
                        if(targetGrid) {
                            targetGrid.style.display = 'grid';
                        }
                    });
                });
            }

            function syncSpinSendPcUI(desiredValue, isSpinMode = true) {
                const cb = document.getElementById('spinSendPcToggle');
                const btn = document.getElementById('spinSendPcBtn');
                if (!cb || !btn) return;
                if (typeof desiredValue === 'boolean') cb.checked = desiredValue;
                const ccGroup = document.getElementById('switchCC')?.closest('.form-group');
                if (cb.checked) {
                    btn.classList.add('active', 'pc-mode');
                    btn.classList.remove('cc-mode');
                    btn.setAttribute('aria-pressed','true');
                    btn.textContent = 'ENVIAR PC';
                    if (isSpinMode && ccGroup) ccGroup.style.display = 'none';
                } else {
                    btn.classList.add('cc-mode');
                    btn.classList.remove('pc-mode');
                    btn.classList.remove('active');
                    btn.setAttribute('aria-pressed','false');
                    btn.textContent = 'ENVIAR CC';
                    if (ccGroup) ccGroup.style.display = 'block';
                }
            }

            function syncStompSendPcToggle(checkboxId, buttonId, desiredValue) {
                const cb = document.getElementById(checkboxId);
                const btn = document.getElementById(buttonId);
                if (!cb || !btn) return;
                if (typeof desiredValue === 'boolean') cb.checked = desiredValue;
                if (cb.checked) {
                    btn.classList.add('active', 'pc-mode');
                    btn.classList.remove('cc-mode');
                    btn.setAttribute('aria-pressed','true');
                    btn.textContent = 'ENVIAR PC';
                } else {
                    btn.classList.add('cc-mode');
                    btn.classList.remove('pc-mode', 'active');
                    btn.setAttribute('aria-pressed','false');
                    btn.textContent = 'ENVIAR CC';
                }
            }

            function createSendPcToggle(checkboxId, buttonId, initialValue) {
                const wrap = document.createElement('div');
                wrap.className = 'stomp-send-pc-row';
                const cb = document.createElement('input');
                cb.type = 'checkbox';
                cb.id = checkboxId;
                cb.style.display = 'none';
                cb.checked = !!initialValue;
                wrap.appendChild(cb);
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.id = buttonId;
                btn.className = 'single-toggle-button stomp-send-pc-btn';
                wrap.appendChild(btn);
                if (cb.checked) {
                    btn.classList.add('active', 'pc-mode');
                    btn.classList.remove('cc-mode');
                    btn.setAttribute('aria-pressed','true');
                    btn.textContent = 'ENVIAR PC';
                } else {
                    btn.classList.add('cc-mode');
                    btn.classList.remove('pc-mode', 'active');
                    btn.setAttribute('aria-pressed','false');
                    btn.textContent = 'ENVIAR CC';
                }
                cb.addEventListener('change', () => { syncStompSendPcToggle(checkboxId, buttonId); updateLocalPresetDataFromUI(); });
                btn.addEventListener('click', (e) => { e.preventDefault(); cb.checked = !cb.checked; cb.dispatchEvent(new Event('change', { bubbles: true })); });
                return wrap;
            }

            function syncSpinHoldEnabledUI(desiredValue) {
                const cb = document.getElementById('spinHoldEnabledToggle');
                const btn = document.getElementById('spinHoldEnabledBtn');
                if (!cb || !btn) return;
                if (typeof desiredValue === 'boolean') cb.checked = desiredValue;

                const isEnabled = !!cb.checked;
                btn.setAttribute('aria-pressed', isEnabled ? 'true' : 'false');
                btn.textContent = isEnabled ? 'HOLD ON' : 'HOLD OFF';
                if (isEnabled) btn.classList.add('active');
                else btn.classList.remove('active');

                const holdSelect = document.getElementById('switchCCHold');
                if (holdSelect) holdSelect.disabled = !isEnabled;

                const holdSelectWrapper = document.querySelector('.custom-select-wrapper[data-select-id="switchCCHold"]');
                if (holdSelectWrapper) {
                    holdSelectWrapper.style.pointerEvents = isEnabled ? '' : 'none';
                    holdSelectWrapper.style.opacity = isEnabled ? '' : '0.55';
                }

                const holdStartToggle = document.getElementById('switchCCHoldStart');
                if (holdStartToggle) holdStartToggle.disabled = !isEnabled;

                const holdStartContainer = document.getElementById('switchCCHoldStartContainer');
                if (holdStartContainer) {
                    holdStartContainer.style.pointerEvents = isEnabled ? '' : 'none';
                    holdStartContainer.style.opacity = isEnabled ? '' : '0.55';
                }

                const holdColorPreview = document.getElementById('selectedHoldColorPreview');
                if (holdColorPreview) {
                    holdColorPreview.style.pointerEvents = isEnabled ? '' : 'none';
                    holdColorPreview.style.opacity = isEnabled ? '' : '0.55';
                    holdColorPreview.setAttribute('aria-disabled', isEnabled ? 'false' : 'true');
                }

                const spinCustomBtn = document.getElementById('spinCustomToggleBtn');
                if (spinCustomBtn) {
                    spinCustomBtn.disabled = !isEnabled;
                    spinCustomBtn.style.opacity = isEnabled ? '' : '0.55';
                    spinCustomBtn.style.pointerEvents = isEnabled ? '' : 'none';
                }
                if (!isEnabled) {
                    const spinCustomFields = document.getElementById('spinCustomFieldsContainer');
                    if (spinCustomFields) spinCustomFields.style.display = 'none';
                }

                const gigView2Group = document.getElementById('gigView2Group');
                const slotToggle = document.getElementById('gigSlotToggleContainer');
                const displayConfigGrid = document.getElementById('displayConfigGrid');
                if (gigView2Group) gigView2Group.style.display = isEnabled ? 'block' : 'none';
                if (slotToggle) slotToggle.style.display = isEnabled ? 'flex' : 'none';
                if (displayConfigGrid) displayConfigGrid.classList.toggle('single-column', !isEnabled);
                
                if (!isEnabled && window.activeGigSlot === 2 && typeof window.refreshGigSlotUI === 'function') {
                    window.activeGigSlot = 1;
                    window.refreshGigSlotUI();
                }

                // Update icon allowed state based on the new isEnabled value
                const selMode = document.getElementById('switchMode');
                const modeVal = selMode ? parseInt(selMode.value, 10) : 0;
                const DUAL_STOMP_MODE_VALUE = 28;
                const isDual = (modeVal === DUAL_STOMP_MODE_VALUE || modeVal === 50);
                const isSpinHoldMode = (modeVal >= 35 && modeVal <= 37) || (modeVal >= 44 && modeVal <= 46);

                if (typeof window.setFxIconAllowed === 'function') {
                    window.setFxIconAllowed(1, true);
                    window.setFxIconAllowed(2, true);
                }
                
                if (typeof window.refreshGigSlotUI === 'function') {
                    window.refreshGigSlotUI();
                }
            }

            function generateSingleSpinUI(parentElement, spinDataItem, spinIndex, sendAsPc = false, spinStartOnPreset = true, spinShowPosition = false) {
                const group = document.createElement('div');
                group.className = 'extras-group';

                // Check if current CC is Pitch Transpose
                const switchCCEl = document.getElementById('switchCC');
                const ccVal = switchCCEl ? parseInt(switchCCEl.value, 10) : 0;
                const isPitchTranspose = (getEffectiveMidiMode() === "KEMPER PLAYER" && ccVal === 208);

                const spinHeader = document.createElement('h4');
                spinHeader.textContent = isPitchTranspose ? 'TRANSPOSE' : `SPIN ${spinIndex + 1}`;
                group.appendChild(spinHeader);

                // Row: ENVIAR CC/PC + SINGLE/DUPLO/TRIPLO
                const sendToggle = document.createElement('div');
                sendToggle.className = 'form-group';
                sendToggle.style.cssText = 'display:flex;align-items:center;gap:8px;flex-wrap:wrap;';
                const sendCheckbox = document.createElement('input');
                sendCheckbox.type = 'checkbox';
                sendCheckbox.id = 'spinSendPcToggle';
                sendCheckbox.style.display = 'none';
                sendCheckbox.checked = !!sendAsPc;
                sendToggle.appendChild(sendCheckbox);
                const sendBtn = document.createElement('button');
                sendBtn.type = 'button';
                sendBtn.id = 'spinSendPcBtn';
                sendBtn.className = 'single-toggle-button';
                sendToggle.appendChild(sendBtn);

                // SINGLE/DUPLO/TRIPLO toggle button
                const spinCountStates = ['SINGLE', 'DUPLO', 'TRIPLO'];
                let currentSpinCount = Math.max(1, Math.min(3, parseInt(spinDataItem && spinDataItem.spin_count != null ? spinDataItem.spin_count : 1, 10))) - 1; // 0-based index
                const spinCountBtn = document.createElement('button');
                spinCountBtn.type = 'button';
                spinCountBtn.id = `spinCountBtn_${spinIndex}`;
                spinCountBtn.className = 'single-toggle-button';
                spinCountBtn.style.cssText = 'min-width:80px;';
                const updateSpinCountBtn = () => {
                    spinCountBtn.textContent = spinCountStates[currentSpinCount];
                    spinCountBtn.classList.toggle('active', currentSpinCount > 0);
                    // Show/hide extra CC blocks
                    const cc2Block = document.getElementById(`spinCC2Block_${spinIndex}`);
                    const cc3Block = document.getElementById(`spinCC3Block_${spinIndex}`);
                    if (cc2Block) cc2Block.style.display = (currentSpinCount >= 1) ? 'block' : 'none';
                    if (cc3Block) cc3Block.style.display = (currentSpinCount >= 2) ? 'block' : 'none';
                    try { updateLocalPresetDataFromUI(); } catch(_) {}
                };
                spinCountBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    currentSpinCount = (currentSpinCount + 1) % 3;
                    updateSpinCountBtn();
                });
                sendToggle.appendChild(spinCountBtn);

                // INICIAR COM PRESET toggle
                const spinStartCb = document.createElement('input');
                spinStartCb.type = 'checkbox';
                spinStartCb.id = 'spinStartOnPresetToggle';
                spinStartCb.style.display = 'none';
                spinStartCb.checked = !!spinStartOnPreset;
                sendToggle.appendChild(spinStartCb);
                const spinStartBtn = document.createElement('button');
                spinStartBtn.type = 'button';
                spinStartBtn.id = 'spinStartOnPresetBtn';
                spinStartBtn.className = 'single-toggle-button';
                spinStartBtn.style.cssText = 'min-width:120px;';
                const updateSpinStartBtn = () => {
                    if (spinStartCb.checked) {
                        spinStartBtn.textContent = 'INICIAR COM PRESET';
                        spinStartBtn.classList.add('active');
                    } else {
                        spinStartBtn.textContent = 'INICIAR COM PRESET';
                        spinStartBtn.classList.remove('active');
                    }
                    try { updateLocalPresetDataFromUI(); } catch(_) {}
                };
                spinStartCb.addEventListener('change', updateSpinStartBtn);
                spinStartBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    spinStartCb.checked = !spinStartCb.checked;
                    updateSpinStartBtn();
                });
                updateSpinStartBtn();
                sendToggle.appendChild(spinStartBtn);

                // SHOW % / SHOW POSITION toggle
                const spinShowPosCb = document.createElement('input');
                spinShowPosCb.type = 'checkbox';
                spinShowPosCb.id = 'spinShowPositionToggle';
                spinShowPosCb.style.display = 'none';
                spinShowPosCb.checked = !!spinShowPosition;
                sendToggle.appendChild(spinShowPosCb);
                const spinShowPosBtn = document.createElement('button');
                spinShowPosBtn.type = 'button';
                spinShowPosBtn.id = 'spinShowPositionBtn';
                spinShowPosBtn.className = 'single-toggle-button';
                spinShowPosBtn.style.cssText = 'min-width:120px;';
                const updateSpinShowPosBtn = () => {
                    if (spinShowPosCb.checked) {
                        spinShowPosBtn.textContent = 'SHOW POSITION';
                        spinShowPosBtn.classList.add('active');
                    } else {
                        spinShowPosBtn.textContent = 'SHOW %';
                        spinShowPosBtn.classList.remove('active');
                    }
                    try { updateLocalPresetDataFromUI(); } catch(_) {}
                };
                spinShowPosCb.addEventListener('change', updateSpinShowPosBtn);
                spinShowPosBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    spinShowPosCb.checked = !spinShowPosCb.checked;
                    updateSpinShowPosBtn();
                });
                updateSpinShowPosBtn();
                sendToggle.appendChild(spinShowPosBtn);

                group.appendChild(sendToggle);

                const syncSpinSendLocal = () => {
                    syncSpinSendPcUI(undefined, true);
                    try { updateLocalPresetDataFromUI(); } catch(_) {}
                };
                sendCheckbox.addEventListener('change', syncSpinSendLocal);
                sendBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    sendCheckbox.checked = !sendCheckbox.checked;
                    syncSpinSendLocal();
                });
                syncSpinSendPcUI(!!sendAsPc);

                // CC1 block (always visible) -- main values
                const cc1Block = document.createElement('div');
                cc1Block.id = `spinCC1Block_${spinIndex}`;
                cc1Block.className = 'extras-group';
                cc1Block.style.cssText = 'margin-top:8px;padding:8px;background:rgba(255,255,255,0.04);border-radius:6px;border:1px solid #333;';
                const cc1Label = document.createElement('div');
                cc1Label.style.cssText = 'font-size:0.8rem;color:#aaa;margin-bottom:4px;';
                cc1Label.textContent = 'CC 1 (principal)';
                cc1Block.appendChild(cc1Label);
                const valuesRowCC1 = document.createElement('div');
                valuesRowCC1.className = 'spin-values-row';
                const slotDefinitions = [
                    { label: 'Valor 1:', key: 'v1' },
                    { label: 'Valor 2:', key: 'v2' },
                    { label: 'Valor 3:', key: 'v3' }
                ];
                const slotState = [];
                let activeSlotIndex = 0;
                slotDefinitions.forEach((slotDef, idx) => {
                    let parsedValue = parseInt((spinDataItem && Object.prototype.hasOwnProperty.call(spinDataItem, slotDef.key)) ? spinDataItem[slotDef.key] : 0, 10);
                    if (Number.isNaN(parsedValue)) parsedValue = isPitchTranspose ? 64 : 0;
                    if (isPitchTranspose) parsedValue = Math.max(28, Math.min(100, parsedValue));
                    else parsedValue = Math.max(0, Math.min(127, parsedValue));
                    const item = document.createElement('div');
                    item.className = 'spin-value-item';
                    item.appendChild(newLabel(slotDef.label));
                    const selectId = `spinV${idx + 1}_${spinIndex}`;
                    let spinModeOverride;
                    if (globalMidiMode === "MODO AVANCADO") {
                        const switchChEl = document.getElementById('switchChannel');
                        if (switchChEl) spinModeOverride = getModeForChannel(parseInt(switchChEl.value, 10));
                    }
                    const wrapper = isPitchTranspose
                        ? newTransposeValueInput(selectId, parsedValue)
                        : newNumericInput(selectId, 0, 127, parsedValue, 'number', spinModeOverride);
                    wrapper.classList.add('spin-value-wrapper');
                    item.appendChild(wrapper);
                    const progWrap = document.createElement('div');
                    progWrap.className = 'macro-progress-wrap';
                    progWrap.innerHTML = `<div class="macro-progress-bg"><div class="macro-progress-fill" id="${selectId}_bar"></div><div class="macro-progress-text" id="${selectId}_label"></div></div>`;
                    item.appendChild(progWrap);
                    valuesRowCC1.appendChild(item);
                    const originalSelect = wrapper.querySelector('.original-select');
                    if (originalSelect) {
                        originalSelect.addEventListener('change', () => {
                            if (typeof updateCustomSelect === 'function') updateCustomSelect(selectId);
                            updateSpinProgressBar(selectId);
                        });
                    }
                    slotState.push({ selectId, selectEl: originalSelect });
                });
                cc1Block.appendChild(valuesRowCC1);
                group.appendChild(cc1Block);

                // CC2 block (DUPLO/TRIPLO)
                const sd = spinDataItem || {};
                const cc2Init = sd.cc2 != null ? parseInt(sd.cc2, 10) : 0;
                const cc2Block = document.createElement('div');
                cc2Block.id = `spinCC2Block_${spinIndex}`;
                cc2Block.style.cssText = 'margin-top:8px;padding:8px;background:rgba(255,255,255,0.04);border-radius:6px;border:1px solid #444;';
                const cc2Header = document.createElement('div');
                cc2Header.style.cssText = 'display:flex;align-items:center;gap:8px;margin-bottom:6px;';
                cc2Header.appendChild(newLabel('CC 2:'));
                let cc2ModeOverride;
                if (globalMidiMode === "MODO AVANCADO") {
                    const switchChEl = document.getElementById('switchChannel');
                    if (switchChEl) cc2ModeOverride = getModeForChannel(parseInt(switchChEl.value, 10));
                }
                const cc2Wrapper = newNumericInput(`spinCC2_${spinIndex}`, 0, 127, cc2Init, 'cc', cc2ModeOverride);
                cc2Wrapper.classList.add('spin-value-wrapper');
                const cc2Orig = cc2Wrapper.querySelector('.original-select');
                if (cc2Orig) cc2Orig.addEventListener('change', () => { try { updateLocalPresetDataFromUI(); } catch(_) {} });
                cc2Header.appendChild(cc2Wrapper);
                cc2Block.appendChild(cc2Header);
                const valRowCC2 = document.createElement('div');
                valRowCC2.className = 'spin-values-row';
                [{ label: 'Valor 1:', id: `spinV1cc2_${spinIndex}`, init: sd.v1cc2 != null ? parseInt(sd.v1cc2, 10) : 0 },
                 { label: 'Valor 2:', id: `spinV2cc2_${spinIndex}`, init: sd.v2cc2 != null ? parseInt(sd.v2cc2, 10) : 64 },
                 { label: 'Valor 3:', id: `spinV3cc2_${spinIndex}`, init: sd.v3cc2 != null ? parseInt(sd.v3cc2, 10) : 127 }].forEach(def => {
                    const item = document.createElement('div');
                    item.className = 'spin-value-item';
                    item.appendChild(newLabel(def.label));
                    const w = newNumericInput(def.id, 0, 127, def.init, 'number');
                    w.classList.add('spin-value-wrapper');
                    item.appendChild(w);
                    const progWrap = document.createElement('div');
                    progWrap.className = 'macro-progress-wrap';
                    progWrap.innerHTML = `<div class="macro-progress-bg"><div class="macro-progress-fill" id="${def.id}_bar"></div><div class="macro-progress-text" id="${def.id}_label"></div></div>`;
                    item.appendChild(progWrap);
                    valRowCC2.appendChild(item);
                    const orig = w.querySelector('.original-select');
                    if (orig) orig.addEventListener('change', () => { if (typeof updateCustomSelect === 'function') updateCustomSelect(def.id); updateSpinProgressBar(def.id); });
                });
                cc2Block.appendChild(valRowCC2);
                group.appendChild(cc2Block);

                // CC3 block (TRIPLO only)
                const cc3Init = sd.cc3 != null ? parseInt(sd.cc3, 10) : 0;
                const cc3Block = document.createElement('div');
                cc3Block.id = `spinCC3Block_${spinIndex}`;
                cc3Block.style.cssText = 'margin-top:8px;padding:8px;background:rgba(255,255,255,0.04);border-radius:6px;border:1px solid #555;';
                const cc3Header = document.createElement('div');
                cc3Header.style.cssText = 'display:flex;align-items:center;gap:8px;margin-bottom:6px;';
                cc3Header.appendChild(newLabel('CC 3:'));
                let cc3ModeOverride;
                if (globalMidiMode === "MODO AVANCADO") {
                    const switchChEl = document.getElementById('switchChannel');
                    if (switchChEl) cc3ModeOverride = getModeForChannel(parseInt(switchChEl.value, 10));
                }
                const cc3Wrapper = newNumericInput(`spinCC3_${spinIndex}`, 0, 127, cc3Init, 'cc', cc3ModeOverride);
                cc3Wrapper.classList.add('spin-value-wrapper');
                const cc3Orig = cc3Wrapper.querySelector('.original-select');
                if (cc3Orig) cc3Orig.addEventListener('change', () => { try { updateLocalPresetDataFromUI(); } catch(_) {} });
                cc3Header.appendChild(cc3Wrapper);
                cc3Block.appendChild(cc3Header);
                const valRowCC3 = document.createElement('div');
                valRowCC3.className = 'spin-values-row';
                [{ label: 'Valor 1:', id: `spinV1cc3_${spinIndex}`, init: sd.v1cc3 != null ? parseInt(sd.v1cc3, 10) : 0 },
                 { label: 'Valor 2:', id: `spinV2cc3_${spinIndex}`, init: sd.v2cc3 != null ? parseInt(sd.v2cc3, 10) : 64 },
                 { label: 'Valor 3:', id: `spinV3cc3_${spinIndex}`, init: sd.v3cc3 != null ? parseInt(sd.v3cc3, 10) : 127 }].forEach(def => {
                    const item = document.createElement('div');
                    item.className = 'spin-value-item';
                    item.appendChild(newLabel(def.label));
                    const w = newNumericInput(def.id, 0, 127, def.init, 'number');
                    w.classList.add('spin-value-wrapper');
                    item.appendChild(w);
                    const progWrap = document.createElement('div');
                    progWrap.className = 'macro-progress-wrap';
                    progWrap.innerHTML = `<div class="macro-progress-bg"><div class="macro-progress-fill" id="${def.id}_bar"></div><div class="macro-progress-text" id="${def.id}_label"></div></div>`;
                    item.appendChild(progWrap);
                    valRowCC3.appendChild(item);
                    const orig = w.querySelector('.original-select');
                    if (orig) orig.addEventListener('change', () => { if (typeof updateCustomSelect === 'function') updateCustomSelect(def.id); updateSpinProgressBar(def.id); });
                });
                cc3Block.appendChild(valRowCC3);
                group.appendChild(cc3Block);

                parentElement.appendChild(group);

                // Apply initial visibility and button text
                updateSpinCountBtn();

                slotState.forEach(slot => { if (slot) updateSpinProgressBar(slot.selectId); });
            }

            function generateSingleControlUI(parentElement, controlDataItem, controlIndex) {
                const group = document.createElement('div');
                group.className = 'extras-group';
                const controlHeader = document.createElement('h4');
                controlHeader.textContent = `CONTROL ${controlIndex + 1}`;
                group.appendChild(controlHeader);
                const inlineGroup = document.createElement('div');
                inlineGroup.className = 'control-inline-group';
                const ccContainer = document.createElement('div');
                ccContainer.className = 'control-cc-container';
                ccContainer.appendChild(newLabel(`CC:`));
                // CONTROL assumes base switch channel for CC since it doesn't have an independent channel selector
                let controlModeOverride;
                if (globalMidiMode === "MODO AVANCADO") {
                    const switchChEl = document.getElementById('switchChannel');
                    if (switchChEl) {
                        controlModeOverride = getModeForChannel(parseInt(switchChEl.value, 10));
                    }
                }
                const controlCcId = `controlCC_${controlIndex}`;
                ccContainer.appendChild(newNumericInput(controlCcId, 0, 127, controlDataItem.cc, 'cc', controlModeOverride));
                inlineGroup.appendChild(ccContainer);
                const toggleContainer = document.createElement('div');
                toggleContainer.className = 'control-toggle-container';
                // Remove extra textual label; toggle itself will show state (NORMAL / INVERT)
                newToggleSwitch(`controlInvertToggle_${controlIndex}`, controlDataItem.modo_invertido, toggleContainer);
                // ensure vertical centering when inserted
                toggleContainer.style.justifyContent = 'center';
                inlineGroup.appendChild(toggleContainer);
                group.appendChild(inlineGroup);
                parentElement.appendChild(group);
            }

            function generateSingleCustomUI(parentElement, customDataItem, customIndex, showOnlyOnValue = false, showCCChannel = false, switchIndex = 0) {
                const group = document.createElement('div');
                group.className = 'extras-group';
                const customHeader = document.createElement('h4');
                customHeader.textContent = `CUSTOM ${customIndex + 1}`;
                group.appendChild(customHeader);

                if (showCCChannel) {
                    const ccChannelRow = document.createElement('div');
                    ccChannelRow.className = 'pccc-entry-row';
                    const ccWrapper = document.createElement('div');
                    ccWrapper.className = 'pccc-value-wrapper';
                    ccWrapper.appendChild(newLabel(`CC:`));
                    const customCcId = `customCC_${switchIndex}_${customIndex}`;
                    const customCcMode = (globalMidiMode === "MODO AVANCADO") ? getModeForChannel(customDataItem.canal) : undefined;
                    ccWrapper.appendChild(newNumericInput(customCcId, 0, 127, customDataItem.cc, 'cc', customCcMode));
                    ccChannelRow.appendChild(ccWrapper);
                    const channelWrapper = document.createElement('div');
                    channelWrapper.className = 'pccc-channel-wrapper';
                    channelWrapper.appendChild(newLabel(`Canal:`));
                    const customChId = `customChannel_${switchIndex}_${customIndex}`;
                    channelWrapper.appendChild(newSelect(customChId, 0, 16, customDataItem.canal));
                    ccChannelRow.appendChild(channelWrapper);
                    
                    if (globalMidiMode === "MODO AVANCADO") {
                        setTimeout(() => {
                            const customChEl = document.getElementById(customChId);
                            if (customChEl) {
                                customChEl.addEventListener('change', () => {
                                    const newCh = parseInt(customChEl.value, 10);
                                    const newMode = getModeForChannel(newCh);
                                    const currentCcVal = parseInt(document.getElementById(customCcId)?.value, 10) || 0;
                                    populateNumericSelect(customCcId, 0, 127, currentCcVal, newMode);
                                    updateCustomSelect(customCcId);
                                });
                            }
                        }, 0);
                    }

                    group.appendChild(ccChannelRow);
                }

                const onContainer = document.createElement('div');
                onContainer.className = 'custom-value-container'; 
                onContainer.appendChild(newLabel(`Valor ON:`));
                const onSelectId = `customOn_${switchIndex}_${customIndex}`;
                const onInput = newNumericInput(onSelectId, 0, 127, customDataItem.valor_on);
                onContainer.appendChild(onInput);
                // progress bar ON
                const onProgWrap = document.createElement('div');
                onProgWrap.className = 'macro-progress-wrap';
                    onProgWrap.innerHTML = `<div class="macro-progress-bg"><div class="macro-progress-fill" id="${onSelectId}_bar"></div><div class="macro-progress-text" id="${onSelectId}_label"></div></div>`;
                    onContainer.appendChild(onProgWrap);

                if (!showOnlyOnValue) {
                    const inlineGroup = document.createElement('div');
                    inlineGroup.className = 'custom-inline-group';

                    const offContainer = document.createElement('div');
                    offContainer.className = 'custom-value-container'; 
                    offContainer.appendChild(newLabel(`Valor OFF:`));
                    const offSelectId = `customOff_${switchIndex}_${customIndex}`;
                    const offInput = newNumericInput(offSelectId, 0, 127, customDataItem.valor_off);
                    offContainer.appendChild(offInput);
                    // progress bar OFF
                    const offProgWrap = document.createElement('div');
                    offProgWrap.className = 'macro-progress-wrap';
                    offProgWrap.innerHTML = `<div class="macro-progress-bg"><div class="macro-progress-fill" id="${offSelectId}_bar"></div><div class="macro-progress-text" id="${offSelectId}_label"></div></div>`;
                    offContainer.appendChild(offProgWrap);

                    inlineGroup.appendChild(offContainer);
                    inlineGroup.appendChild(onContainer); 
                    group.appendChild(inlineGroup);
                } else {
                    onContainer.style.width = '100%'; 
                    group.appendChild(onContainer);
                }
                
                parentElement.appendChild(group);

                const pbIds = [onSelectId];
                if (!showOnlyOnValue) pbIds.push(`customOff_${switchIndex}_${customIndex}`);
                bindProgressBars(pbIds, updateSpinProgressBar);
            }
            
            function generatePcCcFields(gridContainer, extrasData) {
                if (!gridContainer) {
                    console.warn("generatePcCcFields: Grid container para PC Extras nao encontrado.");
                    return;
                }
                gridContainer.innerHTML = '';

                const currentPresetExtras = extrasData || getDefaultExtrasData();
                const enviarExtrasInitialState = currentPresetExtras?.enviar_extras || false;
                const sendExtrasToggleGroup = document.createElement('div');
                sendExtrasToggleGroup.className = 'extras-group';
                const extrasSendToggleLabel = newLabel("Enviar EXTRAS:");
                newToggleSwitch('extrasSendToggle', enviarExtrasInitialState, sendExtrasToggleGroup);
                sendExtrasToggleGroup.appendChild(extrasSendToggleLabel);
                gridContainer.appendChild(sendExtrasToggleGroup);
 
                const pcArray = currentPresetExtras?.pc || [];
                if (pcArray && pcArray.length > 0) {
                    pcArray.forEach((pcItem, i) => {
                        if (i < 4) {
                            const group = document.createElement('div');
                            group.className = 'extras-group';
                            
                            const header = document.createElement('h4');
                            header.textContent = `PC EXTRA ${i + 1}`;
                            group.appendChild(header);
 
                            const entryRow = document.createElement('div');
                            entryRow.className = 'pccc-entry-row';
 
                            const valueWrapper = document.createElement('div');
                            valueWrapper.className = 'pccc-value-wrapper';
                            valueWrapper.appendChild(newLabel(`Valor PC:`));
                            
                            const rawPcCanal = pcItem.canal !== undefined ? pcItem.canal : 1;
                            const parsedPcCanal = parseInt(rawPcCanal, 10);
                            const extraPcCanal = (!isNaN(parsedPcCanal) && parsedPcCanal >= 0 && parsedPcCanal <= 16)
                                ? parsedPcCanal
                                : 1;
                            const extraPcMode = (globalMidiMode === "MODO AVANCADO") ? getModeForChannel(extraPcCanal) : undefined;
                            
                            const pcValueId = `pcValue_${i}`;
                            valueWrapper.appendChild(newNumericInput(pcValueId, 0, 127, (typeof pcItem.valor === 'number' ? pcItem.valor : 0), 'pc', extraPcMode));
                            entryRow.appendChild(valueWrapper);
 
                            const pcChId = `pcChannel_${i}`;
                            const channelWrapper = document.createElement('div');
                            channelWrapper.className = 'pccc-channel-wrapper';
                            channelWrapper.appendChild(newLabel(`Canal PC:`));
                            channelWrapper.appendChild(newSelect(pcChId, 0, 16, extraPcCanal));
                            entryRow.appendChild(channelWrapper);
                            
                            // Em MODO AVANCADO, ao mudar o canal do extra PC, repopula PC labels
                            if (globalMidiMode === "MODO AVANCADO") {
                                setTimeout(() => {
                                    const pcChEl = document.getElementById(pcChId);
                                    if (pcChEl) {
                                        pcChEl.addEventListener('change', () => {
                                            const newCh = parseInt(pcChEl.value, 10);
                                            const newMode = getModeForChannel(newCh);
                                            const currentPcVal = parseInt(document.getElementById(pcValueId)?.value, 10) || 0;
                                            populateNumericSelect(pcValueId, 0, 127, currentPcVal, newMode);
                                            updateCustomSelect(pcValueId);
                                        });
                                    }
                                }, 0);
                            }
 
                            group.appendChild(entryRow);
                            gridContainer.appendChild(group);
                        }
                    });
                }

                const ccArray = currentPresetExtras?.cc || getDefaultExtrasData().cc;
                if (ccArray && ccArray.length > 0) {
                    ccArray.forEach((ccItem, i) => {
                        if (i < 2) {
                            const group = document.createElement('div');
                            group.className = 'extras-group';
                            
                            const header = document.createElement('h4');
                            header.textContent = `CC EXTRA ${i + 1}`;
                            group.appendChild(header);

                            const entryRow = document.createElement('div');
                            entryRow.className = 'pccc-entry-row';

                            const ccNumWrapper = document.createElement('div');
                            ccNumWrapper.className = 'pccc-value-wrapper';
                            ccNumWrapper.appendChild(newLabel(`CC:`));
                            const rawCanal = ccItem.canal !== undefined ? ccItem.canal : 1;
                            const parsedCcCanal = parseInt(rawCanal, 10);
                            const extraCcCanal = (!isNaN(parsedCcCanal) && parsedCcCanal >= 0 && parsedCcCanal <= 16)
                                ? parsedCcCanal
                                : 1;
                            // Em MODO AVANCADO, usa o modo do canal proprio do extra CC
                            const extraCcMode = (globalMidiMode === "MODO AVANCADO") ? getModeForChannel(extraCcCanal) : undefined;
                            const ccNumId = `ccNum_${i}`;
                            ccNumWrapper.appendChild(newNumericInput(ccNumId, 0, 127, (typeof ccItem.cc === 'number' ? ccItem.cc : 0), 'cc', extraCcMode));
                            entryRow.appendChild(ccNumWrapper);

                            const ccValWrapper = document.createElement('div');
                            ccValWrapper.className = 'pccc-value-wrapper';
                            ccValWrapper.appendChild(newLabel(`Valor:`));
                            ccValWrapper.appendChild(newNumericInput(`ccVal_${i}`, 0, 127, (typeof ccItem.valor === 'number' ? ccItem.valor : 0)));
                            entryRow.appendChild(ccValWrapper);

                            const ccChId = `ccChannel_${i}`;
                            const ccChWrapper = document.createElement('div');
                            ccChWrapper.className = 'pccc-channel-wrapper';
                            ccChWrapper.appendChild(newLabel(`Canal:`));
                            ccChWrapper.appendChild(newSelect(ccChId, 0, 16, extraCcCanal));
                            entryRow.appendChild(ccChWrapper);

                            // Em MODO AVANCADO, ao mudar o canal do extra CC, repopula CC labels
                            if (globalMidiMode === "MODO AVANCADO") {
                                setTimeout(() => {
                                    const ccChEl = document.getElementById(ccChId);
                                    if (ccChEl) {
                                        ccChEl.addEventListener('change', () => {
                                            const newCh = parseInt(ccChEl.value, 10);
                                            const newMode = getModeForChannel(newCh);
                                            const currentCcVal = parseInt(document.getElementById(ccNumId)?.value, 10) || 0;
                                            populateNumericSelect(ccNumId, 0, 127, currentCcVal, newMode);
                                            updateCustomSelect(ccNumId);
                                        });
                                    }
                                }, 0);
                            }

                            group.appendChild(entryRow);
                            gridContainer.appendChild(group);
                        }
                    });
                }
            }

            function newLabel(text) { 
                const label = document.createElement('label');
                label.textContent = text;
                return label;
            }
            function newNumericInput(id, min, max, value, inputType = 'number', modeOverride) {
                const originalSelect = document.createElement('select');
                originalSelect.id = id;
                originalSelect.className = 'original-select';

                const normalizedValue = parseInt(value, 10);

                // Determina o modo para labels CC
                let ccMode2;
                if (modeOverride) {
                    ccMode2 = modeOverride;
                } else if (globalMidiMode === "MODO AVANCADO") {
                    const chEl = document.getElementById('switchChannel');
                    ccMode2 = chEl ? getModeForChannel(parseInt(chEl.value, 10)) : getEffectiveMidiMode();
                } else {
                    ccMode2 = getEffectiveMidiMode();
                }
                if (inputType === 'cc' && ccMode2 === "KEMPER PLAYER") {
                    appendKemperSpecialCCGroups(originalSelect, normalizedValue);
                }

                for (let i = min; i <= max; i++) {
                    const option = document.createElement('option');
                    option.value = i;
                    let displayText = i;
                    if (inputType === 'cc') {
                        let lbl = "?";
                        if (ccMode2 === "AMPERO AS2" || ccMode2 === "AMPERO MP350") {
                            lbl = getCC_AMPEROST2_Name(i);
                        } else if (ccMode2 === "AMPERO MINI") {
                            lbl = getCC_AMPERO_MINI_Names(i);
                        } else if (ccMode2 === "MX5") {
                            lbl = getCC_MX5_Names(i);
                        } else if (ccMode2 === "GP-200LT") {
                            lbl = getCC_GP200LT_Names(i);
                        } else if (ccMode2 === "POCKET MASTER") {
                            lbl = getCC_POCKET_MASTER_Names(i);
                        } else if (ccMode2 === "KEMPER PLAYER") {
                            lbl = getCC_KEMPER_PLAYER_Names(i);
                        } else if (ccMode2 === "TONEX") {
                            lbl = getCC_TONEX_Name(i);
                        } else if (ccMode2 === "VALETON GP5") {
                            lbl = getCC_VALETON_GP5_Names(i);
                        } else if (ccMode2 === "QUAD CORTEX") {
                            lbl = getCC_QUAD_CORTEX_Names(i);
                        } else if (ccMode2 === "HX STOMP") {
                            lbl = getCC_HX_STOMP_Names(i);
                        } else if (ccMode2 === "SYNERGY AMPS") {
                            lbl = getCC_SYN2_Names(i);
                        } else if (ccMode2 === "BigSky") {
                            lbl = getCC_BIGSKY_Names(i);
                        } else if (ccMode2 === "BlueSky") {
                            lbl = (typeof getCC_BLUESKY_Names === 'function') ? getCC_BLUESKY_Names(i) : "?";
                        } else if (ccMode2 === "TimeLine") {
                            lbl = getCC_TIMELINE_Names(i);
                        } else if (ccMode2 === "ELCAPISTAN") {
                            lbl = getCC_ELCAPISTAN_Names(i);
                        } else if (ccMode2 === "FLINT") {
                            lbl = getCC_FLINT_Names(i);
                        } else if (ccMode2 === "HX-ONE") {
                            lbl = getCC_HXONE_Names(i);
                        } else if (ccMode2 === "VTR NARCISO") {
                            lbl = getCC_VTR_NARCISO_Names(i);
                        } else if (ccMode2 === "VTR LOKI") {
                            lbl = getCC_VTR_LOKI_Names(i);
                        } else if (ccMode2 === "VTR KAILANI") {
                            lbl = getCC_KAILANI_Names(i);
                        }
                        if (lbl !== "?") displayText = i + " - " + lbl;
                    } else if (inputType === 'pc') {
                        let lbl;
                        if (ccMode2 === "AMPERO AS2") lbl = typeof bank_AS2_Names !== 'undefined' ? bank_AS2_Names[i] : undefined;
                        else if (ccMode2 === "HX STOMP") lbl = typeof bank_HX_STOMP_Names !== 'undefined' ? bank_HX_STOMP_Names[i] : undefined;
                        else if (ccMode2 === "AMPERO MINI") lbl = typeof bank_AMPERO_MINI_Names !== 'undefined' ? bank_AMPERO_MINI_Names[i] : undefined;
                        else if (ccMode2 === "A. STAGE 2") lbl = typeof bank_ASTG2_Names !== 'undefined' ? bank_ASTG2_Names[i] : undefined;
                        else if (ccMode2 === "GP-200LT") lbl = typeof bank_GP200LT_Names !== 'undefined' ? bank_GP200LT_Names[i] : undefined;
                        else if (ccMode2 === "VALETON GP5") lbl = typeof bank_VALETON_GP5_Names !== 'undefined' ? bank_VALETON_GP5_Names[i] : undefined;
                        else if (ccMode2 === "POCKET MASTER") lbl = typeof bank_POCKET_MASTER_Names !== 'undefined' ? bank_POCKET_MASTER_Names[i] : undefined;
                        else if (ccMode2 === "KEMPER PLAYER") lbl = typeof bank_KEMPER_PLAYER_Names !== 'undefined' ? bank_KEMPER_PLAYER_Names[i] : undefined;
                        else if (ccMode2 === "TONEX") lbl = typeof bank_TONEX_Names !== 'undefined' ? bank_TONEX_Names[i] : undefined;
                        else if (ccMode2 === "AMPERO MP350") lbl = typeof bank_AMPERO_MP350_Names !== 'undefined' ? bank_AMPERO_MP350_Names[i] : undefined;
                        else if (ccMode2 === "BigSky") lbl = typeof bank_BIGSKY_Names !== 'undefined' ? bank_BIGSKY_Names[i] : undefined;
                        else if (ccMode2 === "BlueSky") lbl = typeof bank_BLUESKY_Names !== 'undefined' ? bank_BLUESKY_Names[i] : undefined;
                        else if (ccMode2 === "TimeLine") lbl = typeof bank_TIMELINE_Names !== 'undefined' ? bank_TIMELINE_Names[i] : undefined;
                        if (lbl !== undefined) displayText = i + " - " + lbl;
                    }
                    option.textContent = displayText;
                    if (i === normalizedValue) option.selected = true;
                    originalSelect.appendChild(option);
                }
                return wrapSelect(originalSelect, id);
            }



            function bindProgressBars(ids, fn) {
                setTimeout(() => { ids.forEach(id => { fn(id); const el = document.getElementById(id); if (el) { el.addEventListener('input', () => fn(id)); el.addEventListener('change', () => fn(id)); } }); }, 0);
            }

            function appendValueField(parent, id, label, val) {
                const c = document.createElement('div');
                c.className = 'custom-value-container';
                c.appendChild(newLabel(label));
                c.appendChild(newNumericInput(id, 0, 127, val));
                const pw = document.createElement('div');
                pw.className = 'macro-progress-wrap';
                pw.innerHTML = '<div class="macro-progress-bg"><div class="macro-progress-fill" id="' + id + '_bar"></div><div class="macro-progress-text" id="' + id + '_label"></div></div>';
                c.appendChild(pw);
                parent.appendChild(c);
            }

            // Create a value input for Pitch Transpose (range 28-100 with musical labels)
            function newTransposeValueInput(id, value) {
                const originalSelect = document.createElement('select');
                originalSelect.id = id;
                originalSelect.className = 'original-select';

                const normalizedValue = parseInt(value, 10);
                const clampedValue = Math.max(28, Math.min(100, isNaN(normalizedValue) ? 64 : normalizedValue));

                for (let i = 28; i <= 100; i++) {
                    const option = document.createElement('option');
                    option.value = i;
                    const label = kemperTransposeLabels[i] || i.toString();
                    option.textContent = `${i} - ${label}`;
                    if (i === clampedValue) option.selected = true;
                    originalSelect.appendChild(option);
                }
                return wrapSelect(originalSelect, id);
            }

            function newToggleSwitch(id, initialChecked, parentElement) { 
                const container = document.createElement('div');
                container.className = 'toggle-switch-container';
                const label = document.createElement('label');
                label.className = 'toggle-label';
                label.htmlFor = id;
                const checkboxInput = document.createElement('input');
                checkboxInput.type = 'checkbox';
                checkboxInput.id = id;
                checkboxInput.checked = initialChecked;
                // checkboxInput.onchange = updateLocalPresetDataFromUI;
                const toggleDiv = document.createElement('div');
                toggleDiv.className = 'toggle-switch';
                const sliderDiv = document.createElement('div');
                sliderDiv.className = 'toggle-slider';
                toggleDiv.appendChild(sliderDiv);
                label.appendChild(checkboxInput);
                label.appendChild(toggleDiv);
                container.appendChild(label);
                parentElement.appendChild(container);
                return label;
            }
            function newSelect(id, min, max, value) { 
                const originalSelect = document.createElement('select');
                originalSelect.id = id;
                originalSelect.className = 'original-select';
                const normalizedValue = parseInt(value, 10);
                const isChannelSelect = isChannelSelectId(id);
                for (let i = min; i <= max; i++) {
                    const option = document.createElement('option');
                    option.value = i;
                    let txt = i;
                    if (isChannelSelect && i === 0) {
                        txt = 'X';
                    } else if (isChannelSelect && i > 0 && globalMidiMode === "MODO AVANCADO") {
                        const cellMode = typeof getModeForChannel === 'function' ? getModeForChannel(i) : undefined;
                        if (cellMode && cellMode !== "GLOBAL") {
                            txt = `${i} - ${cellMode}`;
                        }
                    }
                    option.textContent = txt;
                    if (i === normalizedValue) option.selected = true;
                    originalSelect.appendChild(option);
                }
                const wrapper = document.createElement('div');
                wrapper.className = 'custom-select-wrapper';
                wrapper.dataset.selectId = id;
                const trigger = document.createElement('div');
                trigger.className = 'custom-select-trigger';
                trigger.tabIndex = 0;
                const selectedValueSpan = document.createElement('span');
                selectedValueSpan.className = 'custom-select-selected-value';
                const arrow = document.createElement('span');
                arrow.className = 'custom-select-arrow-down';
                trigger.appendChild(selectedValueSpan);
                trigger.appendChild(arrow);
                const optionsDiv = document.createElement('div');
                optionsDiv.className = 'custom-select-options';
                wrapper.appendChild(trigger);
                wrapper.appendChild(optionsDiv);
                wrapper.appendChild(originalSelect);
                originalSelect.addEventListener('change', updateLocalPresetDataFromUI);
                return wrapper;
            }

            function hideSwitchConfigArea() {
                // Esconde a Ã¡rea de configuraÃ§Ã£o do switch e o card GIG VIEW
                const switchConfigArea = document.getElementById('switchConfigArea');
                const displayConfigCard = document.getElementById('displayConfigCard');
                const extrasHeaderCard = document.querySelector('.extras-header-card');
                const extrasPcCcSection = document.getElementById('extrasPcCcSection');

                if (switchConfigArea) switchConfigArea.style.display = 'none';
                if (displayConfigCard) displayConfigCard.style.display = 'none';
                if (extrasHeaderCard) extrasHeaderCard.style.display = 'none';
                if (extrasPcCcSection) extrasPcCcSection.style.display = 'none';
            }

            function showSwitchConfigArea() {
                // Mostra a Ã¡rea de configuraÃ§Ã£o do switch e o card GIG VIEW
                const switchConfigArea = document.getElementById('switchConfigArea');
                const displayConfigCard = document.getElementById('displayConfigCard');
                const extrasHeaderCard = document.querySelector('.extras-header-card');

                if (switchConfigArea) switchConfigArea.style.display = 'block';
                if (displayConfigCard) displayConfigCard.style.display = 'block';
                if (extrasHeaderCard) extrasHeaderCard.style.display = 'block';
            }

            function loadPresetDataToUI(colIndex, rowIndex) {
                const globalIndex = colIndex * NUM_PRESET_ROWS + rowIndex;
                const presetNameColorPreviewBox = document.getElementById('selectedPresetNameColorPreviewBox');
                const presetBgColorPreviewBox = document.getElementById('selectedPresetBgColorPreviewBox');
                const backTagColorPreviewBox = document.getElementById('selectedBackTagColorPreviewBox');
                const presetData = getSharedPresetDataForIndex(globalIndex, colIndex, rowIndex);
                if (!presetData) {
                    const defaultPData = getSingleDefaultPresetData(colIndex, rowIndex);
                    syncPresetNameFontButton(defaultPData.nomePresetFont || 2);
                    document.getElementById('presetNameInput').value = resolvePresetNameForEditor(defaultPData.nomePreset, defaultPData.nomePresetFont || 2);
                    if (presetNameColorPreviewBox) applyColorPreview(presetNameColorPreviewBox, getPaletteColorByValue(PRESET_DIRECT_COLORS_WEB, defaultPData.nomePresetTextColor), 'bar');
                    if (presetBgColorPreviewBox) applyColorPreview(presetBgColorPreviewBox, getPaletteColorByValue(PRESET_DIRECT_COLORS_WEB, defaultPData.backgroundColorConfig || 0), 'bar');
                    if (backTagColorPreviewBox) applyColorPreview(backTagColorPreviewBox, getPaletteColorByValue(PRESET_DIRECT_COLORS_WEB, defaultPData.backTagColor || 0x1E1E23), 'bar');
                    document.getElementById('presetChannelInput').value = defaultPData.canal;
                    // Em MODO AVANCADO, repopula bank labels pelo canal do preset
                    if (globalMidiMode === "MODO AVANCADO") {
                        const chMode = getModeForChannel(defaultPData.canal);
                        const bankSelectId = 'presetBankInput';
                    if (chMode === "GLOBAL" || chMode === "MX5" || chMode === "NANO CORTEX" || chMode === "QUAD CORTEX" || chMode === "SYNERGY AMPS" || chMode === "VTR KAILANI") {
                            populateNumericSelect(bankSelectId, 0, 299, defaultPData.bank, chMode);
                        } else if (chMode === "AMPERO AS2") populateBankLabels(bankSelectId, bank_AS2_Names, defaultPData.bank);
                        else if (chMode === "HX STOMP") populateBankLabels(bankSelectId, bank_HX_STOMP_Names, defaultPData.bank);
                        else if (chMode === "AMPERO MINI") populateBankLabels(bankSelectId, bank_AMPERO_MINI_Names, defaultPData.bank);
                        else if (chMode === "A. STAGE 2") populateBankLabels(bankSelectId, bank_ASTG2_Names, defaultPData.bank);
                        else if (chMode === "GP-200LT") populateBankLabels(bankSelectId, bank_GP200LT_Names, defaultPData.bank);
                        else if (chMode === "VALETON GP5") populateBankLabels(bankSelectId, bank_VALETON_GP5_Names, defaultPData.bank);
                        else if (chMode === "POCKET MASTER") populateBankLabels(bankSelectId, bank_POCKET_MASTER_Names, defaultPData.bank);
                        else if (chMode === "KEMPER PLAYER") populateBankLabels(bankSelectId, bank_KEMPER_PLAYER_Names, defaultPData.bank);
                        else if (chMode === "TONEX") populateBankLabels(bankSelectId, bank_TONEX_Names, defaultPData.bank);
                        else if (chMode === "AMPERO MP350") populateBankLabels(bankSelectId, bank_AMPERO_MP350_Names, defaultPData.bank);
                        else if (chMode === "BigSky") populateBankLabels(bankSelectId, bank_BIGSKY_Names, defaultPData.bank);
                        else if (chMode === "BlueSky") populateBankLabels(bankSelectId, bank_BLUESKY_Names, defaultPData.bank);
                        else if (chMode === "TimeLine") populateBankLabels(bankSelectId, bank_TIMELINE_Names, defaultPData.bank);
                        else populateNumericSelect(bankSelectId, 0, 299, defaultPData.bank, chMode);
                    }
                    document.getElementById('presetBankInput').value = defaultPData.bank;
                    updateCustomSelect('presetBankInput');
                    updateCustomSelect('presetChannelInput');
                    return;
                }
                syncPresetNameFontButton(presetData.nomePresetFont || 2);
                document.getElementById('presetNameInput').value = resolvePresetNameForEditor(presetData.nomePreset || "", presetData.nomePresetFont || 2);
                if (presetNameColorPreviewBox) applyColorPreview(presetNameColorPreviewBox, getPaletteColorByValue(PRESET_DIRECT_COLORS_WEB, presetData.nomePresetTextColor || 0xFFFFFF), 'bar');
                if (presetBgColorPreviewBox) applyColorPreview(presetBgColorPreviewBox, getPaletteColorByValue(PRESET_DIRECT_COLORS_WEB, presetData.backgroundColorConfig || 0), 'bar');
                if (backTagColorPreviewBox) applyColorPreview(backTagColorPreviewBox, getPaletteColorByValue(PRESET_DIRECT_COLORS_WEB, presetData.backTagColor || 0x1E1E23), 'bar');
                const presetCanal = presetData.canal !== undefined ? presetData.canal : 1;
                const presetBank = presetData.bank !== undefined ? presetData.bank : 0;
                document.getElementById('presetChannelInput').value = presetCanal;
                // Em MODO AVANCADO, repopula bank labels pelo canal do preset
                if (globalMidiMode === "MODO AVANCADO") {
                    const chMode = getModeForChannel(presetCanal);
                    const bankSelectId = 'presetBankInput';
                    if (chMode === "GLOBAL" || chMode === "MX5" || chMode === "NANO CORTEX" || chMode === "QUAD CORTEX" || chMode === "SYNERGY AMPS" || chMode === "VTR NARCISO" || chMode === "VTR LOKI" || chMode === "VTR KAILANI") {
                        populateNumericSelect(bankSelectId, 0, 299, presetBank, chMode);
                    } else if (chMode === "AMPERO AS2") populateBankLabels(bankSelectId, bank_AS2_Names, presetBank);
                    else if (chMode === "HX STOMP") populateBankLabels(bankSelectId, bank_HX_STOMP_Names, presetBank);
                    else if (chMode === "AMPERO MINI") populateBankLabels(bankSelectId, bank_AMPERO_MINI_Names, presetBank);
                    else if (chMode === "A. STAGE 2") populateBankLabels(bankSelectId, bank_ASTG2_Names, presetBank);
                    else if (chMode === "GP-200LT") populateBankLabels(bankSelectId, bank_GP200LT_Names, presetBank);
                    else if (chMode === "VALETON GP5") populateBankLabels(bankSelectId, bank_VALETON_GP5_Names, presetBank);
                    else if (chMode === "POCKET MASTER") populateBankLabels(bankSelectId, bank_POCKET_MASTER_Names, presetBank);
                    else if (chMode === "KEMPER PLAYER") populateBankLabels(bankSelectId, bank_KEMPER_PLAYER_Names, presetBank);
                    else if (chMode === "TONEX") populateBankLabels(bankSelectId, bank_TONEX_Names, presetBank);
                    else if (chMode === "AMPERO MP350") populateBankLabels(bankSelectId, bank_AMPERO_MP350_Names, presetBank);
                    else if (chMode === "BigSky") populateBankLabels(bankSelectId, bank_BIGSKY_Names, presetBank);
                    else if (chMode === "BlueSky") populateBankLabels(bankSelectId, bank_BLUESKY_Names, presetBank);
                    else if (chMode === "TimeLine") populateBankLabels(bankSelectId, bank_TIMELINE_Names, presetBank);
                    else populateNumericSelect(bankSelectId, 0, 299, presetBank, chMode);
                }
                document.getElementById('presetBankInput').value = presetBank;
                updateCustomSelect('presetBankInput');
                updateCustomSelect('presetChannelInput');
            }

            function createRampField(labelText, id, value = 0) {
                const container = document.createElement('div');
                container.className = 'custom-value-container ramp-field';

                const lbl = newLabel(labelText);
                container.appendChild(lbl);

                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'ramp-display';
                btn.id = `${id}_display`;
                btn.textContent = `${value} ms`;
                container.appendChild(btn);

                const sel = document.createElement('select');
                sel.id = id;
                sel.className = 'original-select';
                sel.style.display = 'none';
                for (let v = 0; v <= 3000; v += 50) {
                    const opt = document.createElement('option');
                    opt.value = v;
                    opt.textContent = v;
                    if (v === value) opt.selected = true;
                    sel.appendChild(opt);
                }
                container.appendChild(sel);

                const sliderWrap = document.createElement('div');
                sliderWrap.className = 'mini-field-slider-wrap';
                const slider = document.createElement('input');
                slider.type = 'range';
                slider.className = 'mini-field-slider';
                slider.min = '0';
                slider.max = '3000';
                slider.step = '50';
                slider.value = String(value);
                sliderWrap.appendChild(slider);
                container.appendChild(sliderWrap);

                const syncSliderFill = () => {
                    const min = parseInt(slider.min, 10) || 0;
                    const max = parseInt(slider.max, 10) || 3000;
                    const v = parseInt(slider.value, 10) || 0;
                    const den = Math.max(1, max - min);
                    const p = Math.round(((v - min) / den) * 100);
                    slider.style.background = `linear-gradient(to right, #7fa6e8 ${p}%, #2a2e33 ${p}%)`;
                };

                const applySliderValueToSelect = () => {
                    let v = parseInt(slider.value, 10);
                    if (Number.isNaN(v)) v = 0;
                    v = Math.max(0, Math.min(3000, Math.round(v / 50) * 50));
                    slider.value = String(v);
                    syncSliderFill();

                    if (sel.value !== String(v)) {
                        sel.value = String(v);
                        sel.dispatchEvent(new Event('change', { bubbles: true }));
                    } else {
                        updateLocalPresetDataFromUI();
                    }
                };

                btn.addEventListener('click', () => {
                    slider.focus();
                });
                slider.addEventListener('input', applySliderValueToSelect);
                slider.addEventListener('change', applySliderValueToSelect);
                syncSliderFill();

                const syncLabel = () => {
                    btn.textContent = `${sel.value} ms`;
                    if (slider.value !== String(sel.value)) {
                        slider.value = String(sel.value);
                        syncSliderFill();
                    }
                };
                sel.addEventListener('change', () => {
                    syncLabel();
                    updateLocalPresetDataFromUI();
                });
                sel.addEventListener('input', syncLabel);

                return container;
            }

            function getSelectedValueLabel(selectEl) {
                if (!selectEl || !selectEl.options) return '';
                const opt = selectEl.options[selectEl.selectedIndex];
                if (!opt) return '';
                const text = opt.textContent || '';
                const sep = text.indexOf(' - ');
                if (sep >= 0) return text.slice(sep + 3);
                if (typeof getKemperLabelForValueSelect === 'function') {
                    return getKemperLabelForValueSelect(selectEl) || '';
                }
                return '';
            }
            function updateMacroProgress(valueInputId) {
                const inputEl = document.getElementById(valueInputId);
                const fillEl = document.getElementById(`${valueInputId}_bar`);
                const labelEl = document.getElementById(`${valueInputId}_label`);
                if (!inputEl || !fillEl) return;
                const raw = parseInt(inputEl.value, 10);
                const clamped = Math.min(127, Math.max(0, isNaN(raw) ? 0 : raw));
                const pct = Math.round((clamped / 127) * 100);
                const labelText = getSelectedValueLabel(inputEl);
                if (labelText) {
                    fillEl.style.width = '100%';
                    if (labelEl) labelEl.textContent = labelText;
                } else {
                    fillEl.style.width = `${pct}%`;
                    if (labelEl) labelEl.textContent = `${pct}%`;
                }
            }

            function generateMacrosUI(container, switchData, switchIndex) {
                const macrosSource = Array.isArray(switchData.macros) ? switchData.macros : [];
                const normalizeMacro = (entry) => {
                    const data = entry || {};
                    const cc = typeof data.cc === 'number' ? data.cc : 0;
                    const valueOff = typeof data.valueOff === 'number'
                        ? data.valueOff
                        : (typeof data.off === 'number' ? data.off : 0);
                    const valueOn = typeof data.valueOn === 'number'
                        ? data.valueOn
                        : (typeof data.on === 'number' ? data.on : 127);
                    const rawCh = data.channel !== undefined ? data.channel : (data.ch !== undefined ? data.ch : 1);
                    const channel = parseInt(rawCh, 10) || 1;
                    return { cc, valueOff, valueOn, channel };
                };
                const macros = Array.from({ length: 4 }, (_, idx) => normalizeMacro(macrosSource[idx]));

                const wrapper = document.createElement('div');
                wrapper.className = 'macros-config-wrapper';

                for (let i = 0; i < 4; i++) {
                    const m = macros[i];
                    
                    const row = document.createElement('div');
                    row.className = 'form-group macro-row';
                    row.style.cssText = 'border:1px solid #444; padding:8px; margin-bottom:8px; border-radius:4px; background:rgba(0,0,0,0.2);';
                    
                    const title = document.createElement('div');
                    title.style.cssText = 'font-weight:bold; margin-bottom:5px; color:#aaa; font-size:0.9em;';
                    title.textContent = `MACRO ${i + 1}`;
                    row.appendChild(title);

                    // Row 1: CC and Channel
                    const line1 = document.createElement('div');
                    line1.className = 'custom-inline-group';
                    
                    const ccDiv = document.createElement('div');
                    ccDiv.className = 'custom-value-container';
                    ccDiv.appendChild(newLabel('CC:'));
                    const macroCcId = `macro_cc_${switchIndex}_${i}`;
                    // Em MODO AVANCADO, usa o modo do canal proprio da macro
                    const macroCcMode = (globalMidiMode === "MODO AVANCADO") ? getModeForChannel(m.channel) : undefined;
                    const macroCcWrapper = newNumericInput(macroCcId, 0, 127, m.cc, 'cc', macroCcMode);
                    ccDiv.appendChild(macroCcWrapper);
                    const macroCcSelect = macroCcWrapper.querySelector('select');
                    line1.appendChild(ccDiv);

                    const chDiv = document.createElement('div');
                    chDiv.className = 'custom-value-container';
                    chDiv.appendChild(newLabel('Ch:'));
                    const macroChSelectId = `macro_ch_${switchIndex}_${i}`;
                    chDiv.appendChild(newSelect(macroChSelectId, 0, 16, m.channel));
                    line1.appendChild(chDiv);
                    
                    row.appendChild(line1);

                    // Row 2: Value Off and Value On
                    const line2 = document.createElement('div');
                    line2.className = 'custom-inline-group';
                    
                    const offDiv = document.createElement('div');
                    offDiv.className = 'custom-value-container';
                    offDiv.appendChild(newLabel('Val Off:'));
                    const offInputId = `macro_off_${switchIndex}_${i}`;
                    const offInputEl = newNumericInput(offInputId, 0, 127, m.valueOff);
                    offInputEl.classList.add('macro-input');
                    offDiv.appendChild(offInputEl);
                    const offProgWrap = document.createElement('div');
                    offProgWrap.className = 'macro-progress-wrap';
                    offProgWrap.innerHTML = `<div class="macro-progress-bg"><div class="macro-progress-fill" id="macro_off_${switchIndex}_${i}_bar"></div><div class="macro-progress-text" id="macro_off_${switchIndex}_${i}_label"></div></div>`;
                    offDiv.appendChild(offProgWrap);
                    line2.appendChild(offDiv);

                    const onDiv = document.createElement('div');
                    onDiv.className = 'custom-value-container';
                    onDiv.appendChild(newLabel('Val On:'));
                    const onInputId = `macro_on_${switchIndex}_${i}`;
                    const onInputEl = newNumericInput(onInputId, 0, 127, m.valueOn);
                    onInputEl.classList.add('macro-input');
                    onDiv.appendChild(onInputEl);
                    const onProgWrap = document.createElement('div');
                    onProgWrap.className = 'macro-progress-wrap';
                    onProgWrap.innerHTML = `<div class="macro-progress-bg"><div class="macro-progress-fill" id="macro_on_${switchIndex}_${i}_bar"></div><div class="macro-progress-text" id="macro_on_${switchIndex}_${i}_label"></div></div>`;
                    onDiv.appendChild(onProgWrap);
                    line2.appendChild(onDiv);

                    row.appendChild(line2);

                    wrapper.appendChild(row);

                    if (macroCcSelect) {
                        macroCcSelect.addEventListener('change', () => {
                            try {
                                if (typeof repopulateValueSelectsForCC === 'function') {
                                    repopulateValueSelectsForCC();
                                }
                            } catch(_) {}
                            updateMacroProgress(offInputId);
                            updateMacroProgress(onInputId);
                        });
                    }

                    // Em MODO AVANCADO, ao mudar o canal da macro, repopula CC labels
                    if (globalMidiMode === "MODO AVANCADO") {
                        setTimeout(() => {
                            const macroChEl = document.getElementById(macroChSelectId);
                            if (macroChEl) {
                                macroChEl.addEventListener('change', () => {
                                    const newCh = parseInt(macroChEl.value, 10);
                                    const newMode = getModeForChannel(newCh);
                                    const currentCcVal = parseInt(document.getElementById(macroCcId)?.value, 10) || 0;
                                    populateNumericSelect(macroCcId, 0, 127, currentCcVal, newMode);
                                    updateCustomSelect(macroCcId);
                                });
                            }
                        }, 0);
                    }

                    bindProgressBars([offInputId, onInputId], updateMacroProgress);
                }
                container.appendChild(wrapper);
            }

            // FX2 field is now permanently in the Display card (gigView2Group)
            // No need to move it around anymore

            function updateSwitchSpecificUI(modeValue, switchIndex) {
                const dynamicArea = document.getElementById('dynamicModeConfigArea');
                const ccGroup = document.getElementById('switchCC').closest('.form-group');
                const chGroup = document.getElementById('switchChannel').closest('.form-group');
                const globalPresetIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const layerIdx = currentLiveLayer - 1;
                const layerPresets = allPresetsData[layerIdx] || [];
                const presetData = layerPresets[globalPresetIndex];

                const ledGroup = document.querySelector('.led-group');
                const ledStartRow = document.querySelector('.switch-config-grid-led-start');
                const ccChRow = document.querySelector('.switch-config-grid-cc-ch');
                const configArea = dynamicArea ? dynamicArea.parentElement : null;
                const siglaFxGroup = document.getElementById('switchSiglaFx')?.closest('.form-group');

                const staleFavoriteInline = ledStartRow ? ledStartRow.querySelector('.favorite-inline-controls') : null;
                if (staleFavoriteInline) staleFavoriteInline.remove();
                if (ledStartRow) ledStartRow.classList.remove('favorite-mode-layout');
                document.getElementById('singleStompCardHeader')?.remove();
                document.getElementById('singleStompCustomWrap')?.remove();
                const singleCard = document.getElementById('singleStompCard');
                if (singleCard && configArea) {
                    if (ledStartRow && ledStartRow.parentElement === singleCard) configArea.insertBefore(ledStartRow, dynamicArea);
                    if (ccChRow && ccChRow.parentElement === singleCard) configArea.insertBefore(ccChRow, dynamicArea);
                    singleCard.remove();
                }

                dynamicArea.innerHTML = '';
                dynamicArea.style.display = 'none';
                ccGroup.style.display = 'block';
                chGroup.style.display = 'block'; 

                const mode = parseInt(modeValue, 10);

                if (mode === 99) { // MUTE
                    if(ccGroup) ccGroup.style.display = 'none';
                    if(chGroup) chGroup.style.display = 'none';
                    if(ledGroup) ledGroup.style.display = 'none';
                    if(siglaFxGroup) siglaFxGroup.style.display = 'none';
                    if(dynamicArea) dynamicArea.style.display = 'none';
                    const switchStartGroup = document.getElementById('switchStart')?.closest('.form-group');
                    if(switchStartGroup) switchStartGroup.style.display = 'none';
                    // Hide Display card for MUTE mode
                    const displayCard = document.getElementById('displayConfigCard');
                    if(displayCard) displayCard.style.display = 'none';
                    return; // Nothing else to do for MUTE mode
                } else {
                    // Ensure everything is visible by default before hiding specific elements for other modes
                    if(ccGroup) ccGroup.style.display = 'block';
                    if(chGroup) chGroup.style.display = 'block';
                    if(ledGroup) ledGroup.style.display = 'block';
                    if(siglaFxGroup) siglaFxGroup.style.display = 'block';
                    // Show Display card
                    const displayCard = document.getElementById('displayConfigCard');
                    if(displayCard) displayCard.style.display = 'block';
                }
    
                const DUAL_STOMP_MODE_VALUE = 28;
                const FAVORITE_MODE_VALUE = 17;
                const isSpin = (mode >= 1 && mode <= 3) || (mode >= 38 && mode <= 43);
                const isSpinHold = (mode >= 35 && mode <= 37) || (mode >= 44 && mode <= 46);
                const isControl = (mode >= 7 && mode <= 9) || (mode >= 47 && mode <= 49);
                const isCustom = (mode >= 10 && mode <= 15);

                const isDualStomp = (mode === DUAL_STOMP_MODE_VALUE || mode === 50);
                const currentSwitchData = presetData?.switches?.[switchIndex] || {};
                const isSpinHoldEnabled = isSpinHold && (currentSwitchData.start_value_cc2 !== true);
                const onlySiglasMode = false;
                
                // Update Display card: show/hide GIG VIEW 2 based on mode
                const gigView2Group = document.getElementById('gigView2Group');
                const displayConfigGrid = document.getElementById('displayConfigGrid');
                const slotToggle = document.getElementById('gigSlotToggleContainer');
                
                const needsGigView2 = isDualStomp || isSpinHoldEnabled;
                if (gigView2Group) {
                    gigView2Group.style.display = needsGigView2 ? 'block' : 'none';
                }
                if (slotToggle) {
                    slotToggle.style.display = needsGigView2 ? 'flex' : 'none';
                }
                if (displayConfigGrid) {
                    displayConfigGrid.classList.toggle('single-column', !needsGigView2);
                }
                
                if (!needsGigView2 && window.activeGigSlot === 2 && typeof window.refreshGigSlotUI === 'function') {
                    window.activeGigSlot = 1;
                    window.refreshGigSlotUI();
                }

                window.setFxIconAllowed = (slot, allowed) => {
                    const btn = document.getElementById(slot === 1 ? 'fxModeToggle1' : 'fxModeToggle2');
                    const textInput = document.getElementById(slot === 1 ? 'switchSiglaFx' : 'switchSiglaFx2');
                    const fxIconSelectDiv = document.getElementById(slot === 1 ? 'fxIconSelect1' : 'fxIconSelect2');
                    const iconHidden = document.getElementById(slot === 1 ? 'switchIconFxValue' : 'switchIconFx2Value');
                    const iconSelect = document.getElementById(slot === 1 ? 'switchIconFx' : 'switchIconFx2');
                    const iconNameInput = slot === 1 ? document.getElementById('switchIconName') : null;
                    const iconNameGroup = slot === 1 ? document.getElementById('iconNameGroup') : null;
                    const iconColorGroup = slot === 1 ? document.getElementById('iconColorGroup') : document.getElementById('iconColorGroup2');
                    const iconColorLabel = slot === 1 ? document.getElementById('iconColorLabel') : document.getElementById('iconColor2Label');
                    const iconColorOffInput = slot === 1 ? document.getElementById('switchIconColorOffValue') : document.getElementById('switchIconColor2OffValue');
                    const backColorOnInput = slot === 1 ? document.getElementById('switchBackColorOnValue') : document.getElementById('switchBackColorOn2Value');
                    const backColorOffInput = slot === 1 ? document.getElementById('switchBackColorOffValue') : document.getElementById('switchBackColorOff2Value');
                    const borderColorOffInput = slot === 1 ? document.getElementById('switchBorderColorOffValue') : document.getElementById('switchBorderColorOff2Value');

                    if (btn) {
                        btn.disabled = !allowed;
                        btn.setAttribute('aria-disabled', allowed ? 'false' : 'true');
                        btn.classList.toggle('locked-sigla', !allowed);
                    }

                    // Get saved data from current switch
                    const layerIdx = currentLiveLayer - 1;
                    const layerPresets = allPresetsData[layerIdx] || [];
                    const globalIdx = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                    const swData = layerPresets[globalIdx]?.switches?.[switchIndex];

                    if (!allowed) {
                        // Force SIGLA mode when icons not allowed
                        if (btn) { btn.setAttribute('data-mode', 'sigla'); btn.textContent = 'SIGLA'; }
                        if (textInput) textInput.style.display = 'block';
                        if (fxIconSelectDiv) fxIconSelectDiv.style.display = 'none';
                        if (iconHidden) iconHidden.value = '0';
                        if (iconSelect) iconSelect.value = '0';
                        if (iconNameGroup) iconNameGroup.style.display = 'block';
                        if (iconNameInput) iconNameInput.style.display = 'none';
                        if (iconColorGroup) iconColorGroup.style.display = 'block';
                        // In forced Sigla mode (Split), keep color/fill options visible for SIGLA.

                        // Load saved sigla text
                        const savedSigla = slot === 1 ? (swData?.sigla_fx || '') : (swData?.sigla_fx_2 || '');
                        if (textInput) {
                            textInput.value = savedSigla.toString().substring(0, 3).toUpperCase();
                            textInput.dataset.userEdited = '0';
                        }
                    } else {
                        // Icons/Color/Fill allowed
                        // Ensure Color Group is visible if in Single Mode (supported for both Icon and Sigla)
                        if (iconColorGroup) iconColorGroup.style.display = 'block';

                        // Icons allowed: load saved icon_fx value from current switch data
                        const savedIconRaw = slot === 1 ? (swData?.icon_fx || 0) : (swData?.icon_fx_2 || 0);
                        const savedIcon = (savedIconRaw >= 0 && savedIconRaw <= MAX_FX_ICON_ID) ? savedIconRaw : 0;
                        
                        if (savedIcon > 0) {
                            // Switch has icon saved - show icon mode
                            if (btn) { btn.setAttribute('data-mode', 'icon'); btn.textContent = 'ICONE'; }
                            if (textInput) textInput.style.display = 'none';
                            if (fxIconSelectDiv) fxIconSelectDiv.style.display = 'block';
                            if (iconHidden) iconHidden.value = String(savedIcon);
                            if (iconSelect) iconSelect.value = String(savedIcon);
                            // Show and load icon name (only for slot 1)
                            if (iconNameGroup) iconNameGroup.style.display = 'block';
                            if (iconNameInput) {
                                iconNameInput.style.display = 'block';
                                const savedIconName = swData?.icon_name || '';
                                iconNameInput.value = savedIconName.toString().substring(0, 6);
                            }
                            // Update Label for Icon Mode
                            if (iconColorLabel) iconColorLabel.textContent = slot === 1 ? "ICON" : "COR ICONE 2 ON:";

                            // Render icon canvas
                            if (typeof setIconValue === 'function') {
                                setIconValue(slot, savedIcon, { silent: true });
                            }
                        } else {
                            // No icon saved - show sigla mode (but still allow toggle)
                            if (btn) { btn.setAttribute('data-mode', 'sigla'); btn.textContent = 'SIGLA'; }
                            if (textInput) textInput.style.display = 'block';
                            if (fxIconSelectDiv) fxIconSelectDiv.style.display = 'none';
                            if (iconHidden) iconHidden.value = '0';
                            if (iconSelect) iconSelect.value = '0';
                            if (iconNameGroup) iconNameGroup.style.display = 'block';
                            if (iconNameInput) iconNameInput.style.display = 'none';
                            
                            // Update Label for Sigla Mode
                            if (iconColorLabel) iconColorLabel.textContent = slot === 1 ? "ICON" : "COR ICONE 2 ON:";
                            
                            // Load saved sigla text
                            const savedSigla = slot === 1 ? (swData?.sigla_fx || '') : (swData?.sigla_fx_2 || '');
                            if (textInput) {
                                textInput.value = savedSigla.toString().substring(0, 3).toUpperCase();
                                textInput.dataset.userEdited = '0';
                            }
                        }
                    }

                    // Load Granular Colors
                    if (slot === 1 || slot === 2) {
                        const iOff = (slot === 1)
                            ? ((swData?.icon_color_off !== undefined) ? swData.icon_color_off : 6)
                            : ((swData?.icon_color_off_2 !== undefined) ? swData.icon_color_off_2 : 6);
                        const bOff = (slot === 1)
                            ? ((swData?.border_color_off !== undefined) ? swData.border_color_off : 9)
                            : ((swData?.border_color_off_2 !== undefined) ? swData.border_color_off_2 : 9);
                        const backOn = (slot === 1)
                            ? ((swData?.back_color_on !== undefined) ? swData.back_color_on : 9)
                            : ((swData?.back_color_on_2 !== undefined) ? swData.back_color_on_2 : 9);
                        const backOff = (slot === 1)
                            ? ((swData?.back_color_off !== undefined) ? swData.back_color_off : 9)
                            : ((swData?.back_color_off_2 !== undefined) ? swData.back_color_off_2 : 9);
                        const iOn = (slot === 1)
                            ? ((swData?.icon_color !== undefined) ? swData.icon_color : 6)
                            : ((swData?.icon_color_2 !== undefined) ? swData.icon_color_2 : 6);
                        
                        const iconColorInput = slot === 1 ? document.getElementById('switchIconColorValue') : document.getElementById('switchIconColor2Value');
                        if (iconColorInput) iconColorInput.value = iOn;
                        if (iconColorOffInput) iconColorOffInput.value = iOff;
                        if (backColorOnInput) backColorOnInput.value = backOn;
                        if (backColorOffInput) backColorOffInput.value = backOff;
                        if (borderColorOffInput) borderColorOffInput.value = bOff;
                        // Note: iconHidden (switchIconFxValue) stores the icon ID, not color.
                        // It is already set correctly in the icon/sigla mode logic above.

                        // Load borderColorOn
                        if (slot === 1) {
                            const borderOnColor = (swData?.border_color_on !== undefined) ? swData.border_color_on : 9;
                            const borderOnColorInput = document.getElementById('switchBorderColorOnValue');
                            if (borderOnColorInput) borderOnColorInput.value = borderOnColor;
                        } else {
                            const borderOnColor = (swData?.border_color_on_2 !== undefined) ? swData.border_color_on_2 : 9;
                            const borderOnColorInput = document.getElementById('switchBorderColorOn2Value');
                            if (borderOnColorInput) borderOnColorInput.value = borderOnColor;
                        }

                        // Helper to update preview box
                        const updatePreview = (val, boxId) => {
                             const box = document.getElementById(boxId);
                             if(box && typeof PERFIS_CORES_WEB !== 'undefined') {
                                 const c = (val === TRANSPARENT_COLOR_INDEX)
                                     ? TRANSPARENT_COLOR_WEB
                                     : (PERFIS_CORES_WEB[val] || PERFIS_CORES_WEB[9]);
                                 if(c) {
                                     const isDot = !!(box.parentElement && box.parentElement.classList && box.parentElement.classList.contains('gig-dot-preview'));
                                     applyColorPreview(box, c, isDot ? 'dot' : 'bar');
                                 }
                             }
                        };
                        if (slot === 1) {
                            updatePreview(iOn, 'selectedIconColorPreviewBox');
                            updatePreview(iOff, 'selectedIconColorOffPreviewBox');
                            updatePreview(backOn, 'selectedBackColorOnPreviewBox');
                            updatePreview(backOff, 'selectedBackColorOffPreviewBox');
                            updatePreview(bOff, 'selectedBorderColorOffPreviewBox');
                            // Update borderColorOn preview
                            const bOnVal = (swData?.border_color_on !== undefined) ? swData.border_color_on : 9;
                            updatePreview(bOnVal, 'selectedBorderColorOnPreviewBox');
                        } else {
                            updatePreview(iOn, 'selectedIconColor2PreviewBox');
                            updatePreview(iOff, 'selectedIconColor2OffPreviewBox');
                            updatePreview(backOn, 'selectedBackColorOn2PreviewBox');
                            updatePreview(backOff, 'selectedBackColorOff2PreviewBox');
                            updatePreview(bOff, 'selectedBorderColorOff2PreviewBox');
                            const bOnVal2 = (swData?.border_color_on_2 !== undefined) ? swData.border_color_on_2 : 9;
                            updatePreview(bOnVal2, 'selectedBorderColorOn2PreviewBox');
                        }
                    }

                    // Reaplica a visibilidade correta dos campos do slot ativo
                    if (typeof window.refreshGigSlotUI === 'function') {
                        window.refreshGigSlotUI();
                    }
                };

                window.setFxIconAllowed(1, !onlySiglasMode);
                window.setFxIconAllowed(2, !onlySiglasMode);
                if (typeof window.refreshGigSlotUI === 'function') {
                    window.refreshGigSlotUI();
                }
                if (onlySiglasMode) {
                    try { updateLocalPresetDataFromUI(); } catch(_) {}
                }
     
                try {
                    const switchStartEl = document.getElementById('switchStart');
                    const switchStartGroup = switchStartEl ? switchStartEl.closest('.form-group') : null;
                    const isMute = (mode === 99);
                    const isTapTempo = (mode === 18);
                const isRampa = (mode === 4) || (mode === 52);
                    const switchConfigAreaEl = document.getElementById('switchConfigArea');
                    if (switchConfigAreaEl) {
                        if (isRampa) switchConfigAreaEl.classList.add('rampa-layout');
                        else switchConfigAreaEl.classList.remove('rampa-layout');
                    }
                    const isSingle = (mode === 16);
                    if (isSingle) {
                        dynamicArea.style.display = 'block';
                        const singleGroup = document.createElement('div');
                        singleGroup.className = 'form-group';
                        singleGroup.id = 'singleValueGroup';
                        singleGroup.innerHTML = `
                            <label for="singleValueInput">Valor CC (SINGLE):</label>
                            <div class="custom-select-wrapper" data-select-id="singleValueInput">
                                <div class="custom-select-trigger" tabindex="0">
                                    <span class="custom-select-selected-value"></span>
                                    <span class="custom-select-arrow-down"></span>
                                </div>
                                <div class="custom-select-options"></div>
                                <select id="singleValueInput" name="singleValueInput" class="original-select"></select>
                            </div>
                        `;
                        dynamicArea.appendChild(singleGroup);
                        const singleVal = (presetData?.switches?.[switchIndex]?.single_value ?? 127);
                        populateNumericSelect('singleValueInput', 0, 127, singleVal);
                        updateCustomSelect('singleValueInput');
                    }
                    if (switchStartGroup) {
                        // Adiciona ou remove classe customizada para SINGLE
                        if (isSingle) {
                            switchStartGroup.classList.add('single-mode-toggle');
                        } else {
                            switchStartGroup.classList.remove('single-mode-toggle');
                        }
                        
                        // ForÃ§a atualizaÃ§Ã£o visual do botÃ£o (texto) disparando evento change
                        // Isso aciona syncStartButtonVisual definido no final do arquivo
                        const swStartCb = document.getElementById('switchStart');
                        if (swStartCb) swStartCb.dispatchEvent(new Event('change'));

                        // Exibe o toggle se for CONTROL, SINGLE, ou outros modos permitidos
                        if (isSpin || isSpinHold || isMute || isTapTempo || isRampa || mode === FAVORITE_MODE_VALUE) {
                            switchStartGroup.style.display = 'none';
                        } else {
                            // CONTROL (7-9, 47-49), CUSTOM (10-15), SINGLE (16), etc.
                            switchStartGroup.style.display = 'block';
                        }
                    }

                    // Atualiza label do campo CC para "PC/CC" se estiver no modo SINGLE
                    const ccLabel = ccGroup ? ccGroup.querySelector('label') : null;
                    if (ccLabel) {
                        if (isSingle) {
                            ccLabel.textContent = 'PC/CC:';
                        } else {
                            ccLabel.textContent = 'CC:';
                        }
                    }

                } catch (e) {
                    console.warn('WARN: could not toggle switchStart visibility for mode', e);
                }

                if (mode === FAVORITE_MODE_VALUE) {
                    ccGroup.style.display = 'none';
                    chGroup.style.display = 'none';
                    dynamicArea.style.display = 'none';

                    const favoriteInline = document.createElement('div');
                    favoriteInline.className = 'favorite-inline-controls';
                    favoriteInline.innerHTML = `
                        <div class="form-group favorite-preset-group">
                            <label for="swFavoritePresetSelect_${switchIndex}">Preset Favorito:</label>
                            <div class="custom-select-wrapper" data-select-id="swFavoritePresetSelect_${switchIndex}">
                                <div class="custom-select-trigger" tabindex="0">
                                    <span class="custom-select-selected-value"></span>
                                    <span class="custom-select-arrow-down"></span>
                                </div>
                                <div class="custom-select-options"></div>
                                <select id="swFavoritePresetSelect_${switchIndex}" name="swFavoritePresetSelect" class="original-select"></select>
                            </div>
                        </div>
                        <div class="form-group favorite-mode-group">
                            <label class="favorite-mode-label-spacer" for="favoriteModeBtn_${switchIndex}">Modo:</label>
                            <input type="checkbox" id="favoriteLiveToggle_${switchIndex}" style="display:none;">
                            <button type="button" id="favoriteModeBtn_${switchIndex}" class="single-toggle-button favorite-mode-toggle-btn" aria-pressed="false">MODO PRESET</button>
                        </div>
                    `;

                    if (ledStartRow) {
                        ledStartRow.classList.add('favorite-mode-layout');
                        ledStartRow.appendChild(favoriteInline);
                    } else {
                        dynamicArea.style.display = 'block';
                        dynamicArea.appendChild(favoriteInline);
                    }

                    const currentSwitchData = presetData?.switches?.[switchIndex] || {};
                    const select = document.getElementById(`swFavoritePresetSelect_${switchIndex}`);
                    const favToggleInput = document.getElementById(`favoriteLiveToggle_${switchIndex}`);
                    const favModeBtn = document.getElementById(`favoriteModeBtn_${switchIndex}`);

                    if (select) {
                        for (let c = 0; c < NUM_PRESET_COLUMNS; c++) {
                            for (let r = 0; r < NUM_PRESET_ROWS; r++) {
                                // Indexação correta: row-major (r * NUM_PRESET_COLUMNS + c)
                                // Compatível com decodificação no firmware: btn = idx % TOTAL_BUTTONS; lvl = idx / TOTAL_BUTTONS
                                const globalIndex = r * NUM_PRESET_COLUMNS + c;
                                const opt = document.createElement('option');
                                opt.value = globalIndex;
                                opt.textContent = String.fromCharCode(65 + r) + (c + 1);
                                select.appendChild(opt);
                            }
                        }
                        select.value = currentSwitchData.cc || 0;
                        select.addEventListener('change', updateLocalPresetDataFromUI);
                    }

                    const syncFavoriteModeButton = () => {
                        if (!favToggleInput || !favModeBtn) return;
                        if (favToggleInput.checked) {
                            favModeBtn.classList.add('active');
                            favModeBtn.setAttribute('aria-pressed', 'true');
                            favModeBtn.textContent = 'MODO LIVE';
                        } else {
                            favModeBtn.classList.remove('active');
                            favModeBtn.setAttribute('aria-pressed', 'false');
                            favModeBtn.textContent = 'MODO PRESET';
                        }
                    };

                    if (favToggleInput) {
                        favToggleInput.checked = !!currentSwitchData.favoriteAutoLive;
                        favToggleInput.addEventListener('change', () => {
                            syncFavoriteModeButton();
                            updateLocalPresetDataFromUI();
                        });
                    }

                    if (favModeBtn && favToggleInput) {
                        favModeBtn.addEventListener('click', (e) => {
                            e.preventDefault();
                            favToggleInput.checked = !favToggleInput.checked;
                            favToggleInput.dispatchEvent(new Event('change', { bubbles: true }));
                        });
                    }

                    syncFavoriteModeButton();
                } else if (mode === 18) { // TAP TEMPO
                    dynamicArea.style.display = 'block';
                    const currentSwitchData = presetData.switches[switchIndex] || {};

                    // MODO TAP toggle (MODO 1 / MODO 2)
                    const tapModeGroup = document.createElement('div');
                    tapModeGroup.className = 'form-group start-group-centered';
                    tapModeGroup.style.marginBottom = '10px';
                    const tapModeBtn = document.createElement('button');
                    tapModeBtn.type = 'button';
                    tapModeBtn.id = 'tapMode2Btn';
                    const isTapMode2 = !!(currentSwitchData.tap_mode2);
                    tapModeBtn.className = 'single-toggle-button' + (isTapMode2 ? ' active' : '');
                    tapModeBtn.setAttribute('aria-pressed', isTapMode2 ? 'true' : 'false');
                    tapModeBtn.textContent = isTapMode2 ? 'MODO 2' : 'MODO 1';
                    tapModeBtn.addEventListener('click', function() {
                        const isOn = tapModeBtn.classList.toggle('active');
                        tapModeBtn.setAttribute('aria-pressed', isOn ? 'true' : 'false');
                        tapModeBtn.textContent = isOn ? 'MODO 2' : 'MODO 1';
                    });
                    tapModeGroup.appendChild(tapModeBtn);
                    dynamicArea.appendChild(tapModeGroup);

                    const group = document.createElement('div');
                    group.className = 'form-group';
                    group.innerHTML = '<h4>TAP Adicionais</h4>';

                    // TAP2 Row
                    const row2 = document.createElement('div');
                    row2.className = 'custom-inline-group';

                    const tap2Cc = document.createElement('div');
                    tap2Cc.className = 'custom-value-container';
                    tap2Cc.appendChild(newLabel('TAP2 CC:'));
                    const tap2CcId = 'tap2_cc';
                    const tap2CcMode = (globalMidiMode === "MODO AVANCADO") ? getModeForChannel(currentSwitchData.tap2_ch || 0) : undefined;
                    tap2Cc.appendChild(newNumericInput(tap2CcId, 0, 127, currentSwitchData.tap2_cc || 0, 'cc', tap2CcMode));
                    row2.appendChild(tap2Cc);

                    const tap2Ch = document.createElement('div');
                    tap2Ch.className = 'custom-value-container';
                    tap2Ch.appendChild(newLabel('TAP2 Canal:'));
                    const tap2ChId = 'tap2_ch';
                    tap2Ch.appendChild(newSelect(tap2ChId, 0, 16, currentSwitchData.tap2_ch || 0));
                    row2.appendChild(tap2Ch);
                    
                    if (globalMidiMode === "MODO AVANCADO") {
                        setTimeout(() => {
                            const tap2ChEl = document.getElementById(tap2ChId);
                            if (tap2ChEl) {
                                tap2ChEl.addEventListener('change', () => {
                                    const newCh = parseInt(tap2ChEl.value, 10);
                                    const newMode = getModeForChannel(newCh);
                                    const currentCcVal = parseInt(document.getElementById(tap2CcId)?.value, 10) || 0;
                                    populateNumericSelect(tap2CcId, 0, 127, currentCcVal, newMode);
                                    updateCustomSelect(tap2CcId);
                                });
                            }
                        }, 0);
                    }

                    group.appendChild(row2);

                    // TAP3 Row
                    const row3 = document.createElement('div');
                    row3.className = 'custom-inline-group';

                    const tap3Cc = document.createElement('div');
                    tap3Cc.className = 'custom-value-container';
                    tap3Cc.appendChild(newLabel('TAP3 CC:'));
                    const tap3CcId = 'tap3_cc';
                    const tap3CcMode = (globalMidiMode === "MODO AVANCADO") ? getModeForChannel(currentSwitchData.tap3_ch || 0) : undefined;
                    tap3Cc.appendChild(newNumericInput(tap3CcId, 0, 127, currentSwitchData.tap3_cc || 0, 'cc', tap3CcMode));
                    row3.appendChild(tap3Cc);

                    const tap3Ch = document.createElement('div');
                    tap3Ch.className = 'custom-value-container';
                    tap3Ch.appendChild(newLabel('TAP3 Canal:'));
                    const tap3ChId = 'tap3_ch';
                    tap3Ch.appendChild(newSelect(tap3ChId, 0, 16, currentSwitchData.tap3_ch || 0));
                    row3.appendChild(tap3Ch);
                    
                    if (globalMidiMode === "MODO AVANCADO") {
                        setTimeout(() => {
                            const tap3ChEl = document.getElementById(tap3ChId);
                            if (tap3ChEl) {
                                tap3ChEl.addEventListener('change', () => {
                                    const newCh = parseInt(tap3ChEl.value, 10);
                                    const newMode = getModeForChannel(newCh);
                                    const currentCcVal = parseInt(document.getElementById(tap3CcId)?.value, 10) || 0;
                                    populateNumericSelect(tap3CcId, 0, 127, currentCcVal, newMode);
                                    updateCustomSelect(tap3CcId);
                                });
                            }
                        }, 0);
                    }

                    group.appendChild(row3);
                    dynamicArea.appendChild(group);

                    const cc2Group = document.createElement('div');
                    cc2Group.className = 'form-group';
                    cc2Group.innerHTML = '<h4>CC2 (toque longo)</h4>';

                    const cc2Grid = document.createElement('div');
                    cc2Grid.className = 'dual-stomp-rampa-grid';

                    const cc2Container = document.createElement('div');
                    cc2Container.className = 'form-group';
                    const cc2Label = newLabel('CC2 (toque longo):');
                    const cc2ChValue = getCc2ChannelValue(currentSwitchData);
                    const cc2Mode = (globalMidiMode === "MODO AVANCADO") ? getModeForChannel(cc2ChValue) : undefined;
                    const cc2Input = newNumericInput('switchCC2', 0, 127, currentSwitchData.cc2 || 0, 'cc', cc2Mode);
                    cc2Container.appendChild(cc2Label);
                    cc2Container.appendChild(cc2Input);
                    cc2Grid.appendChild(cc2Container);

                    const cc2ChContainer = document.createElement('div');
                    cc2ChContainer.className = 'form-group';
                    const cc2ChLabel = newLabel('CH:');
                    const cc2ChSelect = newSelect('switchChannelCC2', 0, 16, cc2ChValue);
                    cc2ChContainer.appendChild(cc2ChLabel);
                    cc2ChContainer.appendChild(cc2ChSelect);
                    cc2Grid.appendChild(cc2ChContainer);
                    
                    if (globalMidiMode === "MODO AVANCADO") {
                        setTimeout(() => {
                            const cc2ChEl = document.getElementById('switchChannelCC2');
                            if (cc2ChEl) {
                                cc2ChEl.addEventListener('change', () => {
                                    const newCh = parseInt(cc2ChEl.value, 10);
                                    const newMode = getModeForChannel(newCh);
                                    const currentCcVal = parseInt(document.getElementById('switchCC2')?.value, 10) || 0;
                                    populateNumericSelect('switchCC2', 0, 127, currentCcVal, newMode);
                                    updateCustomSelect('switchCC2');
                                });
                            }
                        }, 0);
                    }

                    const led2Container = document.createElement('div');
                    led2Container.className = 'form-group';
                    const led2Label = newLabel('LED2:');
                    led2Container.appendChild(led2Label);

                    const led2Picker = document.createElement('div');
                    led2Picker.className = 'custom-color-selector';
                    led2Picker.style.width = '100%';
                    led2Picker.innerHTML = `
                        <div id="selectedLed2ColorPreview" class="selected-color-preview" tabindex="0">
                             <div id="selectedLed2ColorPreviewBox" class="selected-color-preview-box"></div>
                        </div>
                        <input type="hidden" id="switchLed2ColorValue" name="switchLed2ColorValue">
                    `;
                    led2Container.appendChild(led2Picker);
                    cc2Grid.appendChild(led2Container);

                    cc2Group.appendChild(cc2Grid);
                    dynamicArea.appendChild(cc2Group);

                    const startWrapper = document.createElement('div');
                    startWrapper.className = 'form-group start-group-centered';
                    startWrapper.style.marginTop = '15px';

                    const startInput = document.createElement('input');
                    startInput.type = 'checkbox';
                    startInput.id = 'switchCC2Start';
                    startInput.style.display = 'none';
                    startInput.checked = !!currentSwitchData.start_value_cc2;
                    startWrapper.appendChild(startInput);

                    const startBtn = document.createElement('button');
                    startBtn.type = 'button';
                    startBtn.id = 'startToggleBtnCc2';
                    startBtn.className = 'single-toggle-button';
                    startBtn.style.minWidth = '200px';
                    startWrapper.appendChild(startBtn);

                    const syncCc2Start = () => {
                        if (startInput.checked) {
                            startBtn.classList.add('active');
                            startBtn.setAttribute('aria-pressed','true');
                            startBtn.textContent = 'INICIAR LIGADO';
                        } else {
                            startBtn.classList.remove('active');
                            startBtn.setAttribute('aria-pressed','false');
                            startBtn.textContent = 'INICIAR DESLIGADO';
                        }
                    };
                    syncCc2Start();
                    startInput.addEventListener('change', () => { syncCc2Start(); updateLocalPresetDataFromUI(); });
                    startBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        startInput.checked = !startInput.checked;
                        syncCc2Start();
                        startInput.dispatchEvent(new Event('change', { bubbles: true }));
                    });
                    dynamicArea.appendChild(startWrapper);

                    const led2ColorIndex = currentSwitchData.led2 || 0;
                    document.getElementById('switchLed2ColorValue').value = led2ColorIndex;
                    const led2Box = document.getElementById('selectedLed2ColorPreviewBox');
                    if (led2Box && PERFIS_CORES_WEB[led2ColorIndex]) {
                        const hexColor = PERFIS_CORES_WEB[led2ColorIndex].value.toString(16).padStart(6, '0');
                        led2Box.style.backgroundImage = `linear-gradient(to right, black 2%, #${hexColor} 50%, black 98%)`;
                    }
                    document.getElementById('selectedLed2ColorPreview').addEventListener('click', () => {
                        document.getElementById('colorPanelOverlay_Led2').classList.add('active');
                    });
                    const cc2ChSelectEl = document.getElementById('switchChannelCC2');
                    if (cc2ChSelectEl) {
                        cc2ChSelectEl.value = getCc2ChannelValue(currentSwitchData);
                        updateCustomSelect('switchChannelCC2');
                    }

                }
                else if (mode === 0) {
                    dynamicArea.style.display = 'block';
                    const currentSwitchData = presetData.switches[switchIndex] || {};
                    const initialState = currentSwitchData.reclick_enabled
                        ? 'reclick'
                        : (currentSwitchData._dualActive ? 'dual' : 'single');
                    const gv2 = document.getElementById('gigView2Group');
                    const dcg = document.getElementById('displayConfigGrid');
                    const slotToggle = document.getElementById('gigSlotToggleContainer');
                    const ledSvgHtml = document.getElementById('selectedLedColorPreview')?.querySelector('.led-standard-core')?.innerHTML || '';

                    const createCardHeader = (title, subtitle, buttonId) => {
                        const header = document.createElement('div');
                        header.className = 'stomp-card-header';

                        const textWrap = document.createElement('div');
                        textWrap.className = 'stomp-card-header-copy';

                        const titleEl = document.createElement('div');
                        titleEl.className = 'stomp-card-title';
                        titleEl.textContent = title;
                        textWrap.appendChild(titleEl);

                        const subtitleEl = document.createElement('div');
                        subtitleEl.className = 'stomp-card-subtitle';
                        subtitleEl.textContent = subtitle;
                        textWrap.appendChild(subtitleEl);

                        const button = document.createElement('button');
                        button.type = 'button';
                        button.id = buttonId;
                        button.className = 'single-toggle-button stomp-card-custom-btn';

                        header.appendChild(textWrap);
                        header.appendChild(button);
                        return { header, button };
                    };

                    const syncCustomButton = (button, enabled) => {
                        if (enabled) {
                            button.classList.add('active');
                            button.setAttribute('aria-pressed', 'true');
                            button.textContent = 'CUSTOM ON';
                        } else {
                            button.classList.remove('active');
                            button.setAttribute('aria-pressed', 'false');
                            button.textContent = 'CUSTOM OFF';
                        }
                    };

                    const createLedSelectorMarkup = (previewId, boxId, hiddenId) => `
                        <div id="${previewId}" class="selected-color-preview stomp-card-led-preview" tabindex="0">
                            <div class="led-standard-core" aria-hidden="true">${ledSvgHtml}</div>
                            <div class="led-standard-bar" aria-hidden="true"></div>
                            <div id="${boxId}" class="selected-color-preview-box"></div>
                        </div>
                        <input type="hidden" id="${hiddenId}" name="${hiddenId}">
                    `;

                    const createSimpleLedSelectorMarkup = (previewId, boxId, hiddenId) => `
                        <div id="${previewId}" class="selected-color-preview" style="width:100%;" tabindex="0">
                            <div id="${boxId}" class="selected-color-preview-box"></div>
                        </div>
                        <input type="hidden" id="${hiddenId}" name="${hiddenId}">
                    `;

                    const applyLedPreviewColor = (previewId, boxId, colorIndex) => {
                        if (!PERFIS_CORES_WEB[colorIndex]) return;
                        setStompAuxLedPreviewVisual(previewId, boxId, PERFIS_CORES_WEB[colorIndex].value);
                    };

                    const stateRow = document.createElement('div');
                    stateRow.className = 'stomp-toggle-row stomp-state-toggle-row';
                    dynamicArea.appendChild(stateRow);

                    const stompStateInput = document.createElement('input');
                    stompStateInput.type = 'hidden';
                    stompStateInput.id = 'stompModeStateValue';
                    stompStateInput.value = initialState;
                    stateRow.appendChild(stompStateInput);

                    const dualCheck = document.createElement('input');
                    dualCheck.type = 'checkbox';
                    dualCheck.id = 'dualStompEnabled';
                    dualCheck.style.display = 'none';
                    stateRow.appendChild(dualCheck);

                    const reclickCheck = document.createElement('input');
                    reclickCheck.type = 'checkbox';
                    reclickCheck.id = 'reclickEnabled';
                    reclickCheck.style.display = 'none';
                    stateRow.appendChild(reclickCheck);

                    const stateBtn = document.createElement('button');
                    stateBtn.type = 'button';
                    stateBtn.id = 'stompStateToggleBtn';
                    stateBtn.className = 'single-toggle-button stomp-state-toggle-btn';
                    stateBtn.title = 'Alterna entre SINGLE STOMP, DUAL STOMP e RECLICK';
                    stateRow.appendChild(stateBtn);

                    const singleCard = document.createElement('div');
                    singleCard.id = 'singleStompCard';
                    singleCard.className = 'stomp-mode-card';
                    const { header: singleCardHeader, button: singleCustomBtn } = createCardHeader(
                        'SINGLE STOMP',
                        'Toque simples',
                        'stompSingleCustomToggleBtn'
                    );
                    singleCardHeader.id = 'singleStompCardHeader';
                    singleCard.appendChild(singleCardHeader);
                    if (ledStartRow) singleCard.appendChild(ledStartRow);
                    if (ccChRow) singleCard.appendChild(ccChRow);

                    const singleCustomWrap = document.createElement('div');
                    singleCustomWrap.id = 'singleStompCustomWrap';
                    singleCustomWrap.className = 'stomp-card-custom-wrap';

                    const singleCustomCheck = document.createElement('input');
                    singleCustomCheck.type = 'checkbox';
                    singleCustomCheck.id = 'stompSingleCustomEnabled';
                    singleCustomCheck.style.display = 'none';
                    singleCustomCheck.checked = !!currentSwitchData.stomp_custom;
                    singleCustomWrap.appendChild(singleCustomCheck);

                    const singleCustomFields = document.createElement('div');
                    singleCustomFields.id = 'singleStompCustomFieldsContainer';
                    singleCustomFields.className = 'stomp-card-custom-fields';
                    const singleCustomRow = document.createElement('div');
                    singleCustomRow.className = 'custom-inline-group';
                    appendValueField(singleCustomRow, 'stompValOff', 'CC1 OFF:', currentSwitchData._dualActive ? (currentSwitchData.ds_cc1_off ?? currentSwitchData.stomp_val_off ?? 0) : (currentSwitchData.stomp_val_off ?? 0));
                    appendValueField(singleCustomRow, 'stompValOn', 'CC1 ON:', currentSwitchData._dualActive ? (currentSwitchData.ds_cc1_on ?? currentSwitchData.stomp_val_on ?? 127) : (currentSwitchData.stomp_val_on ?? 127));
                    singleCustomFields.appendChild(singleCustomRow);
                    bindProgressBars(['stompValOff', 'stompValOn'], updateSpinProgressBar);
                    singleCustomWrap.appendChild(singleCustomFields);
                    singleCard.appendChild(singleCustomWrap);
                    singleCard.appendChild(createSendPcToggle('stompSendPcToggle', 'stompSendPcBtn', currentSwitchData.stomp_send_pc));
                    dynamicArea.appendChild(singleCard);

                    const syncSingleCustom = () => {
                        syncCustomButton(singleCustomBtn, singleCustomCheck.checked);
                        singleCustomBtn.disabled = false;
                        singleCustomBtn.title = '';
                        singleCustomFields.style.display = singleCustomCheck.checked ? 'block' : 'none';
                    };
                    syncSingleCustom();
                    singleCustomCheck.addEventListener('change', () => { syncSingleCustom(); updateLocalPresetDataFromUI(); });
                    singleCustomBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        singleCustomCheck.checked = !singleCustomCheck.checked;
                        singleCustomCheck.dispatchEvent(new Event('change', { bubbles: true }));
                    });

                    try {
                        const fx2Input = document.getElementById('switchSiglaFx2');
                        if (fx2Input) fx2Input.value = (currentSwitchData.sigla_fx_2 || '');
                        const fx2Hidden = document.getElementById('switchIconFx2Value');
                        if (fx2Hidden) fx2Hidden.value = '0';
                        if (typeof setFxModeFromData === 'function') {
                            setFxModeFromData(2, 0);
                        }
                    } catch (_) { }

                    const cardStack = document.createElement('div');
                    cardStack.className = 'stomp-mode-stack';
                    dynamicArea.appendChild(cardStack);

                    const dualCard = document.createElement('div');
                    dualCard.id = 'dualStompCard';
                    dualCard.className = 'stomp-mode-card';
                    const { header: dualHeader, button: dualCustomBtn } = createCardHeader(
                        'DUAL STOMP',
                        'Toque longo',
                        'dualStompCustomToggleBtn'
                    );
                    dualCard.appendChild(dualHeader);

                    const dualCustomCheck = document.createElement('input');
                    dualCustomCheck.type = 'checkbox';
                    dualCustomCheck.id = 'dualStompCustomEnabled';
                    dualCustomCheck.style.display = 'none';
                    dualCustomCheck.checked = !!currentSwitchData.ds_custom_enabled;
                    dualCard.appendChild(dualCustomCheck);

                    const dualBody = document.createElement('div');
                    dualBody.className = 'stomp-card-body';

                    const led2StartRow = document.createElement('div');
                    led2StartRow.className = 'switch-config-grid-led-start';

                    const led2Container = document.createElement('div');
                    led2Container.className = 'form-group led-group';
                    led2Container.appendChild(newLabel('LED2:'));
                    const led2Picker = document.createElement('div');
                    led2Picker.className = 'custom-color-selector';
                    led2Picker.innerHTML = createSimpleLedSelectorMarkup('selectedLed2ColorPreview', 'selectedLed2ColorPreviewBox', 'switchLed2ColorValue');
                    led2Container.appendChild(led2Picker);
                    led2StartRow.appendChild(led2Container);

                    const startInline2 = document.createElement('div');
                    startInline2.className = 'form-group start-group-inline';
                    const startInput2 = document.createElement('input');
                    startInput2.type = 'checkbox';
                    startInput2.id = 'switchCC2Start';
                    startInput2.style.display = 'none';
                    startInput2.checked = !!currentSwitchData.start_value_cc2;
                    startInline2.appendChild(startInput2);
                    const startBtn2 = document.createElement('button');
                    startBtn2.type = 'button';
                    startBtn2.id = 'startToggleBtnCc2';
                    startBtn2.className = 'single-toggle-button';
                    startInline2.appendChild(startBtn2);
                    const syncCc2Start = () => {
                        if (startInput2.checked) {
                            startBtn2.classList.add('active');
                            startBtn2.setAttribute('aria-pressed','true');
                            startBtn2.textContent = 'INICIAR LIGADO';
                        } else {
                            startBtn2.classList.remove('active');
                            startBtn2.setAttribute('aria-pressed','false');
                            startBtn2.textContent = 'INICIAR DESLIGADO';
                        }
                    };
                    syncCc2Start();
                    startInput2.addEventListener('change', () => { syncCc2Start(); updateLocalPresetDataFromUI(); });
                    startBtn2.addEventListener('click', (e) => {
                        e.preventDefault();
                        startInput2.checked = !startInput2.checked;
                        startInput2.dispatchEvent(new Event('change', { bubbles: true }));
                    });
                    led2StartRow.appendChild(startInline2);
                    dualBody.appendChild(led2StartRow);

                    const dualGrid = document.createElement('div');
                    dualGrid.className = 'switch-config-grid-cc-ch';

                    const cc2Container = document.createElement('div');
                    cc2Container.className = 'form-group';
                    cc2Container.style.flex = '3';
                    cc2Container.style.minWidth = '0';
                    cc2Container.appendChild(newLabel('CC2:'));
                    cc2Container.appendChild(newNumericInput('switchCC2', 0, 127, currentSwitchData.cc2 || 0, 'cc'));
                    dualGrid.appendChild(cc2Container);

                    const cc2ChContainer = document.createElement('div');
                    cc2ChContainer.className = 'form-group ch-group';
                    cc2ChContainer.style.flex = '2';
                    cc2ChContainer.style.minWidth = '0';
                    cc2ChContainer.appendChild(newLabel('CH:'));
                    cc2ChContainer.appendChild(newSelect('switchChannelCC2', 0, 16, getCc2ChannelValue(currentSwitchData)));
                    dualGrid.appendChild(cc2ChContainer);
                    dualBody.appendChild(dualGrid);

                    dualCard.appendChild(dualBody);

                    const dualCustomFields = document.createElement('div');
                    dualCustomFields.id = 'dualStompCustomFieldsContainer';
                    dualCustomFields.className = 'stomp-card-custom-fields';
                    const dualCustomRow2 = document.createElement('div');
                    dualCustomRow2.className = 'custom-inline-group';
                    appendValueField(dualCustomRow2, 'dsCC2Off', 'CC2 OFF:', currentSwitchData.ds_cc2_off || 0);
                    appendValueField(dualCustomRow2, 'dsCC2On', 'CC2 ON:', currentSwitchData.ds_cc2_on || 127);
                    dualCustomFields.appendChild(dualCustomRow2);
                    bindProgressBars(['dsCC2Off', 'dsCC2On'], updateSpinProgressBar);
                    dualCard.appendChild(dualCustomFields);
                    dualCard.appendChild(createSendPcToggle('dualSendPcToggle', 'dualSendPcBtn', currentSwitchData.dual_send_pc));
                    cardStack.appendChild(dualCard);

                    const reclickCard = document.createElement('div');
                    reclickCard.id = 'reclickStompCard';
                    reclickCard.className = 'stomp-mode-card';
                    const { header: reclickHeader, button: reclickCustomBtn } = createCardHeader(
                        'RECLICK',
                        'Terceiro toque',
                        'reclickCustomToggleBtn'
                    );
                    reclickCard.appendChild(reclickHeader);

                    const reclickCustomCheck = document.createElement('input');
                    reclickCustomCheck.type = 'checkbox';
                    reclickCustomCheck.id = 'reclickCustomEnabled';
                    reclickCustomCheck.style.display = 'none';
                    reclickCustomCheck.checked = !!currentSwitchData.reclick_custom_enabled;
                    reclickCard.appendChild(reclickCustomCheck);

                    const reclickBody = document.createElement('div');
                    reclickBody.className = 'stomp-card-body';

                    const led3StartRow = document.createElement('div');
                    led3StartRow.className = 'switch-config-grid-led-start';

                    const led3Container = document.createElement('div');
                    led3Container.className = 'form-group led-group';
                    led3Container.appendChild(newLabel('LED3:'));
                    const led3Picker = document.createElement('div');
                    led3Picker.className = 'custom-color-selector';
                    led3Picker.innerHTML = createSimpleLedSelectorMarkup('selectedLed3ColorPreview', 'selectedLed3ColorPreviewBox', 'switchLed3ColorValue');
                    led3Container.appendChild(led3Picker);
                    led3StartRow.appendChild(led3Container);

                    const startInline3 = document.createElement('div');
                    startInline3.className = 'form-group start-group-inline';
                    const startInput3 = document.createElement('input');
                    startInput3.type = 'checkbox';
                    startInput3.id = 'switchCC3Start';
                    startInput3.style.display = 'none';
                    startInput3.checked = !!currentSwitchData.start_value_cc3;
                    startInline3.appendChild(startInput3);
                    const startBtn3 = document.createElement('button');
                    startBtn3.type = 'button';
                    startBtn3.id = 'startToggleBtnCc3';
                    startBtn3.className = 'single-toggle-button';
                    startInline3.appendChild(startBtn3);
                    const syncCc3Start = () => {
                        if (startInput3.checked) {
                            startBtn3.classList.add('active');
                            startBtn3.setAttribute('aria-pressed','true');
                            startBtn3.textContent = 'INICIAR LIGADO';
                        } else {
                            startBtn3.classList.remove('active');
                            startBtn3.setAttribute('aria-pressed','false');
                            startBtn3.textContent = 'INICIAR DESLIGADO';
                        }
                    };
                    syncCc3Start();
                    startInput3.addEventListener('change', () => { syncCc3Start(); updateLocalPresetDataFromUI(); });
                    startBtn3.addEventListener('click', (e) => {
                        e.preventDefault();
                        startInput3.checked = !startInput3.checked;
                        startInput3.dispatchEvent(new Event('change', { bubbles: true }));
                    });
                    led3StartRow.appendChild(startInline3);
                    reclickBody.appendChild(led3StartRow);

                    const reclickGrid = document.createElement('div');
                    reclickGrid.className = 'switch-config-grid-cc-ch';

                    const cc3Container = document.createElement('div');
                    cc3Container.className = 'form-group';
                    cc3Container.style.flex = '3';
                    cc3Container.style.minWidth = '0';
                    cc3Container.appendChild(newLabel('CC3:'));
                    cc3Container.appendChild(newNumericInput('switchCC3', 0, 127, currentSwitchData.cc3 || 0, 'cc'));
                    reclickGrid.appendChild(cc3Container);

                    const cc3ChContainer = document.createElement('div');
                    cc3ChContainer.className = 'form-group ch-group';
                    cc3ChContainer.style.flex = '2';
                    cc3ChContainer.style.minWidth = '0';
                    cc3ChContainer.appendChild(newLabel('CH:'));
                    cc3ChContainer.appendChild(newSelect('switchChannelCC3', 0, 16, getCc3ChannelValue(currentSwitchData)));
                    reclickGrid.appendChild(cc3ChContainer);
                    reclickBody.appendChild(reclickGrid);

                    reclickCard.appendChild(reclickBody);

                    const reclickCustomFields = document.createElement('div');
                    reclickCustomFields.id = 'reclickCustomFieldsContainer';
                    reclickCustomFields.className = 'stomp-card-custom-fields';
                    const reclickCustomRow = document.createElement('div');
                    reclickCustomRow.className = 'custom-inline-group';
                    appendValueField(reclickCustomRow, 'reclickValOff', 'CC3 OFF:', currentSwitchData.reclick_val_off ?? 0);
                    appendValueField(reclickCustomRow, 'reclickValOn', 'CC3 ON:', currentSwitchData.reclick_val_on ?? 127);
                    reclickCustomFields.appendChild(reclickCustomRow);
                    bindProgressBars(['reclickValOff', 'reclickValOn'], updateSpinProgressBar);
                    reclickCard.appendChild(reclickCustomFields);
                    reclickCard.appendChild(createSendPcToggle('reclickSendPcToggle', 'reclickSendPcBtn', currentSwitchData.reclick_send_pc));
                    cardStack.appendChild(reclickCard);

                    const syncDualCustom = () => {
                        syncCustomButton(dualCustomBtn, dualCustomCheck.checked);
                        dualCustomFields.style.display = dualCustomCheck.checked ? 'block' : 'none';
                    };
                    const syncReclickCustom = () => {
                        syncCustomButton(reclickCustomBtn, reclickCustomCheck.checked);
                        reclickCustomFields.style.display = reclickCustomCheck.checked ? 'block' : 'none';
                    };
                    syncDualCustom();
                    syncReclickCustom();

                    dualCustomCheck.addEventListener('change', () => { syncDualCustom(); updateLocalPresetDataFromUI(); });
                    dualCustomBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        dualCustomCheck.checked = !dualCustomCheck.checked;
                        dualCustomCheck.dispatchEvent(new Event('change', { bubbles: true }));
                    });
                    reclickCustomCheck.addEventListener('change', () => { syncReclickCustom(); updateLocalPresetDataFromUI(); });
                    reclickCustomBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        reclickCustomCheck.checked = !reclickCustomCheck.checked;
                        reclickCustomCheck.dispatchEvent(new Event('change', { bubbles: true }));
                    });

                    const syncStompState = () => {
                        const state = stompStateInput.value === 'reclick'
                            ? 'reclick'
                            : (stompStateInput.value === 'dual' ? 'dual' : 'single');
                        const dualActive = state !== 'single';
                        const reclickActive = state === 'reclick';

                        dualCheck.checked = dualActive;
                        reclickCheck.checked = reclickActive;

                        stateBtn.classList.toggle('active', dualActive);
                        stateBtn.setAttribute('data-state', state);
                        stateBtn.textContent = state === 'single'
                            ? 'SINGLE STOMP'
                            : (state === 'dual' ? 'DUAL STOMP' : 'RECLICK');

                        dualCard.style.display = dualActive ? 'block' : 'none';
                        reclickCard.style.display = reclickActive ? 'block' : 'none';
                        syncSingleCustom();

                        if (dualActive) {
                            window.activeGigSlot = 1;
                            if (gv2) gv2.style.display = 'block';
                            if (slotToggle) slotToggle.style.display = 'flex';
                            if (dcg) dcg.classList.remove('single-column');
                        } else {
                            if (gv2) gv2.style.display = 'none';
                            if (slotToggle) slotToggle.style.display = 'none';
                            if (dcg) dcg.classList.add('single-column');
                            if (window.activeGigSlot === 2 && typeof window.refreshGigSlotUI === 'function') {
                                window.activeGigSlot = 1;
                                window.refreshGigSlotUI();
                            }
                        }

                        currentSwitchData._dualActive = dualActive;
                        currentSwitchData.reclick_enabled = reclickActive;

                        if (typeof window.setFxIconAllowed === 'function') {
                            window.setFxIconAllowed(1, true);
                            window.setFxIconAllowed(2, true);
                        }
                        if (typeof window.refreshGigSlotUI === 'function') {
                            window.refreshGigSlotUI();
                        }
                    };

                    stateBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        stompStateInput.value = stompStateInput.value === 'single'
                            ? 'dual'
                            : (stompStateInput.value === 'dual' ? 'reclick' : 'single');
                        syncStompState();
                        updateLocalPresetDataFromUI();
                    });

                    {
                        const led2ColorIndex = currentSwitchData.led2 || 0;
                        const led2ValEl = document.getElementById('switchLed2ColorValue');
                        if (led2ValEl) led2ValEl.value = led2ColorIndex;
                        applyLedPreviewColor('selectedLed2ColorPreview', 'selectedLed2ColorPreviewBox', led2ColorIndex);
                        document.getElementById('selectedLed2ColorPreview')?.addEventListener('click', () => {
                            document.getElementById('colorPanelOverlay_Led2').classList.add('active');
                        });
                        const cc2ChSelectEl = document.getElementById('switchChannelCC2');
                        if (cc2ChSelectEl) {
                            cc2ChSelectEl.value = getCc2ChannelValue(currentSwitchData);
                            updateCustomSelect('switchChannelCC2');
                        }
                    }

                    {
                        const led3ColorIndex = currentSwitchData.led3 || 0;
                        const led3ValEl = document.getElementById('switchLed3ColorValue');
                        if (led3ValEl) led3ValEl.value = led3ColorIndex;
                        applyLedPreviewColor('selectedLed3ColorPreview', 'selectedLed3ColorPreviewBox', led3ColorIndex);
                        document.getElementById('selectedLed3ColorPreview')?.addEventListener('click', () => {
                            document.getElementById('colorPanelOverlay_Led3').classList.add('active');
                        });
                        const cc3ChSelectEl = document.getElementById('switchChannelCC3');
                        if (cc3ChSelectEl) {
                            cc3ChSelectEl.value = getCc3ChannelValue(currentSwitchData);
                            updateCustomSelect('switchChannelCC3');
                        }
                    }

                    syncStompState();
                }
                // RAMPA UI unificado (agora tambÃƒÂ©m para STOMP RAMPA 29 e DUAL STOMP RAMPA 50)
                if ((mode >= 4 && mode <= 6) || mode === 52 || mode === 50) {
                    dynamicArea.style.display = 'block';
                    // Novo UI de RAMPA unificado: up/down + invert + autoStop
                    const swId = switchIndex + 1;
                    const currentBase = (presetData.rampTimes && presetData.rampTimes[`sw${swId}`]) ? presetData.rampTimes[`sw${swId}`] : 1000;
                    const currSw = (presetData.switches && presetData.switches[switchIndex]) ? presetData.switches[switchIndex] : {};
                    const currUp = (typeof currSw.rampUp === 'number') ? currSw.rampUp : currentBase;
                    const currDn = (typeof currSw.rampDown === 'number') ? currSw.rampDown : currentBase;
                    const currInv = !!currSw.rampInvert;
                    const currAuto = (currSw.rampAutoStop === undefined) ? true : !!currSw.rampAutoStop;

                    const rGroup = document.createElement('div');
                    rGroup.className = 'form-group';
                    const rampLabel = document.createElement('label');
                    rampLabel.textContent = 'Rampa:';
                    rGroup.appendChild(rampLabel);

                    const inline = document.createElement('div');
                    inline.className = 'custom-inline-group';
                    inline.appendChild(createRampField('SUBIDA ms', `rampUp_sw${swId}`, currUp));
                    inline.appendChild(createRampField('DESCIDA ms', `rampDown_sw${swId}`, currDn));
                    rGroup.appendChild(inline);

                    const toggleRow = document.createElement('div');
                    toggleRow.className = 'ramp-toggle-row';
                    toggleRow.style.marginTop = '8px';
                    toggleRow.innerHTML = `
                          <input type="checkbox" id="rampInvert_sw${swId}" style="display:none;" ${currInv? 'checked':''}>
                          <button type="button" id="rampInvertBtn_sw${swId}" class="single-toggle-button" aria-pressed="${currInv? 'true':'false'}">${currInv? 'INVERTIDO':'NORMAL'}</button>
                          <input type="checkbox" id="rampAuto_sw${swId}" style="display:none;" ${currAuto? 'checked':''}>
                          <button type="button" id="rampAutoBtn_sw${swId}" class="single-toggle-button" aria-pressed="${currAuto? 'true':'false'}">AUTO STOP ${currAuto? 'ON':'OFF'}</button>
                    `;
                    rGroup.appendChild(toggleRow);
                    dynamicArea.appendChild(rGroup);
                    // Listeners/visuals
                    const upEl = document.getElementById(`rampUp_sw${swId}`);
                    const dnEl = document.getElementById(`rampDown_sw${swId}`);
                    const invEl = document.getElementById(`rampInvert_sw${swId}`);
                    const invBtn = document.getElementById(`rampInvertBtn_sw${swId}`);
                    const autoEl = document.getElementById(`rampAuto_sw${swId}`);
                    const autoBtn = document.getElementById(`rampAutoBtn_sw${swId}`);
                    if (upEl) { upEl.addEventListener('input', updateLocalPresetDataFromUI); upEl.addEventListener('change', updateLocalPresetDataFromUI); }
                    if (dnEl) { dnEl.addEventListener('input', updateLocalPresetDataFromUI); dnEl.addEventListener('change', updateLocalPresetDataFromUI); }
                    if (invEl && invBtn) {
                      const syncInv = () => {
                        if (invEl.checked) { invBtn.classList.add('active'); invBtn.setAttribute('aria-pressed','true'); invBtn.textContent = 'INVERTIDO'; }
                        else { invBtn.classList.remove('active'); invBtn.setAttribute('aria-pressed','false'); invBtn.textContent = 'NORMAL'; }
                      };
                      syncInv();
                      invEl.addEventListener('change', syncInv);
                      invBtn.addEventListener('click', (e)=>{ e.preventDefault(); invEl.checked = !invEl.checked; syncInv(); invEl.dispatchEvent(new Event('change', { bubbles: true })); });
                    }
                    if (autoEl && autoBtn) {
                      const syncAuto = () => {
                        if (autoEl.checked) { autoBtn.classList.add('active'); autoBtn.setAttribute('aria-pressed','true'); autoBtn.textContent = 'AUTO STOP ON'; }
                        else { autoBtn.classList.remove('active'); autoBtn.setAttribute('aria-pressed','false'); autoBtn.textContent = 'AUTO STOP OFF'; }
                      };
                      syncAuto();
                      autoEl.addEventListener('change', syncAuto);
                      autoBtn.addEventListener('click', (e)=>{ e.preventDefault(); autoEl.checked = !autoEl.checked; syncAuto(); autoEl.dispatchEvent(new Event('change', { bubbles: true })); });
                    }
                } else if (isSpin || isSpinHold) {
                    dynamicArea.style.display = 'block';
                    let spinIndex;
                    if (mode >= 1 && mode <= 3) spinIndex = mode - 1;
                    else if (mode >= 19 && mode <= 21) spinIndex = mode - 19;
                    else if (mode >= 35 && mode <= 37) spinIndex = mode - 35;
                    else if (mode >= 38 && mode <= 40) spinIndex = mode - 38 + 3;
                    else if (mode >= 41 && mode <= 43) spinIndex = mode - 41 + 3;
                    else if (mode >= 44 && mode <= 46) spinIndex = mode - 44 + 3;

                    const currentSwitchData = presetData.switches[switchIndex] || {};
                    const defaultSpin = getDefaultExtrasData().spin;
                    const spinItem = (presetData && presetData.extras && presetData.extras.spin && presetData.extras.spin[spinIndex])
                        ? presetData.extras.spin[spinIndex]
                        : (defaultSpin && defaultSpin[spinIndex])
                        || { v1: 0, v2: 64, v3: 127 };
                    generateSingleSpinUI(dynamicArea, spinItem, spinIndex, !!currentSwitchData.spin_send_pc, currentSwitchData.spin_start_on_preset !== false, !!currentSwitchData.spin_show_pos);

                    initCustomSelects();
                    const sv = spinItem || { v1: 0, v2: 64, v3: 127 };
                    ['v1','v2','v3'].forEach((vk, idx) => {
                        const id = `spinV${idx+1}_${spinIndex}`;
                        const el = document.getElementById(id);
                        if (el) {
                            const num = parseInt(sv[vk], 10);
                            el.value = (!isNaN(num) ? num : 0).toString();
                            updateCustomSelect(id);
                            updateSpinProgressBar(id);
                        }
                    });

                    if (isSpinHold) {
                        // siglaFx2Group visibility is now controlled via gigView2Group in the Display card
                        const ccHoldValue = (typeof currentSwitchData.cc_hold === 'number') ? currentSwitchData.cc_hold : 0;
                        const ccHoldStart = !!currentSwitchData.start_value;
                        const spinHoldEnabled = (currentSwitchData.start_value_cc2 !== true);

                        const holdToggleGroup = document.createElement('div');
                        holdToggleGroup.className = 'form-group';
                        holdToggleGroup.style.marginTop = '25px';
                        const spinCustomEnabled = !!(currentSwitchData.stomp_custom);
                        holdToggleGroup.innerHTML = `
                            <label>Long-press HOLD / CUSTOM:</label>
                            <div style="display:flex;gap:8px;">
                                <input type="checkbox" id="spinHoldEnabledToggle" style="display:none;" ${spinHoldEnabled ? 'checked' : ''}>
                                <button type="button" id="spinHoldEnabledBtn" class="single-toggle-button" style="flex:1;" aria-pressed="${spinHoldEnabled ? 'true' : 'false'}"></button>
                                <input type="checkbox" id="spinCustomEnabled" style="display:none;" ${spinCustomEnabled ? 'checked' : ''}>
                                <button type="button" id="spinCustomToggleBtn" class="single-toggle-button" style="flex:1;" aria-pressed="${spinCustomEnabled ? 'true' : 'false'}"></button>
                            </div>
                            <div id="spinCustomFieldsContainer" style="display:none;margin-top:10px;"></div>
                        `;
                        dynamicArea.appendChild(holdToggleGroup);

                        // Build CUSTOM value fields
                        const spinCustomContainer = document.getElementById('spinCustomFieldsContainer');
                        if (spinCustomContainer) {
                            const r = document.createElement('div');
                            r.className = 'custom-inline-group';
                            appendValueField(r, 'spinValOff', 'Valor OFF:', currentSwitchData.stomp_val_off ?? 0);
                            appendValueField(r, 'spinValOn', 'Valor ON:', currentSwitchData.stomp_val_on ?? 127);
                            spinCustomContainer.appendChild(r);
                            bindProgressBars(['spinValOff','spinValOn'], updateSpinProgressBar);
                            try { initCustomSelects(); } catch (_) {}
                        }

                        // Sync CUSTOM toggle
                        const spinCustomCheck = document.getElementById('spinCustomEnabled');
                        const spinCustomBtn = document.getElementById('spinCustomToggleBtn');
                        const syncSpinCustom = () => {
                            if (!spinCustomCheck || !spinCustomBtn) return;
                            if (spinCustomCheck.checked) {
                                spinCustomBtn.classList.add('active');
                                spinCustomBtn.setAttribute('aria-pressed', 'true');
                                spinCustomBtn.textContent = 'CUSTOM ON';
                                if (spinCustomContainer) spinCustomContainer.style.display = 'block';
                            } else {
                                spinCustomBtn.classList.remove('active');
                                spinCustomBtn.setAttribute('aria-pressed', 'false');
                                spinCustomBtn.textContent = 'CUSTOM OFF';
                                if (spinCustomContainer) spinCustomContainer.style.display = 'none';
                            }
                        };
                        syncSpinCustom();
                        if (spinCustomCheck) {
                            spinCustomCheck.addEventListener('change', () => { syncSpinCustom(); try { updateLocalPresetDataFromUI(); } catch(_) {} });
                        }
                        if (spinCustomBtn && spinCustomCheck) {
                            spinCustomBtn.addEventListener('click', (e) => {
                                e.preventDefault();
                                spinCustomCheck.checked = !spinCustomCheck.checked;
                                spinCustomCheck.dispatchEvent(new Event('change', { bubbles: true }));
                            });
                        }

                        // Divider line
                        const divider = document.createElement('hr');
                        divider.style.cssText = 'margin: 5px 0 25px 0; border: none; border-top: 1px solid rgba(255,255,255,0.1);';
                        dynamicArea.appendChild(divider);

                        const holdCcStartRow = document.createElement('div');
                        holdCcStartRow.className = 'switch-config-grid-led-start';

                        const ccHoldContainer = document.createElement('div');
                        ccHoldContainer.className = 'form-group led-group';
                        ccHoldContainer.innerHTML = `
                            <label for="switchCCHold">CC Long-press:</label>
                            <div class="custom-select-wrapper" data-select-id="switchCCHold">
                                <div class="custom-select-trigger" tabindex="0">
                                    <span class="custom-select-selected-value"></span>
                                    <span class="custom-select-arrow-down"></span>
                                </div>
                                <div class="custom-select-options"></div>
                                <select id="switchCCHold" name="switchCCHold" class="original-select"></select>
                            </div>
                        `;
                        holdCcStartRow.appendChild(ccHoldContainer);

                        const startInline = document.createElement('div');
                        startInline.className = 'form-group start-group-inline';
                        startInline.id = 'switchCCHoldStartContainer';
                        
                        const startInput = document.createElement('input');
                        startInput.type = 'checkbox';
                        startInput.id = 'switchCCHoldStart';
                        startInput.style.display = 'none';
                        startInput.checked = !!ccHoldStart;
                        startInline.appendChild(startInput);

                        const startBtn = document.createElement('button');
                        startBtn.type = 'button';
                        startBtn.id = 'startToggleBtnCCHold';
                        startBtn.className = 'single-toggle-button';
                        startInline.appendChild(startBtn);

                        const syncCcHoldStart = () => {
                            if (startInput.checked) {
                                startBtn.classList.add('active');
                                startBtn.setAttribute('aria-pressed','true');
                                startBtn.textContent = 'INICIAR LIGADO';
                            } else {
                                startBtn.classList.remove('active');
                                startBtn.setAttribute('aria-pressed','false');
                                startBtn.textContent = 'INICIAR DESLIGADO';
                            }
                        };
                        syncCcHoldStart();
                        startInput.addEventListener('change', () => { syncCcHoldStart(); try { updateLocalPresetDataFromUI(); } catch(_) {} });
                        startBtn.addEventListener('click', (e) => {
                            e.preventDefault();
                            startInput.checked = !startInput.checked;
                            syncCcHoldStart();
                            startInput.dispatchEvent(new Event('change', { bubbles: true }));
                        });
                        holdCcStartRow.appendChild(startInline);

                        dynamicArea.appendChild(holdCcStartRow);
                        // Em MODO AVANCADO, usa o modo do canal do switch para labels CC
                        if (globalMidiMode === "MODO AVANCADO") {
                            const chEl = document.getElementById('switchChannel');
                            const chMode = chEl ? getModeForChannel(parseInt(chEl.value, 10)) : getEffectiveMidiMode();
                            populateNumericSelect('switchCCHold', 0, 127, ccHoldValue, chMode);
                        } else {
                            populateNumericSelect('switchCCHold', 0, 127, ccHoldValue);
                        }

                        // Add HOLD color picker UI (matches LED2 style)
                        const holdGroup = document.createElement('div');
                        holdGroup.className = 'form-group';
                        holdGroup.innerHTML = `
                            <label for="switchHoldColorValue">Cor HOLD:</label>
                            <div class="custom-color-selector">
                                <div id="selectedHoldColorPreview" class="selected-color-preview" tabindex="0">
                                     <div id="selectedHoldColorPreviewBox" class="selected-color-preview-box"></div>
                                </div>
                                <input type="hidden" id="switchHoldColorValue" name="switchHoldColorValue">
                            </div>
                        `;
                        dynamicArea.appendChild(holdGroup);

                        // Initialize hold color preview & hidden field
                        const holdIdx = (typeof currentSwitchData.led_hold === 'number') ? currentSwitchData.led_hold : 6;
                        const holdHidden = document.getElementById('switchHoldColorValue');
                        if (holdHidden) holdHidden.value = holdIdx;
                        const holdBox = document.getElementById('selectedHoldColorPreviewBox');
                        if (holdBox && PERFIS_CORES_WEB[holdIdx]) {
                            const hexHold = PERFIS_CORES_WEB[holdIdx].value.toString(16).padStart(6, '0');
                            holdBox.style.backgroundImage = `linear-gradient(to right, black 2%, #${hexHold} 50%, black 98%)`;
                        }

                        const holdPreview = document.getElementById('selectedHoldColorPreview');
                        if (holdPreview) {
                            holdPreview.addEventListener('click', () => {
                                if (document.getElementById('spinHoldEnabledToggle')?.checked === false) return;
                                document.getElementById('colorPanelOverlay_Hold').classList.add('active');
                            });
                        }

                        const holdEnabledToggle = document.getElementById('spinHoldEnabledToggle');
                        const holdEnabledBtn = document.getElementById('spinHoldEnabledBtn');
                        const syncHoldEnabledLocal = () => {
                            syncSpinHoldEnabledUI();
                            try { updateLocalPresetDataFromUI(); } catch(_) {}
                        };
                        if (holdEnabledToggle) {
                            holdEnabledToggle.addEventListener('change', syncHoldEnabledLocal);
                        }
                        if (holdEnabledBtn && holdEnabledToggle) {
                            holdEnabledBtn.addEventListener('click', (e) => {
                                e.preventDefault();
                                holdEnabledToggle.checked = !holdEnabledToggle.checked;
                                syncHoldEnabledLocal();
                            });
                        }
                        syncSpinHoldEnabledUI(spinHoldEnabled);
                        
                    }

                    ['v1','v2','v3'].forEach((vk, idx) => {
                        const id = `spinV${idx+1}_${spinIndex}`;
                        const el = document.getElementById(id);
                        if (el) {
                            const num = parseInt(sv[vk], 10);
                            el.value = (!isNaN(num) ? num : 0).toString();
                            updateCustomSelect(id);
                            updateSpinProgressBar(id);
                        }
                    });
                } else if (isControl) {
                    dynamicArea.style.display = 'block';
                    const controlIndex = (mode >= 47) ? (mode - 47 + 3) : (mode - 7);
                    if (presetData && presetData.extras && presetData.extras.control[controlIndex]) {
                        generateSingleControlUI(dynamicArea, presetData.extras.control[controlIndex], controlIndex);
                    }
                } else if (isCustom) {
                    // Auto-convert legacy CUSTOM to STOMP + stomp_custom
                    const customIndex = mode - 10;
                    const sw = presetData.switches[switchIndex];
                    if (sw) {
                        sw.stomp_custom = true;
                        if (presetData.extras && presetData.extras.custom && presetData.extras.custom[customIndex]) {
                            sw.stomp_val_on = presetData.extras.custom[customIndex].valor_on ?? 127;
                            sw.stomp_val_off = presetData.extras.custom[customIndex].valor_off ?? 0;
                        }
                        sw.modo = 0;
                    }
                    // Re-trigger mode UI as STOMP
                    if (select) { select.value = '0'; select.dispatchEvent(new Event('change', { bubbles: true })); }
                } else if (mode === 53) { // MACROS
                    dynamicArea.style.display = 'block';
                    if(ccGroup) ccGroup.style.display = 'none';
                    if(chGroup) chGroup.style.display = 'none';
                    const currentSwitchData = presetData.switches[switchIndex] || {};
                    generateMacrosUI(dynamicArea, currentSwitchData, switchIndex);
                }

                initCustomSelects();
                try {
                    if (typeof repopulateValueSelectsForCC === 'function') {
                        repopulateValueSelectsForCC();
                    }
                } catch(_) {}

                {
                    const area = document.getElementById('dynamicModeConfigArea');
                    if (area) {
                        area.querySelectorAll('select[id^="spinV"], select[id^="customOn_"], select[id^="customOff_"]')
                            .forEach(sel => updateSpinProgressBar(sel.id));
                    }
                }
            }

            function loadSwitchDataToUI(colIndex, rowIndex, switchIdx) {
                const globalIndex = colIndex * NUM_PRESET_ROWS + rowIndex;
                const select = document.getElementById('switchMode');
                const layerIdx = currentLiveLayer - 1;
                const layerPresets = allPresetsData[layerIdx] || [];

                if (globalIndex >= layerPresets.length || !layerPresets[globalIndex] || !layerPresets[globalIndex].switches[switchIdx]) {
                    const defaultSwData = getSingleDefaultPresetData(colIndex, rowIndex).switches[switchIdx];
                    const mode = defaultSwData.modo;
                    const isCustom = (mode >= 10 && mode <= 15);
                    const isControl = (mode >= 7 && mode <= 9) || (mode >= 47 && mode <= 49);

                    const isRampaModeDefault = (mode === 4 || mode === 5 || mode === 6 || mode === 52);
                    if (isCustom) { select.value = '0'; }
                    else if (isControl) { select.value = "control_placeholder"; }
                    else if (isRampaModeDefault) { select.value = '4'; }
                    else { select.value = mode; }

                    document.getElementById('switchStart').checked = defaultSwData.start_value;
                    try { document.getElementById('switchStart').dispatchEvent(new Event('change', { bubbles: true })); } catch(_) {}
                    try {
                        const btn = document.getElementById('startToggleBtn');
                        const cbv = document.getElementById('switchStart')?.checked;
                        if (btn) {
                            if (cbv) { btn.classList.add('active'); btn.setAttribute('aria-pressed','true'); btn.textContent='INICIAR LIGADO'; }
                            else    { btn.classList.remove('active'); btn.setAttribute('aria-pressed','false'); btn.textContent='INICIAR DESLIGADO'; }
                        }
                    } catch(_) {}


                    
                    // SIGLA FX - default
                    try {
                        const siglaEl = document.getElementById('switchSiglaFx');
                        if (siglaEl) { 
                            siglaEl.value = (defaultSwData.sigla_fx || '').toString().substring(0,3).toUpperCase(); 
                            siglaEl.dataset.userEdited = '0';
                        }
                    } catch(_) {}
                    
                    document.getElementById('switchChannel').value = defaultSwData.canal;
                    const ledColorIndexDefault = typeof defaultSwData.led === 'number' ? defaultSwData.led : 0;
                    document.getElementById('switchLedColorValue').value = ledColorIndexDefault;
                    if (PERFIS_CORES_WEB[ledColorIndexDefault]) {
                        setStompAuxLedPreviewVisual('selectedLedColorPreview', 'selectedLedColorPreviewBox', PERFIS_CORES_WEB[ledColorIndexDefault].value);
                    }
                    updateCustomSelect('switchMode');
                    updateCustomSelect('switchChannel');
                    updateSwitchSpecificUI(mode.toString(), switchIdx);
                    try { syncSpinSendPcUI(!!defaultSwData.spin_send_pc, true); } catch(_) {}
                    try {
                        const spinStartCbEl = document.getElementById('spinStartOnPresetToggle');
                        const spinStartBtnEl = document.getElementById('spinStartOnPresetBtn');
                        if (spinStartCbEl && spinStartBtnEl) {
                            spinStartCbEl.checked = defaultSwData.spin_start_on_preset !== false;
                            if (spinStartCbEl.checked) spinStartBtnEl.classList.add('active');
                            else spinStartBtnEl.classList.remove('active');
                        }
                        const spinShowPosCbEl = document.getElementById('spinShowPositionToggle');
                        const spinShowPosBtnEl = document.getElementById('spinShowPositionBtn');
                        if (spinShowPosCbEl && spinShowPosBtnEl) {
                            spinShowPosCbEl.checked = !!defaultSwData.spin_show_pos;
                            spinShowPosBtnEl.textContent = spinShowPosCbEl.checked ? 'SHOW POSITION' : 'SHOW %';
                            if (spinShowPosCbEl.checked) spinShowPosBtnEl.classList.add('active');
                            else spinShowPosBtnEl.classList.remove('active');
                        }
                    } catch(_) {}
                    const singleInputDefault = document.getElementById('singleValueInput');
                    if (singleInputDefault) {
                        singleInputDefault.value = defaultSwData.single_value ?? 127;
                        updateCustomSelect('singleValueInput');
                    }
                    // after building the dynamic UI ensure autoRamp toggle reflects loaded data (modo 50)
                    try {
                        const autoRampEl = document.getElementById('autoRampToggle');
                        if (autoRampEl) {
                            autoRampEl.checked = !!defaultSwData.autoRamp;
                            autoRampEl.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                    } catch(_) {}
                    if (mode !== 17) {
                        // Em MODO AVANCADO, repopula CC labels pelo canal do switch
                        if (globalMidiMode === "MODO AVANCADO") {
                            const chMode = getModeForChannel(defaultSwData.canal);
                            populateNumericSelect('switchCC', 0, 127, defaultSwData.cc, chMode);
                        }
                        document.getElementById('switchCC').value = defaultSwData.cc;
                        updateCustomSelect('switchCC');
                        try {
                            if (typeof repopulateValueSelectsForCC === 'function') {
                                repopulateValueSelectsForCC();
                            }
                        } catch(_) {}
                    }
                    return;
                }
                const switchData = normalizeModesClient(layerPresets[globalIndex].switches[switchIdx], layerPresets[globalIndex]?.extras);
                layerPresets[globalIndex].switches[switchIdx] = switchData;
                let mode = switchData.modo;
                const isCustom = (mode >= 10 && mode <= 15);

                // Auto-convert legacy CUSTOM to STOMP + stomp_custom
                if (isCustom) {
                    const customIndex = mode - 10;
                    const extras = layerPresets[globalIndex]?.extras;
                    switchData.stomp_custom = true;
                    if (extras && extras.custom && extras.custom[customIndex]) {
                        switchData.stomp_val_on = extras.custom[customIndex].valor_on ?? 127;
                        switchData.stomp_val_off = extras.custom[customIndex].valor_off ?? 0;
                    }
                    switchData.modo = 0;
                    mode = 0;
                }

                // Auto-convert DUAL_STOMP (28) / STOMP_RAMPA (29) / DUAL_STOMP_RAMPA (50) to STOMP
                if (mode === 28 || mode === 50) {
                    switchData._dualActive = true;
                }
                if (mode === 28 || mode === 29 || mode === 50) {
                    switchData.modo = 0;
                    mode = 0;
                }

                const isRampaModeLoaded = (mode === 4 || mode === 5 || mode === 6 || mode === 52);
                if (isRampaModeLoaded) { select.value = '4'; }
                else { select.value = mode; }

                document.getElementById('switchStart').checked = switchData.start_value || false;
                try { document.getElementById('switchStart').dispatchEvent(new Event('change', { bubbles: true })); } catch(_) {}
                try {
                    const btn = document.getElementById('startToggleBtn');
                    const cbv = document.getElementById('switchStart')?.checked;
                    if (btn) {
                        if (cbv) { btn.classList.add('active'); btn.setAttribute('aria-pressed','true'); btn.textContent='INICIAR LIGADO'; }
                        else    { btn.classList.remove('active'); btn.setAttribute('aria-pressed','false'); btn.textContent='INICIAR DESLIGADO'; }
                    }
                } catch(_) {}
                const singleInput = document.getElementById('singleValueInput');
                if (singleInput) {
                    singleInput.value = switchData.single_value ?? 127;
                    updateCustomSelect('singleValueInput');
                }
                document.getElementById('switchChannel').value = switchData.canal;
                const ledColorIndex = typeof switchData.led === 'number' ? switchData.led : 0;
                if (PERFIS_CORES_WEB[ledColorIndex]) {
                    setStompAuxLedPreviewVisual('selectedLedColorPreview', 'selectedLedColorPreviewBox', PERFIS_CORES_WEB[ledColorIndex].value);
                }
                document.getElementById('switchLedColorValue').value = ledColorIndex;
                updateActiveButton('switchSelection', switchIdx);
                updateCustomSelect('switchMode');
                updateCustomSelect('switchChannel');

                if (mode >= 4 && mode <= 6) {
                    select.value = 4;
                    updateCustomSelect('switchMode');
                    updateSwitchSpecificUI(String(mode), switchIdx);
                } else {
                    updateSwitchSpecificUI(mode.toString(), switchIdx);
                }

                // ensure autoRamp toggle (for modo 50) reflects loaded server data after dynamic UI is built
                try {
                    const autoRampEl = document.getElementById('autoRampToggle');
                    if (autoRampEl) {
                        autoRampEl.checked = !!switchData.autoRamp;
                        autoRampEl.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                } catch(_) {}

                // SIGLA FX - loaded AFTER updateSwitchSpecificUI to ensure elements exist
                try {
                    const siglaFxInput = document.getElementById('switchSiglaFx');
                    if (siglaFxInput) {
                        siglaFxInput.value = (switchData.sigla_fx || "");
                        siglaFxInput.dataset.userEdited = '0';
                    }
                    const siglaFx2Input = document.getElementById('switchSiglaFx2');
                    if (siglaFx2Input) {
                        siglaFx2Input.value = (switchData.sigla_fx_2 || "");
                        siglaFx2Input.dataset.userEdited = '0';
                    }
                    // ICON FX - set mode toggle and select values
                    if (typeof setFxModeFromData === 'function') {
                        setFxModeFromData(1, switchData.icon_fx || 0);
                        setFxModeFromData(2, switchData.icon_fx_2 || 0);
                    }
                    // ICON NAME - load into input
                    const iconNameEl = document.getElementById('switchIconName');
                    if (iconNameEl) iconNameEl.value = switchData.icon_name || '';
                } catch(_) {}

                try { syncSpinSendPcUI(!!switchData.spin_send_pc, true); } catch(_) {}
                try {
                    const spinStartCbEl = document.getElementById('spinStartOnPresetToggle');
                    const spinStartBtnEl = document.getElementById('spinStartOnPresetBtn');
                    if (spinStartCbEl && spinStartBtnEl) {
                        spinStartCbEl.checked = switchData.spin_start_on_preset !== false;
                        if (spinStartCbEl.checked) spinStartBtnEl.classList.add('active');
                        else spinStartBtnEl.classList.remove('active');
                    }
                    const spinShowPosCbEl = document.getElementById('spinShowPositionToggle');
                    const spinShowPosBtnEl = document.getElementById('spinShowPositionBtn');
                    if (spinShowPosCbEl && spinShowPosBtnEl) {
                        spinShowPosCbEl.checked = !!switchData.spin_show_pos;
                        spinShowPosBtnEl.textContent = spinShowPosCbEl.checked ? 'SHOW POSITION' : 'SHOW %';
                        if (spinShowPosCbEl.checked) spinShowPosBtnEl.classList.add('active');
                        else spinShowPosBtnEl.classList.remove('active');
                    }
                } catch(_) {}

                const FAVORITE_MODE_VALUE = 17;
                if (mode !== FAVORITE_MODE_VALUE) {
                    const swCcSelect = document.getElementById('switchCC');
                    if (swCcSelect && swCcSelect.closest('.form-group').style.display !== 'none') {
                         // Em MODO AVANCADO, repopula CC labels pelo canal do switch
                         if (globalMidiMode === "MODO AVANCADO") {
                             const chMode = getModeForChannel(switchData.canal);
                             populateNumericSelect('switchCC', 0, 127, switchData.cc, chMode);
                         }
                         swCcSelect.value = switchData.cc;
                         updateCustomSelect('switchCC');
                         try {
                             if (typeof repopulateValueSelectsForCC === 'function') {
                                 repopulateValueSelectsForCC();
                             }
                         } catch(_) {}
                    }
                }
                if ((mode >= 35 && mode <= 37) || (mode >= 44 && mode <= 46)) {
                    const swHoldEnabled = document.getElementById('spinHoldEnabledToggle');
                    if (swHoldEnabled) {
                        swHoldEnabled.checked = (switchData.start_value_cc2 !== true);
                        syncSpinHoldEnabledUI(swHoldEnabled.checked);
                    }
                    const swCCHold = document.getElementById('switchCCHold');
                    if (swCCHold) {
                        // Em MODO AVANCADO, repopula CC Hold labels pelo canal do switch
                        if (globalMidiMode === "MODO AVANCADO") {
                            const chMode = getModeForChannel(switchData.canal);
                            populateNumericSelect('switchCCHold', 0, 127, switchData.cc_hold || 0, chMode);
                        }
                        swCCHold.value = switchData.cc_hold || 0;
                        updateCustomSelect('switchCCHold');
                    }
                    const swCCHoldStart = document.getElementById('switchCCHoldStart');
                    if (swCCHoldStart) {
                        swCCHoldStart.checked = !!switchData.start_value;
                    }
                    
                }
            }
            
            function updateCustomSelect(selectId) {
                const originalSelect = document.getElementById(selectId);
                if (!originalSelect) return;
                const wrapper = document.querySelector(`.custom-select-wrapper[data-select-id="${selectId}"]`);
                if (!wrapper) return;
                const selectedValueSpan = wrapper.querySelector('.custom-select-selected-value');
                const optionsDiv = wrapper.querySelector('.custom-select-options');
                if (!selectedValueSpan || !optionsDiv) return;
                // Se as options do select mudaram (dirty), rebuilda as custom options
                if (originalSelect.dataset.dirty === '1') {
                    if (typeof populateCustomOptions === 'function') {
                        populateCustomOptions(originalSelect, optionsDiv, selectedValueSpan, wrapper);
                    }
                    originalSelect.dataset.dirty = '';
                }
                const currentValue = originalSelect.value;
                const selectedOption = Array.from(originalSelect.options).find(opt => opt.value === currentValue);
                
                let textToShow = selectedOption ? selectedOption.textContent : '';
                if (originalSelect.id.startsWith('spinV') || originalSelect.id.startsWith('customOff_') || originalSelect.id.startsWith('customOn_')) {
                    const numValue = parseInt(currentValue, 10);
                    if (!isNaN(numValue) && selectedOption) { 
                        textToShow = `${numValue}`;
                    } else if (selectedOption) {
                        textToShow = selectedOption.textContent;
                    } else {
                        textToShow = ''; 
                    }
                }
                selectedValueSpan.textContent = textToShow;

                optionsDiv.querySelectorAll('.custom-select-option').forEach(opt => {
                    if (opt.dataset.value === currentValue) {
                        opt.classList.add('selected');
                    } else {
                        opt.classList.remove('selected');
                    }
                });
                if (typeof ensureMiniSliderForWrapper === 'function') {
                    ensureMiniSliderForWrapper(originalSelect, wrapper);
                }
            }
            function updatePresetNameColorData(colorValue) {
                const globalPresetIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const preset = ensurePresetDataForLayer(globalPresetIndex, 0, currentPresetColumnIndex, currentPresetRowIndex);
                if (preset) {
                    preset.nomePresetTextColor = colorValue;
                    syncSharedPresetFieldsForIndex(globalPresetIndex, currentPresetColumnIndex, currentPresetRowIndex);
                }
            }
            function updatePresetBgColorData(colorValue) {
                const globalPresetIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const preset = ensurePresetDataForLayer(globalPresetIndex, 0, currentPresetColumnIndex, currentPresetRowIndex);
                if (preset) {
                    preset.backgroundColorConfig = colorValue;
                    syncSharedPresetFieldsForIndex(globalPresetIndex, currentPresetColumnIndex, currentPresetRowIndex);
                }
            }
            function updateBackTagColorData(colorValue) {
                const globalPresetIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const preset = ensurePresetDataForLayer(globalPresetIndex, 0, currentPresetColumnIndex, currentPresetRowIndex);
                if (preset) {
                    preset.backTagColor = colorValue;
                    syncSharedPresetFieldsForIndex(globalPresetIndex, currentPresetColumnIndex, currentPresetRowIndex);
                }
            }
            function updateSwitchLedColorData(colorIndex) { 
                const globalPresetIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const layerIdx = currentLiveLayer - 1;
                const layerPresets = allPresetsData[layerIdx] || [];
                const preset = layerPresets[globalPresetIndex];
                if (preset && preset.switches && preset.switches[currentSwitchIndex]) {
                    preset.switches[currentSwitchIndex].led = colorIndex;
                }
                updateLiveLayerButtonColorFromCurrentSwitch();
            }

            function updateSwitchLed2ColorData(colorIndex) {
                const globalPresetIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const layerIdx = currentLiveLayer - 1;
                const layerPresets = allPresetsData[layerIdx] || [];
                const preset = layerPresets[globalPresetIndex];
                if (preset && preset.switches && preset.switches[currentSwitchIndex]) {
                    preset.switches[currentSwitchIndex].led2 = colorIndex;
                }
            }

            function updateSwitchHoldColorData(colorIndex) {
                const globalPresetIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const layerIdx = currentLiveLayer - 1;
                const layerPresets = allPresetsData[layerIdx] || [];
                const preset = layerPresets[globalPresetIndex];
                if (preset && preset.switches && preset.switches[currentSwitchIndex]) {
                    preset.switches[currentSwitchIndex].led_hold = colorIndex;
                }
            }

            function updateSwitchLed3ColorData(colorIndex) {
                const globalPresetIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const layerIdx = currentLiveLayer - 1;
                const layerPresets = allPresetsData[layerIdx] || [];
                const preset = layerPresets[globalPresetIndex];
                if (preset && preset.switches && preset.switches[currentSwitchIndex]) {
                    preset.switches[currentSwitchIndex].led3 = colorIndex;
                }
            }

            function updateLiveLayerButtonColorFromCurrentSwitch() {
                // Apesar do nome legado, aqui usamos APENAS as cores globais
                // definidas em GLOBAL_CONFIG: LIVE MODE 1 / LIVE MODE 2.
                try {
                    const layerBtn = document.getElementById('liveLayerToggleButton');
                    if (!layerBtn) return;

                    const colorUint32 = (currentLiveLayer === 2) ? liveModeColorLayer2 : liveModeColorLayer1;
                    if (typeof colorUint32 !== 'number') return;

                    const r = (colorUint32 >> 16) & 0xFF;
                    const g = (colorUint32 >> 8) & 0xFF;
                    const b = colorUint32 & 0xFF;
                    const hex = `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;

                    layerBtn.style.borderColor = hex;
                    layerBtn.style.color = hex;
                    layerBtn.style.boxShadow = `0 0 12px ${hex}88, 0 0 26px ${hex}44`;
                } catch (_) {}
            }

            function applyLiveModeColorToCurrentPresetSwitches() {
                // Ajusta os 6 SWs do preset atual para usar a cor
                // de LIVE MODE correspondente ao layer selecionado.
                try {
                    const colorUint32 = (currentLiveLayer === 2) ? liveModeColorLayer2 : liveModeColorLayer1;
                    if (typeof colorUint32 !== 'number') return;

                    // Encontra o Ã­ndice em PERFIS_CORES_WEB cujo value bate com a cor global
                    let ledIndex = 0;
                    for (let i = 0; i < PERFIS_CORES_WEB.length; i++) {
                        if (PERFIS_CORES_WEB[i] && PERFIS_CORES_WEB[i].value === colorUint32) {
                            ledIndex = i;
                            break;
                        }
                    }

                    const globalIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                    const layerIdx = currentLiveLayer - 1;
                    const layerPresets = allPresetsData[layerIdx] || [];

                    if (!layerPresets[globalIndex]) {
                        layerPresets[globalIndex] = getSingleDefaultPresetData(currentPresetColumnIndex, currentPresetRowIndex);
                    }
                    const presetData = layerPresets[globalIndex];

                    if (!Array.isArray(presetData.switches)) {
                        presetData.switches = getSingleDefaultPresetData(currentPresetColumnIndex, currentPresetRowIndex).switches;
                    }

                    for (let i = 0; i < presetData.switches.length; i++) {
                        if (!presetData.switches[i]) {
                            presetData.switches[i] = getSingleDefaultPresetData(currentPresetColumnIndex, currentPresetRowIndex).switches[i];
                        }
                        presetData.switches[i].led = ledIndex;
                    }

                    updateAllFootButtonsUI();
                } catch (_) {}
            }

            function applySwitchCommonFieldsFromMemory(modeValue, globalIndex) {
                try {
                    const layerIdx = currentLiveLayer - 1;
                    const layerPresets = allPresetsData[layerIdx] || [];
                    const sw = layerPresets[globalIndex]?.switches?.[currentSwitchIndex];
                    if (!sw) return;

                    const swCh = document.getElementById('switchChannel');
                    if (swCh) { swCh.value = sw.canal ?? 1; updateCustomSelect('switchChannel'); }
                    const swCc = document.getElementById('switchCC');
                    if (swCc && swCc.closest('.form-group').style.display !== 'none') {
                        swCc.value = sw.cc ?? 0; updateCustomSelect('switchCC');
                    }

                    const ledIdx = (typeof sw.led === 'number') ? sw.led : 0;
                    const ledHidden = document.getElementById('switchLedColorValue');
                    if (ledHidden) ledHidden.value = ledIdx;
                    if (PERFIS_CORES_WEB[ledIdx]) {
                        setStompAuxLedPreviewVisual('selectedLedColorPreview', 'selectedLedColorPreviewBox', PERFIS_CORES_WEB[ledIdx].value);
                    }

                    // SIGLA FX - from memory
                    const siglaEl = document.getElementById('switchSiglaFx');
                    if (siglaEl) { 
                        siglaEl.value = (sw.sigla_fx || '').toString().substring(0,3).toUpperCase(); 
                        siglaEl.dataset.userEdited = '0';
                    }
                    // SIGLA FX 2 - from memory
                    const sigla2El = document.getElementById('switchSiglaFx2');
                    if (sigla2El) { 
                        sigla2El.value = (sw.sigla_fx_2 || '').toString().substring(0,3).toUpperCase(); 
                        sigla2El.dataset.userEdited = '0';
                    }
                    const sigla2Dyn = document.getElementById('switchSiglaFx2_Dynamic');
                    if (sigla2Dyn) {
                        sigla2Dyn.value = (sw.sigla_fx_2 || '').toString().substring(0,3).toUpperCase();
                    }


                    if (modeValue === 28 || modeValue === 50 || modeValue === 18) {
                        const cc2El = document.getElementById('switchCC2');
                        if (cc2El) { cc2El.value = sw.cc2 ?? 0; }
                        const led2El = document.getElementById('switchLed2ColorValue');
                        if (led2El) { led2El.value = sw.led2 ?? 0; }
                        const led2Idx = sw.led2 ?? 0;
                        if (PERFIS_CORES_WEB[led2Idx]) {
                            setStompAuxLedPreviewVisual('selectedLed2ColorPreview', 'selectedLed2ColorPreviewBox', PERFIS_CORES_WEB[led2Idx].value);
                        }
                        if (modeValue === 50) {
                            const autoRampEl = document.getElementById('autoRampToggle');
                            if (autoRampEl) {
                                autoRampEl.checked = !!sw.autoRamp;
                                autoRampEl.dispatchEvent(new Event('change', { bubbles: true }));
                            }
                        }
                        try {
                            if (typeof repopulateValueSelectsForCC === 'function') {
                                repopulateValueSelectsForCC();
                            }
                        } catch(_) {}
                    }

                    if ((modeValue >= 35 && modeValue <= 37) || (modeValue >= 44 && modeValue <= 46)) {
                        const swHoldEnabled = document.getElementById('spinHoldEnabledToggle');
                        if (swHoldEnabled) {
                            swHoldEnabled.checked = (sw.start_value_cc2 !== true);
                            syncSpinHoldEnabledUI(swHoldEnabled.checked);
                        }
                        const swCCHold = document.getElementById('switchCCHold');
                        if (swCCHold) { swCCHold.value = sw.cc_hold ?? 0; updateCustomSelect('switchCCHold'); }
                        const swCCHoldStart = document.getElementById('switchCCHoldStart');
                        if (swCCHoldStart) swCCHoldStart.checked = !!sw.start_value;
                    }

                    // Atualiza sliders/knobs para SPIN
                    const isSpinMode = (modeValue >= 1 && modeValue <= 3)
                                     || (modeValue >= 35 && modeValue <= 37) || (modeValue >= 38 && modeValue <= 46);
                    if (isSpinMode) {
                        let spinIndex;
                        if (modeValue >= 1 && modeValue <= 3) spinIndex = modeValue - 1;
                        else if (modeValue >= 19 && modeValue <= 21) spinIndex = modeValue - 19;
                        else if (modeValue >= 35 && modeValue <= 37) spinIndex = modeValue - 35;
                        else if (modeValue >= 38 && modeValue <= 40) spinIndex = modeValue - 38 + 3;
                        else if (modeValue >= 41 && modeValue <= 43) spinIndex = modeValue - 41 + 3;
                        else if (modeValue >= 44 && modeValue <= 46) spinIndex = modeValue - 44 + 3;

                        const layerIdx = currentLiveLayer - 1;
                        const layerPresets = allPresetsData[layerIdx] || [];
                        const presetData = layerPresets[globalIndex];
                        try {
                            syncSpinSendPcUI(!!sw.spin_send_pc, true);
                        } catch(_) {}
                        try {
                            const spinStartCbEl = document.getElementById('spinStartOnPresetToggle');
                            const spinStartBtnEl = document.getElementById('spinStartOnPresetBtn');
                            if (spinStartCbEl && spinStartBtnEl) {
                                spinStartCbEl.checked = sw.spin_start_on_preset !== false;
                                if (spinStartCbEl.checked) spinStartBtnEl.classList.add('active');
                                else spinStartBtnEl.classList.remove('active');
                            }
                            const spinShowPosCbEl = document.getElementById('spinShowPositionToggle');
                            const spinShowPosBtnEl = document.getElementById('spinShowPositionBtn');
                            if (spinShowPosCbEl && spinShowPosBtnEl) {
                                spinShowPosCbEl.checked = !!sw.spin_show_pos;
                                spinShowPosBtnEl.textContent = spinShowPosCbEl.checked ? 'SHOW POSITION' : 'SHOW %';
                                if (spinShowPosCbEl.checked) spinShowPosBtnEl.classList.add('active');
                                else spinShowPosBtnEl.classList.remove('active');
                            }
                        } catch(_) {}
                        const defaults = getDefaultExtrasData().spin;
                        const sv = (presetData && presetData.extras && Array.isArray(presetData.extras.spin) && presetData.extras.spin[spinIndex])
                                  ? presetData.extras.spin[spinIndex]
                                  : (defaults && defaults[spinIndex]) || { v1: 0, v2: 64, v3: 127 };

                        ['v1','v2','v3'].forEach((vk, idx) => {
                            const id = `spinV${idx+1}_${spinIndex}`;
                            const el = document.getElementById(id);
                            if (el) {
                                const num = parseInt(sv[vk], 10);
                                el.value = (!isNaN(num) ? num : 0).toString();
                                updateCustomSelect(id);
                                updateSpinKnobVisual(id);
                            }
                        });
                    }
                } catch (_) {}
            }

            // === ICON COLOR AND FILL HANDLERS ===
            (function initIconColorAndFill() {
                
                function setupColorPicker(triggerId, overlayId, panelId, hiddenInputId, previewBoxId, title) {
                    const colorPreview = document.getElementById(triggerId);
                    const colorOverlay = document.getElementById(overlayId);
                    
                    if (colorPreview && colorOverlay) {
                        colorPreview.addEventListener('click', () => colorOverlay.classList.add('active'));
                        colorOverlay.addEventListener('click', (e) => {
                            if (e.target === colorOverlay) colorOverlay.classList.remove('active');
                        });
                    }
                    
                    if (document.getElementById(panelId) && typeof PRESET_DIRECT_COLORS_WEB !== 'undefined') {
                        createColorOptionsPanel(panelId, PRESET_DIRECT_COLORS_WEB, (storedValue, idx, color) => {
                            const box = document.getElementById(previewBoxId);
                            if (box) {
                                const isDot = !!(box.parentElement && box.parentElement.classList && box.parentElement.classList.contains('gig-dot-preview'));
                                applyColorPreview(box, color || storedValue, isDot ? 'dot' : 'bar');
                            }
                            const hidden = document.getElementById(hiddenInputId);
                            if (hidden) hidden.value = (typeof color.actualIndex === 'number') ? color.actualIndex : idx;
                            updateLocalPresetDataFromUI();
                            try { if (typeof updateGigViewPreview === 'function') updateGigViewPreview(); } catch(_) {}
                            try { if (typeof updateGigView2Preview === 'function') updateGigView2Preview(); } catch(_) {}
                        }, { gradientPalette: true, panelTitle: title });
                    }
                }

                // Init all pickers
                setupColorPicker('selectedIconColorPreview', 'colorPanelOverlay_IconColor', 'colorPanel_IconColor', 'switchIconColorValue', 'selectedIconColorPreviewBox', 'Cor do Ãcone (ON)');
                setupColorPicker('selectedIconColorOffPreview', 'colorPanelOverlay_IconColorOff', 'colorPanel_IconColorOff', 'switchIconColorOffValue', 'selectedIconColorOffPreviewBox', 'Cor do Ãcone (OFF)');
                setupColorPicker('selectedBorderColorOffPreview', 'colorPanelOverlay_BorderColorOff', 'colorPanel_BorderColorOff', 'switchBorderColorOffValue', 'selectedBorderColorOffPreviewBox', 'Cor da Borda (OFF)');
                setupColorPicker('selectedBorderColorOnPreview', 'colorPanelOverlay_BorderColorOn', 'colorPanel_BorderColorOn', 'switchBorderColorOnValue', 'selectedBorderColorOnPreviewBox', 'Cor da Borda (ON)');
                setupColorPicker('selectedBackColorOnPreview', 'colorPanelOverlay_BackColorOn', 'colorPanel_BackColorOn', 'switchBackColorOnValue', 'selectedBackColorOnPreviewBox', 'Cor do Back (ON)');
                setupColorPicker('selectedBackColorOffPreview', 'colorPanelOverlay_BackColorOff', 'colorPanel_BackColorOff', 'switchBackColorOffValue', 'selectedBackColorOffPreviewBox', 'Cor do Back (OFF)');
                setupColorPicker('selectedIconColor2Preview', 'colorPanelOverlay_IconColor2', 'colorPanel_IconColor2', 'switchIconColor2Value', 'selectedIconColor2PreviewBox', 'Cor do Icone 2 (ON)');
                setupColorPicker('selectedIconColor2OffPreview', 'colorPanelOverlay_IconColorOff2', 'colorPanel_IconColorOff2', 'switchIconColor2OffValue', 'selectedIconColor2OffPreviewBox', 'Cor do Icone 2 (OFF)');
                setupColorPicker('selectedBorderColorOff2Preview', 'colorPanelOverlay_BorderColorOff2', 'colorPanel_BorderColorOff2', 'switchBorderColorOff2Value', 'selectedBorderColorOff2PreviewBox', 'Cor da Borda 2 (OFF)');
                setupColorPicker('selectedBackColorOn2Preview', 'colorPanelOverlay_BackColorOn2', 'colorPanel_BackColorOn2', 'switchBackColorOn2Value', 'selectedBackColorOn2PreviewBox', 'Cor do Back 2 (ON)');
                setupColorPicker('selectedBackColorOff2Preview', 'colorPanelOverlay_BackColorOff2', 'colorPanel_BackColorOff2', 'switchBackColorOff2Value', 'selectedBackColorOff2PreviewBox', 'Cor do Back 2 (OFF)');
                setupColorPicker('selectedBorderColorOn2Preview', 'colorPanelOverlay_BorderColorOn2', 'colorPanel_BorderColorOn2', 'switchBorderColorOn2Value', 'selectedBorderColorOn2PreviewBox', 'Cor da Borda 2 (ON)');

            })();


            // GIG VIEW fica sempre visivel (sem colapso)
            (function() {
                const content = document.getElementById('displayConfigGrid');
                if (content) content.style.display = 'block';
            })();

            let presetAutoSaveTimer = null;
            let presetSaveInFlight = false;
            let presetSaveQueued = false;
            let suppressPresetAutoSave = false;
            let presetAutoSaveEnabled = false;
            const lastSavedPresetPayloadByKey = {};

            function updateLocalPresetDataFromUI() {
                if (typeof suppressModelUpdate !== 'undefined' && suppressModelUpdate) return;
                const globalIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const layerIdx = currentLiveLayer - 1;
                let presetToUpdate = ensurePresetDataForLayer(globalIndex, layerIdx, currentPresetColumnIndex, currentPresetRowIndex);
                const sharedPresetToUpdate = ensurePresetDataForLayer(globalIndex, 0, currentPresetColumnIndex, currentPresetRowIndex);
                sharedPresetToUpdate.nomePresetFont = (parseInt(document.getElementById('presetNameFontValue')?.value || '2', 10) === 1) ? 1 : 2;
                const presetNameMaxLen = getPresetNameMaxLengthForFont(sharedPresetToUpdate.nomePresetFont);
                sharedPresetToUpdate.nomePreset = document.getElementById('presetNameInput').value.substring(0, presetNameMaxLen);
                sharedPresetToUpdate.bank = parseInt(document.getElementById('presetBankInput').value, 10);
                {
                    const chVal = parseInt(document.getElementById('presetChannelInput').value, 10);
                    sharedPresetToUpdate.canal = (!isNaN(chVal) && chVal >= 0 && chVal <= 16) ? chVal : 1;
                }
                syncSharedPresetFieldsForIndex(globalIndex, currentPresetColumnIndex, currentPresetRowIndex);

                let modeValue;
                const switchModeSelect = document.getElementById('switchMode');
                if (switchModeSelect.value === 'custom_placeholder') {
                    modeValue = 10 + currentSwitchIndex;
                } else {
                    modeValue = parseInt(switchModeSelect.value, 10);
                }

                // SW COMBO removido: descartar caso apareça em dados/seleções antigas.
                if (modeValue >= 30 && modeValue <= 34) {
                    modeValue = 0;
                }
                const stompStateValue = document.getElementById('stompModeStateValue')?.value || 'single';
                if (modeValue === 0 && stompStateValue !== 'single') {
                    modeValue = 28;
                }
                
                
                // Modo RAMPA: mantemos valor 4 (unificado). Opcoes sao salvas em campos extras do switch

                if (presetToUpdate.switches && presetToUpdate.switches[currentSwitchIndex]) {
                    let currentSwitchData = presetToUpdate.switches[currentSwitchIndex];
                    currentSwitchData.modo = modeValue;
                    const FAVORITE_MODE_VALUE = 17;
                    if (currentSwitchData.modo === FAVORITE_MODE_VALUE) {
                        const favoriteSelect = document.getElementById(`swFavoritePresetSelect_${currentSwitchIndex}`);
                        if (favoriteSelect) {
                            currentSwitchData.favoritePresetIndex = parseInt(favoriteSelect.value, 10);
                            currentSwitchData.cc = currentSwitchData.favoritePresetIndex;
                        } else { currentSwitchData.cc = undefined; }
                        // Captura estado do toggle "MODO LIVE"
                        const favAutoInput = document.getElementById(`favoriteLiveToggle_${currentSwitchIndex}`);
                        if (favAutoInput) {
                            currentSwitchData.favoriteAutoLive = !!favAutoInput.checked;
                        }
                    } else {
                        currentSwitchData.cc = parseInt(document.getElementById('switchCC').value, 10);
                        currentSwitchData.favoritePresetIndex = undefined;
                    }
                    currentSwitchData.start_value = document.getElementById('switchStart').checked;
                    // STOMP: 3-state toggle + custom values per card
                    if (currentSwitchData.modo === 0 || currentSwitchData.modo === 28) {
                        const stompState = document.getElementById('stompModeStateValue')?.value
                            || (document.getElementById('reclickEnabled')?.checked ? 'reclick'
                                : (document.getElementById('dualStompEnabled')?.checked ? 'dual' : 'single'));
                        currentSwitchData._dualActive = stompState !== 'single';
                        currentSwitchData.reclick_enabled = stompState === 'reclick';
                        currentSwitchData.modo = currentSwitchData._dualActive ? 28 : 0;

                        currentSwitchData.stomp_custom = !!document.getElementById('stompSingleCustomEnabled')?.checked;
                        currentSwitchData.ds_custom_enabled = currentSwitchData._dualActive
                            ? !!document.getElementById('dualStompCustomEnabled')?.checked
                            : false;

                        currentSwitchData.stomp_val_on = parseInt(document.getElementById('stompValOn')?.value, 10);
                        if (isNaN(currentSwitchData.stomp_val_on)) currentSwitchData.stomp_val_on = 127;
                        currentSwitchData.stomp_val_off = parseInt(document.getElementById('stompValOff')?.value, 10);
                        if (isNaN(currentSwitchData.stomp_val_off)) currentSwitchData.stomp_val_off = 0;

                        currentSwitchData.ds_cc1_off = currentSwitchData.stomp_val_off;
                        currentSwitchData.ds_cc1_on = currentSwitchData.stomp_val_on;
                        currentSwitchData.ds_cc2_off = parseInt(document.getElementById('dsCC2Off')?.value, 10) || 0;
                        currentSwitchData.ds_cc2_on = parseInt(document.getElementById('dsCC2On')?.value, 10) || 127;

                        const reclickCustomEl = document.getElementById('reclickCustomEnabled');
                        currentSwitchData.reclick_custom_enabled = !!(reclickCustomEl && reclickCustomEl.checked);
                        const reclickOffEl = document.getElementById('reclickValOff');
                        if (reclickOffEl) {
                            const reclickOffVal = parseInt(reclickOffEl.value, 10);
                            currentSwitchData.reclick_val_off = isNaN(reclickOffVal) ? 0 : reclickOffVal;
                        }
                        const reclickOnEl = document.getElementById('reclickValOn');
                        if (reclickOnEl) {
                            const reclickOnVal = parseInt(reclickOnEl.value, 10);
                            currentSwitchData.reclick_val_on = isNaN(reclickOnVal) ? 127 : reclickOnVal;
                        }

                        const cc3El = document.getElementById('switchCC3');
                        if (cc3El) {
                            currentSwitchData.cc3 = parseInt(cc3El.value, 10) || 0;
                        }
                        const cc3ChEl = document.getElementById('switchChannelCC3');
                        if (cc3ChEl) {
                            const chVal3 = parseInt(cc3ChEl.value, 10);
                            currentSwitchData.canal_cc3 = (!isNaN(chVal3) && chVal3 >= 0 && chVal3 <= 16) ? chVal3 : 1;
                        } else if (currentSwitchData.canal_cc3 === undefined) {
                            currentSwitchData.canal_cc3 = 1;
                        }
                        currentSwitchData.cc3_ch = currentSwitchData.canal_cc3;
                        const cc3StartEl = document.getElementById('switchCC3Start');
                        currentSwitchData.start_value_cc3 = !!(cc3StartEl && cc3StartEl.checked);
                        const led3El = document.getElementById('switchLed3ColorValue');
                        if (led3El) {
                            currentSwitchData.led3 = parseInt(led3El.value, 10) || 0;
                        }
                        // STOMP send PC toggles
                        const stompSendPcEl = document.getElementById('stompSendPcToggle');
                        currentSwitchData.stomp_send_pc = !!(stompSendPcEl && stompSendPcEl.checked);
                        const dualSendPcEl = document.getElementById('dualSendPcToggle');
                        currentSwitchData.dual_send_pc = !!(dualSendPcEl && dualSendPcEl.checked);
                        const reclickSendPcEl = document.getElementById('reclickSendPcToggle');
                        currentSwitchData.reclick_send_pc = !!(reclickSendPcEl && reclickSendPcEl.checked);
                    }
                    if (currentSwitchData.modo === 16) {
                        const singleValEl = document.getElementById('singleValueInput');
                        const sv = parseInt(singleValEl ? singleValEl.value : 127, 10);
                        currentSwitchData.single_value = Number.isNaN(sv) ? 127 : Math.max(0, Math.min(127, sv));
                    }
                    const spinSendInput = document.getElementById('spinSendPcToggle');
                    if (spinSendInput) {
                        currentSwitchData.spin_send_pc = !!spinSendInput.checked;
                    } else if (currentSwitchData.spin_send_pc === undefined) {
                        currentSwitchData.spin_send_pc = false;
                    }
                    const spinStartInput = document.getElementById('spinStartOnPresetToggle');
                    if (spinStartInput) {
                        currentSwitchData.spin_start_on_preset = !!spinStartInput.checked;
                    } else if (currentSwitchData.spin_start_on_preset === undefined) {
                        currentSwitchData.spin_start_on_preset = true;
                    }
                    const spinShowPosInput = document.getElementById('spinShowPositionToggle');
                    if (spinShowPosInput) {
                        currentSwitchData.spin_show_pos = !!spinShowPosInput.checked;
                    } else if (currentSwitchData.spin_show_pos === undefined) {
                        currentSwitchData.spin_show_pos = false;
                    }
                    {
                        const chVal = parseInt(document.getElementById('switchChannel').value, 10);
                        currentSwitchData.canal = (!isNaN(chVal) && chVal >= 0 && chVal <= 16) ? chVal : 1;
                    }
                    currentSwitchData.led = parseInt(document.getElementById('switchLedColorValue').value, 10) || 0;
                    // SIGLA/ICON FX (mutually exclusive) - save
                    try {
                        const fxMode1 = document.getElementById('fxModeToggle1')?.getAttribute('data-mode') || 'sigla';
                        const iconFxValueRaw = parseInt(document.getElementById('switchIconFxValue')?.value, 10) || 0;
                        const iconFxValue = (iconFxValueRaw >= 0 && iconFxValueRaw <= MAX_FX_ICON_ID) ? iconFxValueRaw : 0;
                        const siglaEl = document.getElementById('switchSiglaFx');
                        const siglaRaw = (siglaEl?.value || '').toString().toUpperCase();
                        const sigla = siglaRaw.substring(0, 3);
                        const userEdited = siglaEl && siglaEl.dataset.userEdited === '1';

                        if (fxMode1 === 'icon') {
                            currentSwitchData.icon_fx = iconFxValue;
                            currentSwitchData.sigla_fx = "";
                            const iconNameEl = document.getElementById('switchIconName');
                            currentSwitchData.icon_name = (iconNameEl?.value || '').substring(0, 6);

                            const iconColorVal = parseInt(document.getElementById('switchIconColorValue')?.value, 10);
                            currentSwitchData.icon_color = (!isNaN(iconColorVal) && iconColorVal >= 0) ? iconColorVal : 6;
                            
                            const iconColorOffVal = parseInt(document.getElementById('switchIconColorOffValue')?.value, 10);
                            currentSwitchData.icon_color_off = (!isNaN(iconColorOffVal) && iconColorOffVal >= 0) ? iconColorOffVal : 6;

                            const borderOffVal = parseInt(document.getElementById('switchBorderColorOffValue')?.value, 10);
                            currentSwitchData.border_color_off = (!isNaN(borderOffVal) && borderOffVal >= 0) ? borderOffVal : 9;

                            // Border ON color
                            const borderOnVal = parseInt(document.getElementById('switchBorderColorOnValue')?.value, 10);
                            currentSwitchData.border_color_on = (!isNaN(borderOnVal) && borderOnVal >= 0) ? borderOnVal : 9;

                            const backOnVal = parseInt(document.getElementById('switchBackColorOnValue')?.value, 10);
                            currentSwitchData.back_color_on = (!isNaN(backOnVal) && backOnVal >= 0) ? backOnVal : 9;
                            const backOffVal = parseInt(document.getElementById('switchBackColorOffValue')?.value, 10);
                            currentSwitchData.back_color_off = (!isNaN(backOffVal) && backOffVal >= 0) ? backOffVal : 9;
                        } else {
                            currentSwitchData.icon_fx = 0;
                            currentSwitchData.icon_name = "";
                            if (sigla.length > 0 || userEdited) currentSwitchData.sigla_fx = sigla;
                            else currentSwitchData.sigla_fx = "";

                            // Also save color/fill for SIGLA
                            const iconColorVal = parseInt(document.getElementById('switchIconColorValue')?.value, 10);
                            currentSwitchData.icon_color = (!isNaN(iconColorVal) && iconColorVal >= 0) ? iconColorVal : 6;

                            const iconColorOffVal = parseInt(document.getElementById('switchIconColorOffValue')?.value, 10);
                            currentSwitchData.icon_color_off = (!isNaN(iconColorOffVal) && iconColorOffVal >= 0) ? iconColorOffVal : 6;

                            const borderOffVal = parseInt(document.getElementById('switchBorderColorOffValue')?.value, 10);
                            currentSwitchData.border_color_off = (!isNaN(borderOffVal) && borderOffVal >= 0) ? borderOffVal : 9;

                            // Border ON color
                            const borderOnVal = parseInt(document.getElementById('switchBorderColorOnValue')?.value, 10);
                            currentSwitchData.border_color_on = (!isNaN(borderOnVal) && borderOnVal >= 0) ? borderOnVal : 9;

                            const backOnVal = parseInt(document.getElementById('switchBackColorOnValue')?.value, 10);
                            currentSwitchData.back_color_on = (!isNaN(backOnVal) && backOnVal >= 0) ? backOnVal : 9;
                            const backOffVal = parseInt(document.getElementById('switchBackColorOffValue')?.value, 10);
                            currentSwitchData.back_color_off = (!isNaN(backOffVal) && backOffVal >= 0) ? backOffVal : 9;
                        }
                    } catch(_) {}

                    // SIGLA/ICON FX 2 (mutually exclusive) - save
                    try {
                        const fxMode2 = document.getElementById('fxModeToggle2')?.getAttribute('data-mode') || 'sigla';
                        const iconFx2ValueRaw = parseInt(document.getElementById('switchIconFx2Value')?.value, 10) || 0;
                        const iconFx2Value = (iconFx2ValueRaw >= 0 && iconFx2ValueRaw <= MAX_FX_ICON_ID) ? iconFx2ValueRaw : 0;

                        let sigla2El = document.getElementById('switchSiglaFx2');
                        const sigla2Dyn = document.getElementById('switchSiglaFx2_Dynamic');
                        if (sigla2Dyn && sigla2Dyn.offsetParent !== null) sigla2El = sigla2Dyn;
                        const sigla2Raw = (sigla2El?.value || '').toString().toUpperCase();
                        const sigla2 = sigla2Raw.substring(0, 3);
                        const userEdited2 = sigla2El && sigla2El.dataset.userEdited === '1';
                        const iconColor2Val = parseInt(document.getElementById('switchIconColor2Value')?.value, 10);
                        const iconColor2OffVal = parseInt(document.getElementById('switchIconColor2OffValue')?.value, 10);
                        const borderOff2Val = parseInt(document.getElementById('switchBorderColorOff2Value')?.value, 10);
                        const borderOn2Val = parseInt(document.getElementById('switchBorderColorOn2Value')?.value, 10);
                        const backOn2Val = parseInt(document.getElementById('switchBackColorOn2Value')?.value, 10);
                        const backOff2Val = parseInt(document.getElementById('switchBackColorOff2Value')?.value, 10);

                        if (fxMode2 === 'icon') {
                            currentSwitchData.icon_fx_2 = iconFx2Value;
                            currentSwitchData.sigla_fx_2 = "";
                            currentSwitchData.icon_color_2 = (!isNaN(iconColor2Val) && iconColor2Val >= 0) ? iconColor2Val : 6;
                            currentSwitchData.icon_color_off_2 = (!isNaN(iconColor2OffVal) && iconColor2OffVal >= 0) ? iconColor2OffVal : 6;
                            currentSwitchData.border_color_off_2 = (!isNaN(borderOff2Val) && borderOff2Val >= 0) ? borderOff2Val : 9;
                            currentSwitchData.border_color_on_2 = (!isNaN(borderOn2Val) && borderOn2Val >= 0) ? borderOn2Val : 9;
                            currentSwitchData.back_color_on_2 = (!isNaN(backOn2Val) && backOn2Val >= 0) ? backOn2Val : 9;
                            currentSwitchData.back_color_off_2 = (!isNaN(backOff2Val) && backOff2Val >= 0) ? backOff2Val : 9;
                        } else {
                            currentSwitchData.icon_fx_2 = 0;
                            if (sigla2.length > 0 || userEdited2) currentSwitchData.sigla_fx_2 = sigla2;
                            else currentSwitchData.sigla_fx_2 = "";

                            // Also save color/fill for SIGLA 2
                            currentSwitchData.icon_color_2 = (!isNaN(iconColor2Val) && iconColor2Val >= 0) ? iconColor2Val : 6;
                            currentSwitchData.icon_color_off_2 = (!isNaN(iconColor2OffVal) && iconColor2OffVal >= 0) ? iconColor2OffVal : 6;
                            currentSwitchData.border_color_off_2 = (!isNaN(borderOff2Val) && borderOff2Val >= 0) ? borderOff2Val : 9;
                            currentSwitchData.border_color_on_2 = (!isNaN(borderOn2Val) && borderOn2Val >= 0) ? borderOn2Val : 9;
                            currentSwitchData.back_color_on_2 = (!isNaN(backOn2Val) && backOn2Val >= 0) ? backOn2Val : 9;
                            currentSwitchData.back_color_off_2 = (!isNaN(backOff2Val) && backOff2Val >= 0) ? backOff2Val : 9;
                        }
                    } catch(_) {}

                    // Update ramp config (rampa unificado)
                    try {
                        const swId = currentSwitchIndex + 1;
                        const upEl = document.getElementById(`rampUp_sw${swId}`);
                        const dnEl = document.getElementById(`rampDown_sw${swId}`);
                        const invEl = document.getElementById(`rampInvert_sw${swId}`);
                        const autoEl = document.getElementById(`rampAuto_sw${swId}`);
                        if (upEl && dnEl) {
                            if (!presetToUpdate.rampTimes) presetToUpdate.rampTimes = { sw1: 1000, sw2: 1000, sw3: 1000, sw4: 1000, sw5: 1000, sw6: 1000 };
                            // base time mantem compat: usa tempo de subida
                            presetToUpdate.rampTimes[`sw${swId}`] = (Number.isNaN(parseInt(upEl.value, 10)) ? 1000 : parseInt(upEl.value, 10));
                            currentSwitchData.rampUp = (Number.isNaN(parseInt(upEl.value, 10)) ? 1000 : parseInt(upEl.value, 10));
                            currentSwitchData.rampDown = (Number.isNaN(parseInt(dnEl.value, 10)) ? 1000 : parseInt(dnEl.value, 10));
                            if (invEl) currentSwitchData.rampInvert = !!invEl.checked;
                            if (autoEl) currentSwitchData.rampAutoStop = !!autoEl.checked;
                        } else if (upEl && !dnEl) {
                            // Modo STOMP RAMPA (29): salva apenas SUBIDA
                            if (!presetToUpdate.rampTimes) presetToUpdate.rampTimes = { sw1: 1000, sw2: 1000, sw3: 1000, sw4: 1000, sw5: 1000, sw6: 1000 };
                            const vUp = Number.isNaN(parseInt(upEl.value, 10)) ? 1000 : parseInt(upEl.value, 10);
                            presetToUpdate.rampTimes[`sw${swId}`] = vUp;
                            currentSwitchData.rampUp = vUp;
                        }
                    } catch(_) {}

                    const isDualStomp = (currentSwitchData.modo === 28 || currentSwitchData.modo === 50);
                    const isTapTempo = (currentSwitchData.modo === 18);
                    if (isDualStomp || isTapTempo) {
                        const cc2El = document.getElementById('switchCC2');
                        if (cc2El) {
                            currentSwitchData.cc2 = parseInt(cc2El.value, 10) || 0;
                        }
                        const cc2ChEl = document.getElementById('switchChannelCC2');
                        if (cc2ChEl) {
                            const chVal = parseInt(cc2ChEl.value, 10);
                            currentSwitchData.canal_cc2 = (!isNaN(chVal) && chVal >= 0 && chVal <= 16) ? chVal : 1;
                        } else if (currentSwitchData.canal_cc2 === undefined) {
                            currentSwitchData.canal_cc2 = 1;
                        }
                        currentSwitchData.cc2_ch = currentSwitchData.canal_cc2;
                        if (currentSwitchData.modo === 28 || currentSwitchData.modo === 18) {
                            const cc2StartEl = document.getElementById('switchCC2Start');
                            currentSwitchData.start_value_cc2 = !!(cc2StartEl && cc2StartEl.checked);
                        } else { // modo === 50
                            const autoRampEl = document.getElementById('autoRampToggle');
                            if (autoRampEl) { currentSwitchData.autoRamp = !!autoRampEl.checked; }
                        }
                        const led2El = document.getElementById('switchLed2ColorValue');
                        if (led2El) {
                            currentSwitchData.led2 = parseInt(led2El.value, 10) || 0;
                        }
                        if (isDualStomp) {
                            // DUAL STOMP custom values - already collected by STOMP DUAL toggle handler above
                            // Only re-collect if ds_custom_enabled was not already set (legacy fallback)
                            if (currentSwitchData.ds_custom_enabled === undefined) {
                                currentSwitchData.ds_custom_enabled = false;
                            }
                        }
                    }
                    // TAP TEMPO: capturar TAP2/TAP3
                    if (currentSwitchData.modo === 18) {
                        const t2cc = parseInt(document.getElementById("tap2_cc")?.value, 10);
                        const t2ch = parseInt(document.getElementById("tap2_ch")?.value, 10);
                        const t3cc = parseInt(document.getElementById("tap3_cc")?.value, 10);
                        const t3ch = parseInt(document.getElementById("tap3_ch")?.value, 10);
                        currentSwitchData.tap2_cc = isNaN(t2cc) ? 0 : t2cc;
                        currentSwitchData.tap2_ch = isNaN(t2ch) ? 0 : t2ch;
                        currentSwitchData.tap3_cc = isNaN(t3cc) ? 0 : t3cc;
                        currentSwitchData.tap3_ch = isNaN(t3ch) ? 0 : t3ch;
                        const tapM2Btn = document.getElementById("tapMode2Btn");
                        currentSwitchData.tap_mode2 = tapM2Btn ? tapM2Btn.classList.contains('rect-toggle-fx-on') : false;
                    }
                    if ((currentSwitchData.modo >= 35 && currentSwitchData.modo <= 37) || (currentSwitchData.modo >= 44 && currentSwitchData.modo <= 46)) {
                        // SPIN HOLD: CUSTOM values
                        const spinCustomEl = document.getElementById('spinCustomEnabled');
                        currentSwitchData.stomp_custom = !!(spinCustomEl && spinCustomEl.checked);
                        if (currentSwitchData.stomp_custom) {
                            currentSwitchData.stomp_val_on = parseInt(document.getElementById('spinValOn')?.value, 10);
                            if (isNaN(currentSwitchData.stomp_val_on)) currentSwitchData.stomp_val_on = 127;
                            currentSwitchData.stomp_val_off = parseInt(document.getElementById('spinValOff')?.value, 10);
                            if (isNaN(currentSwitchData.stomp_val_off)) currentSwitchData.stomp_val_off = 0;
                        } else {
                            currentSwitchData.stomp_custom = false;
                        }
                        const holdEnabledEl = document.getElementById('spinHoldEnabledToggle');
                        const holdEnabled = holdEnabledEl ? !!holdEnabledEl.checked : (currentSwitchData.start_value_cc2 !== true);
                        // Reaproveita start_value_cc2 como flag do SPIN HOLD:
                        // false = HOLD ON, true = HOLD OFF
                        currentSwitchData.start_value_cc2 = !holdEnabled;
                        if (holdEnabled) {
                            const ccHoldVal = parseInt(document.getElementById('switchCCHold')?.value, 10);
                            // Aceita CC normal (0-127) ou CC especial Kemper (200-321)
                            if (!isNaN(ccHoldVal) && ((ccHoldVal >= 0 && ccHoldVal <= 127) || (ccHoldVal >= 200 && ccHoldVal <= 321))) {
                                currentSwitchData.cc_hold = ccHoldVal;
                            } else {
                                currentSwitchData.cc_hold = 0;
                            }
                            const ccHoldStartEl = document.getElementById('switchCCHoldStart');
                            currentSwitchData.start_value = !!(ccHoldStartEl && ccHoldStartEl.checked);

                            // Save HOLD color index (if the UI exists)
                            const holdIdxVal = parseInt(document.getElementById('switchHoldColorValue')?.value, 10);
                            if (!isNaN(holdIdxVal) && holdIdxVal >= 0) {
                                currentSwitchData.led_hold = holdIdxVal;
                            } else {
                                currentSwitchData.led_hold = currentSwitchData.led_hold || 6;
                            }
                        } else {
                            // HOLD OFF: forca estado OFF no bloco secundario
                            currentSwitchData.start_value = false;
                        }
                    }

                    if (currentSwitchData.modo === 53) { // MACROS
                        if (!currentSwitchData.macros) currentSwitchData.macros = [];
                        for (let i = 0; i < 4; i++) {
                            const cc = parseInt(document.getElementById(`macro_cc_${currentSwitchIndex}_${i}`)?.value, 10) || 0;
                            const chRaw = parseInt(document.getElementById(`macro_ch_${currentSwitchIndex}_${i}`)?.value, 10);
                            const ch = (!isNaN(chRaw) && chRaw >= 0 && chRaw <= 16) ? chRaw : 1;
                            const off = parseInt(document.getElementById(`macro_off_${currentSwitchIndex}_${i}`)?.value, 10) || 0;
                            const on = parseInt(document.getElementById(`macro_on_${currentSwitchIndex}_${i}`)?.value, 10) || 127;
                            
                            currentSwitchData.macros[i] = { cc: cc, valueOff: off, valueOn: on, channel: ch };
                        }
                    }
                    
                }

                if (presetToUpdate.extras) {
                    presetToUpdate.extras.enviar_extras = document.getElementById('extrasSendToggle')?.checked || false;
                    const currentModeValue = modeValue;

                    if (!presetToUpdate.extras.custom || !Array.isArray(presetToUpdate.extras.custom)) {
                        presetToUpdate.extras.custom = getDefaultExtrasData().custom;
                    } else if (presetToUpdate.extras.custom.length < 6) {
                        const defaultCustomBase = getDefaultExtrasData().custom;
                        for (let i = presetToUpdate.extras.custom.length; i < 6; i++) {
                            presetToUpdate.extras.custom.push(JSON.parse(JSON.stringify(defaultCustomBase[i]))); 
                        }
                    }
                    if (!presetToUpdate.extras.spin || !Array.isArray(presetToUpdate.extras.spin)) {
                        presetToUpdate.extras.spin = getDefaultExtrasData().spin;
                    } else if (presetToUpdate.extras.spin.length < 6) {
                        const defaultSpinBase = getDefaultExtrasData().spin;
                        for (let i = presetToUpdate.extras.spin.length; i < 6; i++) {
                            presetToUpdate.extras.spin.push(JSON.parse(JSON.stringify(defaultSpinBase[i])));
                        }
                    }
                    if (!presetToUpdate.extras.control || !Array.isArray(presetToUpdate.extras.control)) {
                        presetToUpdate.extras.control = getDefaultExtrasData().control;
                    } else if (presetToUpdate.extras.control.length < 6) {
                        const defaultControlBase = getDefaultExtrasData().control;
                        for (let i = presetToUpdate.extras.control.length; i < 6; i++) {
                            presetToUpdate.extras.control.push(JSON.parse(JSON.stringify(defaultControlBase[i])));
                        }
                    }

                    const isSpin = (currentModeValue >= 1 && currentModeValue <= 3) || (currentModeValue >= 38 && currentModeValue <= 43);
                    const isSpinHold = (currentModeValue >= 35 && currentModeValue <= 37) || (currentModeValue >= 44 && currentModeValue <= 46);

                    if (isSpin || isSpinHold) {
                        let spinIndex;
                        if (currentModeValue >= 1 && currentModeValue <= 3) spinIndex = currentModeValue - 1;
                        else if (currentModeValue >= 35 && currentModeValue <= 37) spinIndex = currentModeValue - 35;
                        else if (currentModeValue >= 38 && currentModeValue <= 40) spinIndex = currentModeValue - 38 + 3;
                        else if (currentModeValue >= 41 && currentModeValue <= 43) spinIndex = currentModeValue - 41 + 3;
                        else if (currentModeValue >= 44 && currentModeValue <= 46) spinIndex = currentModeValue - 44 + 3;

                        if (presetToUpdate.extras.spin && spinIndex >= 0 && spinIndex < presetToUpdate.extras.spin.length) {
                            presetToUpdate.extras.spin[spinIndex].v1 = parseInt(document.getElementById(`spinV1_${spinIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.spin[spinIndex].v2 = parseInt(document.getElementById(`spinV2_${spinIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.spin[spinIndex].v3 = parseInt(document.getElementById(`spinV3_${spinIndex}`)?.value, 10) || 0;
                            updateSpinKnobVisual(`spinV1_${spinIndex}`); updateSpinKnobVisual(`spinV2_${spinIndex}`); updateSpinKnobVisual(`spinV3_${spinIndex}`);
                            // Multi-CC fields
                            const spinCountBtn = document.getElementById(`spinCountBtn_${spinIndex}`);
                            const spinCountStates = ['SINGLE','DUPLO','TRIPLO'];
                            const scText = spinCountBtn ? spinCountBtn.textContent.trim() : 'SINGLE';
                            presetToUpdate.extras.spin[spinIndex].spin_count = (spinCountStates.indexOf(scText) + 1) || 1;
                            presetToUpdate.extras.spin[spinIndex].cc2 = parseInt(document.getElementById(`spinCC2_${spinIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.spin[spinIndex].v1cc2 = parseInt(document.getElementById(`spinV1cc2_${spinIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.spin[spinIndex].v2cc2 = parseInt(document.getElementById(`spinV2cc2_${spinIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.spin[spinIndex].v3cc2 = parseInt(document.getElementById(`spinV3cc2_${spinIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.spin[spinIndex].cc3 = parseInt(document.getElementById(`spinCC3_${spinIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.spin[spinIndex].v1cc3 = parseInt(document.getElementById(`spinV1cc3_${spinIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.spin[spinIndex].v2cc3 = parseInt(document.getElementById(`spinV2cc3_${spinIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.spin[spinIndex].v3cc3 = parseInt(document.getElementById(`spinV3cc3_${spinIndex}`)?.value, 10) || 0;
                        }
                    } else if ((currentModeValue >= 7 && currentModeValue <= 9) || (currentModeValue >= 47 && currentModeValue <= 49)) { 
                        const controlIndex = (currentModeValue >= 47) ? (currentModeValue - 47 + 3) : (currentModeValue - 7);
                        if (presetToUpdate.extras.control && controlIndex >= 0 && controlIndex < presetToUpdate.extras.control.length) {
                            presetToUpdate.extras.control[controlIndex].cc = parseInt(document.getElementById(`controlCC_${controlIndex}`)?.value, 10) || 0;
                            presetToUpdate.extras.control[controlIndex].modo_invertido = document.getElementById(`controlInvertToggle_${controlIndex}`)?.checked || false;
                        }
                    } else if ((currentModeValue >= 10 && currentModeValue <= 15)) { 
                        const customIndex = currentModeValue - 10;
                        if (presetToUpdate.extras.custom && customIndex >= 0 && customIndex < presetToUpdate.extras.custom.length) {
                            const legacyOnId = `customOn_${customIndex}`;
                            const indexedOnId = `customOn_${currentSwitchIndex}_${customIndex}`;
                            const onValElement = document.getElementById(indexedOnId) || document.getElementById(legacyOnId);
                            if (onValElement) {
                                const onVal = parseInt(onValElement.value, 10);
                                presetToUpdate.extras.custom[customIndex].valor_on = !isNaN(onVal) ? onVal : 127;
                                const onIdToUpdate = document.getElementById(indexedOnId) ? indexedOnId : legacyOnId;
                                updateSpinKnobVisual(onIdToUpdate);
                            }

                            const legacyOffId = `customOff_${customIndex}`;
                            const indexedOffId = `customOff_${currentSwitchIndex}_${customIndex}`;
                            const offValElement = document.getElementById(indexedOffId) || document.getElementById(legacyOffId);
                            if (offValElement) { 
                                const offVal = parseInt(offValElement.value, 10);
                                presetToUpdate.extras.custom[customIndex].valor_off = !isNaN(offVal) ? offVal : 0;
                                const offIdToUpdate = document.getElementById(indexedOffId) ? indexedOffId : legacyOffId;
                                updateSpinKnobVisual(offIdToUpdate);
                            }

                            // Sempre atualizar CC e Canal exibidos na UI de CUSTOM
                            const ccElement = document.getElementById(`customCC_${currentSwitchIndex}_${customIndex}`);
                            if (ccElement) {
                                const ccVal = parseInt(ccElement.value, 10);
                                presetToUpdate.extras.custom[customIndex].cc = !isNaN(ccVal) ? ccVal : (presetToUpdate.extras.custom[customIndex].cc || 0);
                            }
                            const channelElement = document.getElementById(`customChannel_${currentSwitchIndex}_${customIndex}`);
                            if (channelElement) {
                                const chVal = parseInt(channelElement.value, 10);
                                presetToUpdate.extras.custom[customIndex].canal = (!isNaN(chVal) && chVal >= 0 && chVal <= 16) ? chVal : (presetToUpdate.extras.custom[customIndex].canal ?? 1);
                            }
                        }
                    }

                    // PC EXTRAS - salvar independentemente do modo do switch
                    if (presetToUpdate.extras.pc && Array.isArray(presetToUpdate.extras.pc)) {
                        presetToUpdate.extras.pc.forEach((item, i) => {
                            const pcValEl = document.getElementById(`pcValue_${i}`);
                            const pcChEl = document.getElementById(`pcChannel_${i}`);
                            if (pcValEl) item.valor = parseInt(pcValEl.value, 10) || 0;
                            if (pcChEl) {
                                const chVal = parseInt(pcChEl.value, 10);
                                item.canal = (!isNaN(chVal) && chVal >= 0 && chVal <= 16) ? chVal : 1;
                            }
                        });
                    }

                    // CC EXTRAS - salvar independentemente do modo do switch
                    if (!presetToUpdate.extras.cc || !Array.isArray(presetToUpdate.extras.cc)) {
                        presetToUpdate.extras.cc = getDefaultExtrasData().cc;
                    } else if (presetToUpdate.extras.cc.length < 2) {
                        const defaultCC = getDefaultExtrasData().cc;
                        for (let i = presetToUpdate.extras.cc.length; i < 2; i++) {
                            presetToUpdate.extras.cc.push(JSON.parse(JSON.stringify(defaultCC[i])));
                        }
                    }
                    for (let i = 0; i < 2; i++) {
                        const ccNumEl = document.getElementById(`ccNum_${i}`);
                        const ccValEl = document.getElementById(`ccVal_${i}`);
                        const ccChEl  = document.getElementById(`ccChannel_${i}`);
                        if (ccNumEl) presetToUpdate.extras.cc[i].cc = parseInt(ccNumEl.value, 10) || 0;
                        if (ccValEl) presetToUpdate.extras.cc[i].valor = parseInt(ccValEl.value, 10) || 0;
                        if (ccChEl) {
                            const chVal = parseInt(ccChEl.value, 10);
                            presetToUpdate.extras.cc[i].canal = (!isNaN(chVal) && chVal >= 0 && chVal <= 16) ? chVal : 1;
                        }
                    }
                }

                // Atualizar preview dos foot buttons após mudanças no modelo
                try {
                    if (typeof updateAllFootButtonsUI === 'function') {
                        updateAllFootButtonsUI();
                    }
                } catch (_) {}

                // Qualquer alteracao de parametro deve persistir automaticamente.
                if (!suppressPresetAutoSave && presetAutoSaveEnabled) {
                    schedulePresetAutoSave();
                }
            }

            function showCopyPasteBanner(message) {
                const bannerId = 'copyPasteBanner';
                let banner = document.getElementById(bannerId);
                if (!banner) {
                    banner = document.createElement('div');
                    banner.id = bannerId;
                    banner.className = 'save-banner';
                    banner.setAttribute('aria-hidden', 'true');
                    document.body.appendChild(banner);
                }
                banner.textContent = message;
                if (message === 'COPIADO') {
                    banner.style.backgroundColor = '#3498db';
                } else if (message === 'COLADO') {
                    banner.style.backgroundColor = '#2ecc71';
                }
                banner.classList.add('show');
                banner.setAttribute('aria-hidden', 'false');
                banner.style.display = 'block';
                setTimeout(() => {
                    banner.classList.remove('show');
                    banner.setAttribute('aria-hidden', 'true');
                    setTimeout(() => { banner.style.display = 'none'; }, 150);
                }, 500);
            }

            function showSavedBanner() {
                const bannerId = 'saveBanner';
                let banner = document.getElementById(bannerId);
                if (!banner) {
                    banner = document.createElement('div');
                    banner.id = bannerId;
                    banner.className = 'save-banner';
                    banner.setAttribute('aria-hidden', 'true');
                    banner.textContent = 'SALVO!';
                    document.body.appendChild(banner);
                }
                banner.classList.add('show');
                banner.setAttribute('aria-hidden', 'false');
                banner.style.display = 'block';
                setTimeout(() => {
                    banner.classList.remove('show');
                    banner.setAttribute('aria-hidden', 'true');
                    setTimeout(() => { banner.style.display = 'none'; }, 150);
                }, 500);
            }

            function schedulePresetAutoSave(delayMs = 550) {
                return;
            }

            function isPresetAutoSaveEnabled() {
                return !!presetAutoSaveEnabled;
            }

            function setPresetAutoSaveEnabled(enabled) {
                presetAutoSaveEnabled = !!enabled;
                if (!presetAutoSaveEnabled && presetAutoSaveTimer) {
                    clearTimeout(presetAutoSaveTimer);
                    presetAutoSaveTimer = null;
                }
            }
            window.isPresetAutoSaveEnabled = isPresetAutoSaveEnabled;
            window.setPresetAutoSaveEnabled = setPresetAutoSaveEnabled;

            async function saveCurrentPresetData(options = {}) {
                const silent = !!options.silent;
                const force = !!options.force;
                const col = currentPresetColumnIndex;
                const row = currentPresetRowIndex;
                const globalIndex = col * NUM_PRESET_ROWS + row;
                const statusMessage = document.getElementById('statusMessage');

                if (window.isPresetLoadInProgress) return;

                if (presetSaveInFlight) {
                    presetSaveQueued = true;
                    return;
                }

                // Forcar captura dos dados da UI ignorando suppressModelUpdate
                const prevSuppress = suppressModelUpdate;
                suppressPresetAutoSave = true;
                try {
                    suppressModelUpdate = false;
                    updateLocalPresetDataFromUI();
                } finally {
                    suppressModelUpdate = prevSuppress;
                    suppressPresetAutoSave = false;
                }

                const layersToSave = [];
                const maxLayerToSave = liveLayer2Enabled ? TOTAL_LIVE_LAYERS : 1;
                for (let layerToSave = 1; layerToSave <= maxLayerToSave; layerToSave++) {
                    const layerIdx = layerToSave - 1;
                    const presetDataToSave = allPresetsData[layerIdx]?.[globalIndex];
                    if (!presetDataToSave) continue;

                    try {
                        if (presetDataToSave?.extras?.combo) delete presetDataToSave.extras.combo;
                        if (Array.isArray(presetDataToSave?.switches)) {
                            presetDataToSave.switches.forEach(sw => {
                                if (!sw) return;
                                if (typeof sw.comboCount !== 'undefined') delete sw.comboCount;
                                if (typeof sw.modo === 'number' && sw.modo >= 30 && sw.modo <= 34) sw.modo = 0;
                            });
                        }
                    } catch (_) {}

                    const payload = JSON.stringify(presetDataToSave);
                    const saveKey = `${layerToSave}:${globalIndex}`;
                    if (!force && lastSavedPresetPayloadByKey[saveKey] === payload) {
                        continue;
                    }
                    layersToSave.push({ layerToSave, payload, saveKey });
                }

                if (layersToSave.length === 0) {
                    return;
                }

                presetSaveInFlight = true;
                if (statusMessage && !silent) {
                    statusMessage.textContent = `Salvando preset ${String.fromCharCode(65 + row)}${col + 1}...`;
                    statusMessage.style.color = 'orange';
                }

                try {
                    for (const { layerToSave, payload, saveKey } of layersToSave) {
                        const response = await apiFetch(`/save-single-preset-data?btn=${col}&lvl=${row}&layer=${layerToSave}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: payload
                        });
                        if (!response.ok && response.status !== 202) {
                            throw new Error(`Falha (${response.status}): ${await response.text()}`);
                        }
                        lastSavedPresetPayloadByKey[saveKey] = payload;
                    }

                    if (statusMessage && !silent) {
                        statusMessage.textContent = 'Dados gravados!';
                        statusMessage.style.color = 'green';
                    }
                    setTimeout(() => {
                        try { showSavedBanner(); } catch (_) {}
                    }, 100);

                    // Atualiza display no dispositivo sem enviar MIDI (apenas nome/tela)
                    try {
                        await new Promise(r => setTimeout(r, 300));
                        await apiFetch(`/refresh-display-only?btn=${col}&lvl=${row}&layer=${currentLiveLayer}`);
                    } catch (e) {
                        console.warn('Falha ao atualizar display (sem MIDI):', e);
                    }

                    // Atualizar TODOS os 12 botoes visuais (ambos os layers)
                    updateAllFootButtonsUI();
                } catch (error) {
                    if (statusMessage) {
                        statusMessage.textContent = 'Erro: ' + error.message;
                        statusMessage.style.color = 'red';
                    }
                } finally {
                    presetSaveInFlight = false;
                    if (presetSaveQueued) {
                        presetSaveQueued = false;
                        saveCurrentPresetData({ silent: true });
                    }
                }
            }
            const UI_MAX_FX_ICON_ID = 51;
            const ICON_OPTIONS = [
                { value: 0, text: "Nenhum (Texto)" },
                ...Array.from({ length: UI_MAX_FX_ICON_ID }, (_, i) => ({ value: i + 1, text: "ICO" + (i + 1) }))
            ];

            function populateIconSelects() {
                const selects = [document.getElementById('switchIconFx'), document.getElementById('switchIconFx2')];
                selects.forEach(sel => {
                    if (sel) {
                        const currentRaw = parseInt(sel.value, 10) || 0;
                        const current = (currentRaw >= 0 && currentRaw <= UI_MAX_FX_ICON_ID) ? String(currentRaw) : '0';
                        const savedOptions = Array.from(sel.options).map(o => o.value);
                        const expectedValues = ICON_OPTIONS.map(o => String(o.value));
                        const alreadyPopulated = savedOptions.length === expectedValues.length &&
                            savedOptions.every((value, idx) => value === expectedValues[idx]);
                        if (alreadyPopulated) return;
                        
                        sel.innerHTML = '';
                        ICON_OPTIONS.forEach(opt => {
                            const el = document.createElement('option');
                            el.value = opt.value;
                            el.textContent = opt.text;
                            sel.appendChild(el);
                        });
                        if (current) sel.value = current;
                        updateCustomSelect(sel.id);
                    }
                });
            }

            // Call on init
            document.addEventListener('DOMContentLoaded', populateIconSelects);


function setupEventListeners() {
                    // navigation / save
                    document.getElementById('btnNavPreset')?.addEventListener('click', () => { window.location.href = '/preset-config'; });
                    document.getElementById('btnNavGlobal')?.addEventListener('click', () => { window.location.href = '/global-config'; });
                    document.getElementById('btnNavSystem')?.addEventListener('click', () => { window.location.href = '/system'; });

                    document.getElementById('btnSalvarFooter')?.addEventListener('click', () => {
                        try { saveCurrentPresetData({ silent: false, force: true }); } catch (_) {}
                    });

                    // NEW GRID SELECTOR LOGIC
                    try {
                         const updateGridVisuals = () => {
                             document.querySelectorAll('#presetRowSelector .grid-btn-selector').forEach(b => {
                                 if (parseInt(b.dataset.row,10) === currentPresetRowIndex) b.classList.add('active');
                                 else b.classList.remove('active');
                             });
                             document.querySelectorAll('#presetColSelector .grid-btn-selector').forEach(b => {
                                 if (parseInt(b.dataset.col,10) === currentPresetColumnIndex) b.classList.add('active');
                                 else b.classList.remove('active');
                             });
                         };
                         // Init visuals
                         setTimeout(updateGridVisuals, 100);

                         // Rows
                         document.querySelectorAll('#presetRowSelector .grid-btn-selector').forEach(btn => {
                            btn.addEventListener('click', async () => {
                                const row = parseInt(btn.dataset.row, 10);
                                if (row === currentPresetRowIndex) return;
                                const now = Date.now();
                                if (window.presetNavLastTs && now - window.presetNavLastTs < 250) return;
                                if (window.isPresetLoadInProgress) return;
                                window.presetNavLastTs = now;
                                suppressModelUpdate = true;
                                currentPresetRowIndex = row;
                                currentSwitchIndex = -1;
                                updateGridVisuals();
                                await fetchAndLoadSinglePreset(currentPresetColumnIndex, currentPresetRowIndex, true);
                                suppressModelUpdate = false;
                            });
                         });
                         // Cols
                         document.querySelectorAll('#presetColSelector .grid-btn-selector').forEach(btn => {
                            btn.addEventListener('click', async () => {
                                const col = parseInt(btn.dataset.col, 10);
                                if (col === currentPresetColumnIndex) return;
                                const now = Date.now();
                                if (window.presetNavLastTs && now - window.presetNavLastTs < 250) return;
                                if (window.isPresetLoadInProgress) return;
                                window.presetNavLastTs = now;
                                suppressModelUpdate = true;
                                currentPresetColumnIndex = col;
                                currentSwitchIndex = -1;
                                updateGridVisuals();
                                await fetchAndLoadSinglePreset(currentPresetColumnIndex, currentPresetRowIndex, true);
                                suppressModelUpdate = false;
                            });
                         });
                    } catch(e) { console.warn('Grid setup error', e); }
    
                    // Ensure paste button state if clipboard already persisted in localStorage
                    try {
                        const stored = localStorage.getItem('bfmidiPresetClipboard');
                        if (stored) {
                            try { presetClipboard = JSON.parse(stored); } catch (_) { presetClipboard = stored; }
                            document.getElementById('btnColar').disabled = false;
                        }
                    } catch (_) {}
    
                    // BANK ROW (A..E) selector: advance row and reload preset
                    try {
                        const btnRow = document.getElementById('btnRowSelector');
                        const rowLabel = document.getElementById('rowLabel');
                        if (btnRow && rowLabel) {
                            btnRow.addEventListener('click', async () => {
                                const now = Date.now();
                                if (window.presetNavLastTs && now - window.presetNavLastTs < 250) return;
                                if (window.isPresetLoadInProgress) return;
                                window.presetNavLastTs = now;
                                suppressModelUpdate = true; // Bloqueia updateLocalPresetDataFromUI durante troca
                                currentPresetRowIndex = (currentPresetRowIndex + 1) % NUM_PRESET_ROWS; // 0..4
                                const rowChar = String.fromCharCode(65 + currentPresetRowIndex); // A..E
                                rowLabel.textContent = rowChar;
                                // Desseleciona switch ao trocar de preset
                                currentSwitchIndex = -1;
                                // reload current preset (column,row) and update UI
                                await fetchAndLoadSinglePreset(currentPresetColumnIndex, currentPresetRowIndex, true);
                                suppressModelUpdate = false;
                            });
                        }
                    } catch (_) {}

                    // PRESET SLOT (1..6) selector: advance column and reload preset
                    try {
                        const btnCol = document.getElementById('btnColSelector');
                        const colLabel = document.getElementById('colLabel');
                        if (btnCol && colLabel) {
                            btnCol.addEventListener('click', async () => {
                                const now = Date.now();
                                if (window.presetNavLastTs && now - window.presetNavLastTs < 250) return;
                                if (window.isPresetLoadInProgress) return;
                                window.presetNavLastTs = now;
                                suppressModelUpdate = true; // Bloqueia updateLocalPresetDataFromUI durante troca
                                currentPresetColumnIndex = (currentPresetColumnIndex + 1) % NUM_PRESET_COLUMNS; // 0..5
                                colLabel.textContent = String(currentPresetColumnIndex + 1); // 1..6
                                // Desseleciona switch ao trocar de preset
                                currentSwitchIndex = -1;
                                // reload current preset (column,row) and update UI
                                await fetchAndLoadSinglePreset(currentPresetColumnIndex, currentPresetRowIndex, true);
                                suppressModelUpdate = false;
                            });
                        }
                    } catch (_) {}

                    // LIVE layer toggle REMOVIDO - agora exibimos ambos os layers simultaneamente
                    /*
                    try {
                        const layerBtn = document.getElementById('liveLayerToggleButton');
                        if (layerBtn) {
                            layerBtn.addEventListener('click', async () => {
                                // Garante que o layer atual esteja salvo no modelo local
                                try { updateLocalPresetDataFromUI(); } catch (_) {}

                                currentLiveLayer = (currentLiveLayer === 1 ? 2 : 1);
                                layerBtn.textContent = `Layer ${currentLiveLayer}`;

                                const col = currentPresetColumnIndex;
                                const row = currentPresetRowIndex;
                                const globalIndex = col * NUM_PRESET_ROWS + row;
                                const layerIdx = currentLiveLayer - 1;

                                // Se ainda não carregamos esse preset/layer do ESP, usa o fluxo padrão
                                try {
                                    const alreadyLoaded =
                                        presetsLoadedFromServer[layerIdx] &&
                                        presetsLoadedFromServer[layerIdx][globalIndex];

                                                    if (!alreadyLoaded) {
                                                        await fetchAndLoadSinglePreset(col, row, true);
                                                        return; // fetchAndLoadSinglePreset já atualiza toda a UI
                                                    }                                } catch (e) {
                                    console.warn('Falha ao recarregar preset ao trocar de layer:', e);
                                }

                                // Caso já exista em memória (ou em fallback), atualiza a UI a partir do modelo local
                                const layerPresets = allPresetsData[layerIdx] || [];
                                const presetData = layerPresets[globalIndex] || getSingleDefaultPresetData(col, row);

                                updateAllFootButtonsUI();
                                loadPresetDataToUI(col, row);
                                loadSwitchDataToUI(col, row, currentSwitchIndex);

                                const pcCcGrid = document.getElementById('extrasPcCcSection')?.querySelector('.extras-grid');
                                if (pcCcGrid && presetData.extras?.pc) {
                                    generatePcCcFields(pcCcGrid, presetData.extras);
                                }

                                updateLiveLayerButtonColorFromCurrentSwitch();

                                initCustomSelects();

                                // Atualiza somente display/LEDs no ESP para refletir o novo layer ativo
                                try {
                                    await apiFetch(`/refresh-display-only?btn=${col}&lvl=${row}&layer=${currentLiveLayer}`);
                                } catch (e) {
                                    console.warn('Falha ao atualizar display ao trocar de layer:', e);
                                }
                            });
                        }
                    } catch (_) {}
                    */
    
                    // other interactive listeners (originally present)
                    document.getElementById('presetNameFontBtn')?.addEventListener('click', () => {
                        const hidden = document.getElementById('presetNameFontValue');
                        const current = (parseInt(hidden?.value || '2', 10) === 1) ? 1 : 2;
                        const next = current === 1 ? 2 : 1;
                        syncPresetNameFontButton(next);
                        updateLocalPresetDataFromUI();
                        try { schedulePresetAutoSave(); } catch(_) {}
                    });
                    document.getElementById('presetNameInput')?.addEventListener('input', () => {
                        presetNameIsAutoManaged = false;
                        updateLocalPresetDataFromUI();
                    });
                    document.getElementById('presetBankInput')?.addEventListener('change', updateLocalPresetDataFromUI);
                    document.getElementById('presetChannelInput')?.addEventListener('change', () => {
                        // Em MODO AVANCADO, repopula bank/PC labels quando o canal do preset muda
                        try { repopulateBankForChannel(); } catch(_) {}
                        updateLocalPresetDataFromUI();
                    });
    
                    // (handler original de change do switchMode removido para evitar comportamentos concorrentes)

                    document.getElementById('switchMode')?.addEventListener('change', async () => {
                        try { suppressModelUpdate = true; } catch(_) {}
                        // Determina o modo escolhido e atualiza o modelo local antes de recarregar
                        let modeValue;
                        try {
                            const sel0 = document.getElementById('switchMode');
                            if (sel0.value === 'custom_placeholder') modeValue = 10 + currentSwitchIndex;
                            else modeValue = parseInt(sel0.value, 10) || 0;
                        } catch(_) { modeValue = 0; }
                        try {
                            const gi = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                            const layerIdx = currentLiveLayer - 1;
                            const layerPresets = allPresetsData[layerIdx] || [];
                            if (layerPresets[gi] && layerPresets[gi].switches[currentSwitchIndex]) {
                                layerPresets[gi].switches[currentSwitchIndex].modo = modeValue;
                            }
                        } catch(_) {}
                        // Recarrega os dados do preset do servidor (extras/switches) (REMOVIDO: causa reset do modo antes de salvar)
                        // try { await fetchAndLoadSinglePreset(currentPresetColumnIndex, currentPresetRowIndex, false); } catch(_) {}
                        try {
                            const sel = document.getElementById('switchMode');
                            if (sel) {
                                sel.value = (modeValue >= 10 && modeValue <= 15) ? 'custom_placeholder'
                                          : String(modeValue);
                                updateCustomSelect('switchMode');
                            }
                            updateSwitchSpecificUI(modeValue.toString(), currentSwitchIndex);
                            initCustomSelects();
                            const globalIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                            applySwitchCommonFieldsFromMemory(modeValue, globalIndex);
                            
                            // Atualiza os botoes de foot para refletir a mudanca (ex: label do modo)
                            updateAllFootButtonsUI();
                        } catch(_) {}
                        try { suppressModelUpdate = false; } catch(_) {}
                        try { schedulePresetAutoSave(); } catch(_) {}
                    });
    
        document.getElementById('switchCC')?.addEventListener('change', () => {
            updateLocalPresetDataFromUI();
            // Repopulate value selects when CC changes (for Pitch Transpose mode)
            try {
                if (typeof repopulateValueSelectsForCC === 'function') {
                    repopulateValueSelectsForCC();
                }
            } catch(_) {}
            // Refresh all value progress bars when CC changes
            try {
                document.querySelectorAll('[id$="_bar"]').forEach(bar => {
                    const barId = bar.id;
                    const selectId = barId.replace('_bar', '');
                    if (document.getElementById(selectId)) {
                        updateSpinProgressBar(selectId);
                    }
                });
            } catch(_) {}
        });
        document.getElementById('switchCC2')?.addEventListener('change', () => {
            updateLocalPresetDataFromUI();
            try {
                if (typeof repopulateValueSelectsForCC === 'function') {
                    repopulateValueSelectsForCC();
                }
            } catch(_) {}
            try {
                document.querySelectorAll('[id$="_bar"]').forEach(bar => {
                    const barId = bar.id;
                    const selectId = barId.replace('_bar', '');
                    if (document.getElementById(selectId)) {
                        updateSpinProgressBar(selectId);
                    }
                });
            } catch(_) {}
        });
        document.getElementById('switchStart')?.addEventListener('change', () => {
            updateLocalPresetDataFromUI();
            updateLiveLayerButtonColorFromCurrentSwitch();
        });
        document.getElementById('switchChannel')?.addEventListener('change', () => {
            // Em MODO AVANCADO, repopula CC labels quando o canal muda
            try { repopulateSwitchCCForChannel(); } catch(_) {}
            updateLocalPresetDataFromUI();
        });
        // Keep SIGLA FX synced with saved data and foot label
        try {
            const siglaInput = document.getElementById('switchSiglaFx');
            if (siglaInput) {
                const applySiglaToModelAndUI = () => {
                    siglaInput.dataset.userEdited = '1';
                    const gi = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                    const raw = (siglaInput.value || '').toString().toUpperCase();
                    const val = raw.substring(0, 3);
                    const layerIdx = currentLiveLayer - 1;
                    const layerPresets = allPresetsData[layerIdx] || [];
                    if (layerPresets[gi] && layerPresets[gi].switches && layerPresets[gi].switches[currentSwitchIndex]) {
                        layerPresets[gi].switches[currentSwitchIndex].sigla_fx = val;
                        // Update foot buttons label immediately
                        updateAllFootButtonsUI();
                    }
                    // Persist into local model as well
                    updateLocalPresetDataFromUI();
                };
                siglaInput.addEventListener('input', applySiglaToModelAndUI);
                siglaInput.addEventListener('change', applySiglaToModelAndUI);
            }
        } catch (_) {}
    
        // ADDED FIX: Keep Icon FX selects synced with hidden inputs
        try {
            const iconSelect = document.getElementById('switchIconFx');
            if (iconSelect) {
                 iconSelect.addEventListener('change', () => {
                     const val = iconSelect.value;
                     const hidden = document.getElementById('switchIconFxValue');
                     if (hidden) hidden.value = val;
                     updateLocalPresetDataFromUI();
                 });
            }
            const iconSelect2 = document.getElementById('switchIconFx2');
            if (iconSelect2) {
                 iconSelect2.addEventListener('change', () => {
                     const val = iconSelect2.value;
                     const hidden = document.getElementById('switchIconFx2Value');
                     if (hidden) hidden.value = val;
                     updateLocalPresetDataFromUI();
                 });
            }
        } catch (_) {}
    
                    document.querySelectorAll('button[data-section="extrasPcCcSection"]').forEach(button => {
                        button.addEventListener('click', (e) => {
                            const sectionId = e.target.dataset.section;
                            const section = document.getElementById(sectionId);
                            if (section) {
                                const isVisible = section.style.display !== 'none';
                                section.style.display = isVisible ? 'none' : 'block';
                                if (!isVisible) {
                                    const globalPresetIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                                    const layerIdx = currentLiveLayer - 1;
                                    const layerPresets = allPresetsData[layerIdx] || [];
                                    const presetData = layerPresets[globalPresetIndex];
                                    if (sectionId === 'extrasPcCcSection' && presetData?.extras?.pc) {
                                        const grid = section.querySelector('.extras-grid');
                                        generatePcCcFields(grid, presetData.extras);
                                        initCustomSelects();
                                    }
                                }
                            }
                        });
                    });
    
                    document.body.addEventListener('change', (e) => {
                        if (e.target && (e.target.id.startsWith('spin') || e.target.id.startsWith('control') || e.target.id.startsWith('custom') || e.target.id.startsWith('pc') || e.target.id === 'extrasSendToggle' || e.target.id === 'autoRampToggle')) {
                            updateLocalPresetDataFromUI();
                            if(e.target.id.startsWith('spin') || e.target.id.startsWith('custom')) {
                                updateSpinKnobVisual(e.target.id);
                                updateSpinSliderFillForSelect(e.target.id);
                            }
                        }
                    });
                }

            function updateActiveButton(containerId, activeIndex) {
                const container = document.getElementById(containerId);
                if (!container) return;
                const buttons = container.querySelectorAll('.grid-btn');
                buttons.forEach((btn, index) => {
                    if (index === activeIndex) {
                        btn.classList.add('active');
                    } else {
                        btn.classList.remove('active');
                    }
                });
            }

            function updateEspDisplayForPreset(col, row) {
                return apiFetch(`/set-active-config-preset?btn=${col}&lvl=${row}&layer=${currentLiveLayer}`);
            }

            function initCustomSelects() {
                document.querySelectorAll('.custom-select-wrapper').forEach(setupCustomSelect);
            }

            function getNumericRangeFromSelect(selectEl) {
                if (!selectEl || !selectEl.options || !selectEl.options.length) return null;
                let min = Infinity;
                let max = -Infinity;
                let hasNumeric = false;
                Array.from(selectEl.options).forEach(opt => {
                    const val = parseInt(opt.value, 10);
                    if (!Number.isNaN(val)) {
                        hasNumeric = true;
                        if (val < min) min = val;
                        if (val > max) max = val;
                    }
                });
                if (!hasNumeric) return null;
                return { min, max };
            }

            function clampToRange(value, min, max) {
                if (Number.isNaN(value)) return min;
                if (value < min) return min;
                if (value > max) return max;
                return value;
            }

            function selectClosestOptionValue(originalSelect, targetValue) {
                if (!originalSelect || !originalSelect.options) return null;
                let closest = null;
                let smallestDiff = Infinity;
                Array.from(originalSelect.options).forEach(opt => {
                    const val = parseInt(opt.value, 10);
                    if (!Number.isNaN(val)) {
                        const diff = Math.abs(val - targetValue);
                        if (diff < smallestDiff) {
                            smallestDiff = diff;
                            closest = val;
                        }
                    }
                });
                if (closest === null) return null;
                originalSelect.value = String(closest);
                return closest;
            }

            function updateMiniFieldSliderTrack(sliderEl, min, max, value) {
                if (!sliderEl) return;
                const den = Math.max(1, max - min);
                const pct = Math.round(((value - min) / den) * 100);
                sliderEl.style.background = `linear-gradient(to right, #7fa6e8 ${pct}%, #2a2e33 ${pct}%)`;
            }

            function hasVisualProgressForSelect(selectId) {
                if (!selectId) return false;
                return !!document.getElementById(`${selectId}_bar`);
            }

            function ensureMiniSliderForWrapper(originalSelect, wrapper) {
                if (!originalSelect || !wrapper || !originalSelect.id) return;
                const range = getNumericRangeFromSelect(originalSelect);
                const selector = `.mini-field-slider-wrap[data-select-id="${originalSelect.id}"]`;
                const existing = wrapper.parentElement ? wrapper.parentElement.querySelector(selector) : null;
                const hasVisualProgress = hasVisualProgressForSelect(originalSelect.id);

                if (originalSelect.id === 'switchMode' || !range || !hasVisualProgress) {
                    if (existing) existing.remove();
                    return;
                }

                let sliderWrap = existing;
                let sliderEl = sliderWrap ? sliderWrap.querySelector('.mini-field-slider') : null;

                if (!sliderWrap || !sliderEl) {
                    sliderWrap = document.createElement('div');
                    sliderWrap.className = 'mini-field-slider-wrap';
                    sliderWrap.dataset.selectId = originalSelect.id;

                    sliderEl = document.createElement('input');
                    sliderEl.type = 'range';
                    sliderEl.className = 'mini-field-slider';
                    sliderEl.step = '1';
                    sliderWrap.appendChild(sliderEl);
                    wrapper.insertAdjacentElement('afterend', sliderWrap);

                    const applyValue = (commit) => {
                        const min = parseInt(sliderEl.min, 10);
                        const max = parseInt(sliderEl.max, 10);
                        const minVal = Number.isNaN(min) ? 0 : min;
                        const maxVal = Number.isNaN(max) ? 127 : max;
                        const raw = parseInt(sliderEl.value, 10);
                        const clamped = clampToRange(raw, minVal, maxVal);
                        const closest = selectClosestOptionValue(originalSelect, clamped);
                        const applied = closest !== null ? closest : clamped;
                        sliderEl.value = String(applied);
                        updateMiniFieldSliderTrack(sliderEl, minVal, maxVal, applied);

                        if (typeof updateCustomSelect === 'function') {
                            updateCustomSelect(originalSelect.id);
                        }
                        if (typeof updateSpinKnobVisual === 'function') {
                            updateSpinKnobVisual(originalSelect.id);
                        }

                        originalSelect.dispatchEvent(
                            new Event(commit ? 'change' : 'input', { bubbles: true })
                        );
                    };

                    sliderEl.addEventListener('input', () => applyValue(false));
                    sliderEl.addEventListener('change', () => applyValue(true));
                    sliderEl.addEventListener('pointerdown', () => {
                        wrapper.classList.add('focused');
                    });
                    sliderEl.addEventListener('focus', () => {
                        wrapper.classList.add('focused');
                    });
                }

                const currentVal = clampToRange(parseInt(originalSelect.value, 10), range.min, range.max);
                sliderEl.min = String(range.min);
                sliderEl.max = String(range.max);
                sliderEl.value = String(currentVal);
                updateMiniFieldSliderTrack(sliderEl, range.min, range.max, currentVal);
            }

            function positionDropdown(triggerEl, optionsDiv) {
                const rect = triggerEl.getBoundingClientRect();
                const spaceBelow = window.innerHeight - rect.bottom;
                const spaceAbove = rect.top;
                const maxH = 200;
                if (spaceBelow >= maxH || spaceBelow >= spaceAbove) {
                    optionsDiv.style.top = (rect.bottom + 4) + 'px';
                    optionsDiv.style.bottom = 'auto';
                    optionsDiv.style.maxHeight = Math.min(maxH, spaceBelow - 8) + 'px';
                } else {
                    optionsDiv.style.bottom = (window.innerHeight - rect.top + 4) + 'px';
                    optionsDiv.style.top = 'auto';
                    optionsDiv.style.maxHeight = Math.min(maxH, spaceAbove - 8) + 'px';
                }
                optionsDiv.style.left = rect.left + 'px';
                optionsDiv.style.width = rect.width + 'px';
            }

            function setupCustomSelect(wrapper) {
                const trigger = wrapper.querySelector('.custom-select-trigger');
                const originalSelect = wrapper.querySelector('.original-select');
                const optionsDiv = wrapper.querySelector('.custom-select-options');
                const selectedValueSpan = trigger ? trigger.querySelector('.custom-select-selected-value') : null;

                if (!trigger || !originalSelect || !optionsDiv || !selectedValueSpan) {
                    console.warn('Custom select wrapper incompleto:', wrapper?.dataset?.selectId || wrapper);
                    return;
                }

                // Only repopulate if options changed or first time
                if (originalSelect.dataset.dirty === '1' || !wrapper.dataset.populated) {
                    populateCustomOptions(originalSelect, optionsDiv, selectedValueSpan, wrapper);
                    originalSelect.dataset.dirty = '';
                    wrapper.dataset.populated = '1';
                }
                ensureMiniSliderForWrapper(originalSelect, wrapper);

                if (wrapper.dataset.listenerAdded) return;
                wrapper.dataset.listenerAdded = 'true';
    
                wrapper.addEventListener('focusin', () => {
                    wrapper.classList.add('focused');
                    ensureMiniSliderForWrapper(originalSelect, wrapper);
                });

                wrapper.addEventListener('focusout', (e) => {
                    const sliderWrap = wrapper.parentElement
                        ? wrapper.parentElement.querySelector(`.mini-field-slider-wrap[data-select-id="${originalSelect.id}"]`)
                        : null;
                    const focusMovedToSlider = sliderWrap && sliderWrap.contains(e.relatedTarget);
                    if (!wrapper.contains(e.relatedTarget) && !focusMovedToSlider) {
                        wrapper.classList.remove('focused');
                    }
                });

                trigger.addEventListener('click', (e) => {
                    e.stopPropagation();
                    ensureMiniSliderForWrapper(originalSelect, wrapper);

                    closeAllSelects(wrapper);
                    const willOpen = !optionsDiv.classList.contains('open');
                    optionsDiv.classList.toggle('open');
                    wrapper.classList.toggle('focused');
                    if (willOpen) positionDropdown(trigger, optionsDiv);
                });

                trigger.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        trigger.click();
                    }
                });
            }

            function populateCustomOptions(originalSelect, optionsDiv, selectedValueSpan, wrapper) {
                if (!originalSelect || !optionsDiv || !selectedValueSpan) return;
                optionsDiv.innerHTML = '';
                let hasSelected = false;
                const appendCustomOption = (option) => {
                    if (option.disabled) return;
                    const customOption = document.createElement('div');
                    customOption.className = 'custom-select-option';

                    const textContent = option.textContent;
                    customOption.textContent = textContent;
                    customOption.dataset.value = option.value;
    
                    if (option.selected) {
                        customOption.classList.add('selected');
                        selectedValueSpan.textContent = textContent;
                        hasSelected = true;
                    }
    
                    customOption.addEventListener('click', () => {
                        if (originalSelect.value !== option.value) {
                            originalSelect.value = option.value;
                            updateLocalPresetDataFromUI();
                            if (originalSelect.id.startsWith('spin') || originalSelect.id.startsWith('custom')) {
                                updateSpinKnobVisual(originalSelect.id);
                            }
                            originalSelect.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                        selectedValueSpan.textContent = customOption.textContent;
                        optionsDiv.querySelectorAll('.custom-select-option').forEach(opt => opt.classList.remove('selected'));
                        customOption.classList.add('selected');
                        optionsDiv.classList.remove('open');
                        if (wrapper && typeof wrapper.classList !== 'undefined') {
                            wrapper.classList.remove('focused');
                        } else {
                            const fallbackWrapper = optionsDiv.closest('.custom-select-wrapper');
                            if (fallbackWrapper) fallbackWrapper.classList.remove('focused');
                        }
                        ensureMiniSliderForWrapper(originalSelect, wrapper);
                    });
                    optionsDiv.appendChild(customOption);
                };
                Array.from(originalSelect.options).forEach(option => {
                    if (option.disabled) {
                        const header = document.createElement('div');
                        header.className = 'custom-select-group-header';
                        header.textContent = option.textContent;
                        optionsDiv.appendChild(header);
                        return;
                    }
                    appendCustomOption(option);
                });
                if (!hasSelected && originalSelect.options.length > 0) {
                    originalSelect.selectedIndex = 0;
                    originalSelect.dispatchEvent(new Event('change', { bubbles: true }));
                    const firstCustomOption = optionsDiv.querySelector('.custom-select-option');
                    if(firstCustomOption) {
                        firstCustomOption.classList.add('selected');
                        selectedValueSpan.textContent = firstCustomOption.textContent;
                    }
                }
                ensureMiniSliderForWrapper(originalSelect, wrapper);
            }

            function closeAllSelects(exceptThisWrapper) {
                document.querySelectorAll('.custom-select-wrapper').forEach(wrapper => {
                    if (wrapper !== exceptThisWrapper) {
                        const optionsDiv = wrapper.querySelector('.custom-select-options');
                        if (optionsDiv) optionsDiv.classList.remove('open');
                        wrapper.classList.remove('focused');
                    }
                });
            }

            function polarToCartesian(cx, cy, r, angleDeg) {
                const rad = (angleDeg - 90) * Math.PI / 180.0;
                return { x: cx + (r * Math.cos(rad)), y: cy + (r * Math.sin(rad)) };
            }
            function describeArc(cx, cy, r, startAngle, endAngle) {
                const start = polarToCartesian(cx, cy, r, endAngle);
                const end = polarToCartesian(cx, cy, r, startAngle);
                const largeArc = (endAngle - startAngle) <= 180 ? 0 : 1;
                return `M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArc} 0 ${end.x} ${end.y}`;
            }
            function updateSpinSliderFillForSelect(selectId) {
                const sel = document.getElementById(selectId);
                if (!sel) return;
                let rangeId = null;
                if (selectId.startsWith('customOn_') || selectId.startsWith('customOff_')) {
                    const m = selectId.match(/_(\d+)_(\d+)$/);
                    if (m) rangeId = `customRange_${m[1]}_${m[2]}`;
                }
                if (!rangeId) return;
                const rng = document.getElementById(rangeId);
                if (!rng) return;
                const v = Math.max(0, Math.min(127, parseInt(sel.value, 10) || 0));
                rng.value = String(v);
                const p = Math.round((v / 127) * 100);
                rng.style.background = `linear-gradient(to right, #7fa6e8 ${p}%, #2a2e33 ${p}%)`;
            }
            function getOptionLabelText(opt) {
                if (!opt) return '';
                const text = opt.textContent || '';
                const sep = text.indexOf(' - ');
                return sep >= 0 ? text.slice(sep + 3) : '';
            }
            function updateSpinProgressBar(selectId) {
                const sel = document.getElementById(selectId);
                const bar = document.getElementById(`${selectId}_bar`);
                const label = document.getElementById(`${selectId}_label`);
                if (!sel || !bar) return;

                // Check if current CC for this value select is Kemper Pitch Transpose (208)
                const switchCCEl = document.getElementById('switchCC');
                const switchCCVal = switchCCEl ? parseInt(switchCCEl.value, 10) : 0;
                let ccVal = switchCCVal;
                if (typeof getValueSelectCcValue === 'function') {
                    const resolved = getValueSelectCcValue(selectId);
                    if (resolved !== null && resolved !== undefined) {
                        ccVal = resolved;
                    }
                }
                const isPitchTranspose = (typeof getEffectiveMidiMode === 'function' && getEffectiveMidiMode() === "KEMPER PLAYER" && ccVal === 208);

                let v, pct, labelText;
                if (isPitchTranspose) {
                    // Range 28-100 for Pitch Transpose with label
                    v = Math.max(28, Math.min(100, parseInt(sel.value, 10) || 64));
                    // Show musical label
                    labelText = (typeof kemperTransposeLabels !== 'undefined' && kemperTransposeLabels[v]) ? kemperTransposeLabels[v] : '';
                    if (!labelText && typeof getKemperLabelForValueSelect === 'function') {
                        labelText = getKemperLabelForValueSelect(sel);
                    }
                } else {
                    // Normal range 0-127 with progress bar
                    bar.style.display = '';
                    v = Math.max(0, Math.min(127, parseInt(sel.value, 10) || 0));
                    pct = Math.round((v / 127) * 100);
                    const opt = sel.options && sel.options[sel.selectedIndex];
                    labelText = getOptionLabelText(opt);
                    if (!labelText && typeof getKemperLabelForValueSelect === 'function') {
                        labelText = getKemperLabelForValueSelect(sel);
                    }
                }
                if (labelText) {
                    bar.style.display = '';
                    bar.style.width = '100%';
                    if (label) label.textContent = labelText;
                } else {
                    if (typeof pct !== 'number') {
                        v = Math.max(0, Math.min(127, parseInt(sel.value, 10) || 0));
                        pct = Math.round((v / 127) * 100);
                    }
                    bar.style.display = '';
                    bar.style.width = `${pct}%`;
                    if (label) label.textContent = `${pct}%`;
                }
            }
            function updateSpinKnobVisual(selectId) {
                const selectElement = document.getElementById(selectId);
                if (!selectElement) return;

                let value = parseInt(selectElement.value, 10);
                if (Number.isNaN(value)) value = 0;
                value = Math.max(0, Math.min(127, value));
                const percentage = Math.round((value / 127) * 100);

                const textElement = document.getElementById(`${selectId}_text`);
                if (textElement) {
                    const tag = (textElement.tagName || '').toLowerCase();
                    const isSvgText = tag === 'text';
                    if (isSvgText) {
                        textElement.textContent = (value >= 127) ? 'MAX' : `${value}`;
                    } else {
                        const label = (value >= 127) ? 'MAX' : `${value}`;
                        textElement.innerHTML = `<span class="spin-percent-number">${label}</span>`;
                    }
                }

                const trackElement = document.getElementById(`${selectId}_track`);
                const progressElement = document.getElementById(`${selectId}_progress`);
                if (trackElement && progressElement) {
                    const startAngle = 240; 
                    const endAngle = 480; 
                    trackElement.setAttribute('d', describeArc(50, 50, 44, startAngle, endAngle));
                    const progressAngle = startAngle + ((endAngle - startAngle) * (value / 127));
                    progressElement.setAttribute('d', describeArc(50, 50, 44, startAngle, progressAngle));
                }

                const barsWrap = document.getElementById(`${selectId}_bars`);
                if (barsWrap) {
                    const bars = barsWrap.querySelectorAll('.spin-bar');
                    const total = bars.length || 10;
                    const filled = Math.max(0, Math.min(total, Math.round((value / 127) * total)));
                    bars.forEach((bar, i) => {
                        if (i < filled) bar.classList.add('filled');
                        else bar.classList.remove('filled');
                    });
                }

                try {
                    const barsWrap = document.getElementById(`${selectId}_bars`);
                    if (barsWrap) {
                        const bars = barsWrap.querySelectorAll('.spin-bar');
                        const total = Math.max(1, bars.length || 9);
                        const filled = Math.max(0, Math.min(total, Math.round((value / 127) * total)));
                        bars.forEach((bar, i) => {
                            if (i < filled) bar.classList.add('filled');
                            else bar.classList.remove('filled');
                        });
                    }
                } catch (e) {  }

                const progressBar = document.getElementById(`${selectId}_progressBar`);
                if (progressBar) {
                    progressBar.style.width = `${percentage}%`;
                    const label = progressBar.querySelector('span');
                    if (label) {
                        const opt = selectElement.options && selectElement.options[selectElement.selectedIndex];
                        const labelText = getOptionLabelText(opt);
                        if (labelText) {
                            progressBar.style.width = '100%';
                            label.textContent = labelText;
                        } else {
                            label.textContent = `${percentage}%`;
                        }
                    }
                }

                // Sync new linear progress bar used in simplified SPIN UI
                updateSpinProgressBar(selectId);
            }

            function addKnobDragControl(selectId, parentElement) {
                function ensureGlobalFader() {
                    const area = document.getElementById('dynamicModeConfigArea');
                    if (!area) return;
                    let wrap = document.getElementById('globalKnobFaderWrap');
                    if (!wrap) {
                        wrap = document.createElement('div');
                        wrap.id = 'globalKnobFaderWrap';
                        wrap.className = 'knob-fader';
                        const rng = document.createElement('input');
                        rng.type = 'range'; rng.min = '0'; rng.max = '127'; rng.step = '1';
                        rng.id = 'globalKnobFader';
                        wrap.appendChild(rng);
                        area.appendChild(wrap);
                        globalFaderWrap = wrap; globalFaderRange = rng;
                        const applyActive = () => {
                            if (!activeKnobSelectId) return;
                            const s = document.getElementById(activeKnobSelectId);
                            if (!s) return;
                            const v = Math.max(0, Math.min(127, Math.round(parseInt(globalFaderRange.value, 10) || 0)));
                            if (String(s.value) !== String(v)) {
                                s.value = String(v);
                                if (typeof updateCustomSelect === 'function') updateCustomSelect(activeKnobSelectId);
                                updateSpinKnobVisual(activeKnobSelectId);
                                s.dispatchEvent(new Event('change', { bubbles: true }));
                            } else {
                                updateSpinKnobVisual(activeKnobSelectId);
                            }
                        };
                        rng.addEventListener('input', applyActive);
                        rng.addEventListener('change', applyActive);
                        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hideGlobalFader(); });
                    } else {
                        globalFaderWrap = wrap;
                        globalFaderRange = document.getElementById('globalKnobFader');
                        if (wrap.parentElement !== area) area.appendChild(wrap);
                    }
                }
                function showGlobalFader(forSelectId) {
                    ensureGlobalFader();
                    if (!globalFaderWrap || !globalFaderRange) return;
                    const s = document.getElementById(forSelectId);
                    if (!s) return;
                    globalFaderRange.value = String(parseInt(s.value, 10) || 0);
                    globalFaderWrap.style.display = 'flex';
                }
                function hideGlobalFader() {
                    if (!globalFaderWrap) return;
                    globalFaderWrap.style.display = 'none';
                    if (activeKnobProgressEl) activeKnobProgressEl.style.stroke = '';
                    activeKnobProgressEl = null; activeKnobSelectId = null;
                }

                const knobEl = parentElement.querySelector('.spin-knob');
                const progressEl = document.getElementById(`${selectId}_progress`);
                if (knobEl) {
                    knobEl.addEventListener('click', (e) => {
                        e.stopPropagation();
                        ensureGlobalFader();
                        const fVisible = globalFaderWrap && globalFaderWrap.style.display === 'flex';
                        if (fVisible && activeKnobSelectId === selectId) {
                            hideGlobalFader();
                            return;
                        }
                        if (activeKnobProgressEl) activeKnobProgressEl.style.stroke = '';
                        activeKnobSelectId = selectId;
                        activeKnobProgressEl = progressEl;
                        if (activeKnobProgressEl) activeKnobProgressEl.style.stroke = '#2ecc71';
                        showGlobalFader(selectId);
                    });
                }
                document.addEventListener('click', (e) => {
                    if (!globalFaderWrap) return;
                    const area = document.getElementById('dynamicModeConfigArea');
                    if (!area) return;
                    if (!globalFaderWrap.contains(e.target) && !area.contains(e.target)) hideGlobalFader();
                });
            }

            document.addEventListener('click', closeAllSelects);
            document.addEventListener('scroll', (e) => {
                if (e.target && e.target.closest && e.target.closest('.custom-select-options')) return;
                closeAllSelects();
            }, true);

            (function(){
                const syncStartButtonVisual = () => {
                    const cb = document.getElementById('switchStart');
                    const btn = document.getElementById('startToggleBtn');
                    if (!cb || !btn) return;
                    
                    // Verifica se estamos no modo SINGLE (classe adicionada em updateSwitchSpecificUI)
                    const isSingleMode = document.getElementById('switchStart')?.closest('.form-group')?.classList.contains('single-mode-toggle');

                    if (isSingleMode) {
                        const singleValGroup = document.getElementById('singleValueGroup');
                        if (cb.checked) {
                            btn.classList.add('active');
                            btn.classList.add('cc-mode');
                            btn.classList.remove('pc-mode');
                            btn.setAttribute('aria-pressed','true');
                            btn.textContent = 'ENVIAR CC';
                            if (singleValGroup) singleValGroup.style.display = 'block';
                        } else {
                            btn.classList.remove('active');
                            btn.classList.add('pc-mode');
                            btn.classList.remove('cc-mode');
                            btn.setAttribute('aria-pressed','false');
                            btn.textContent = 'ENVIAR PC';
                            if (singleValGroup) singleValGroup.style.display = 'none';
                        }
                    } else {
                        // Comportamento padrão
                        if (cb.checked) {
                            btn.classList.add('active');
                            btn.classList.remove('cc-mode');
                            btn.classList.remove('pc-mode');
                            btn.setAttribute('aria-pressed','true');
                            btn.textContent = 'INICIAR LIGADO';
                        } else {
                            btn.classList.remove('active');
                            btn.classList.remove('cc-mode');
                            btn.classList.remove('pc-mode');
                            btn.setAttribute('aria-pressed','false');
                            btn.textContent = 'INICIAR DESLIGADO';
                        }
                    }
                };
                try {
                    const cb = document.getElementById('switchStart');
                    const btn = document.getElementById('startToggleBtn');
                    if (cb && btn) {
                        // estado inicial
                        syncStartButtonVisual();
                        // quando checkbox mudar, atualiza visual
                        cb.addEventListener('change', syncStartButtonVisual);
                        btn.addEventListener('click', (e) => {
                            e.preventDefault();
                            cb.checked = !cb.checked;
                            syncStartButtonVisual();
                            cb.dispatchEvent(new Event('change', { bubbles: true }));
                        });
                    }
                } catch (err) {
                    console.warn('Start toggle init error:', err);
                }
            })();
            
            // Slider universal removido. Cada campo numerico agora possui seu proprio mini-slider local.

            // ========== FX ICON PICKER (THUMBNAILS) ==========
            const MAX_FX_ICON_ID = 51;
            const normalizeFxIconId = (value) => {
                const parsed = parseInt(value, 10) || 0;
                return (parsed >= 0 && parsed <= MAX_FX_ICON_ID) ? parsed : 0;
            };
            const FX_ICONS_LIST = Array.from({ length: MAX_FX_ICON_ID + 1 }, (_, i) => ({
                value: i,
                name: i === 0 ? "SIGLA" : `ICO${i}`
            }));

            const ICONS_WEB = (typeof window.BFMIDI_ICONS_WEB === 'object' && window.BFMIDI_ICONS_WEB) ? window.BFMIDI_ICONS_WEB : null;
            const iconMetaById = (() => {
                const m = new Map();
                try {
                    if (ICONS_WEB && Array.isArray(ICONS_WEB.icons)) {
                        ICONS_WEB.icons.forEach(it => { if (it && typeof it.id === 'number') m.set(it.id, it); });
                    }
                } catch (_) {}
                return m;
            })();

            const iconCanvasCache = new Map(); // id -> offscreen canvas (native size)
            let gigViewPreviewState = 'on';

            window.toggleGigViewState = function() {
                gigViewPreviewState = gigViewPreviewState === 'on' ? 'off' : 'on';
                const btn = document.getElementById('gigViewStateToggle');
                const isOn = gigViewPreviewState === 'on';
                if (btn) {
                    btn.dataset.state = gigViewPreviewState;
                    const label = btn.querySelector('.power-btn-label');
                    if (label) label.innerHTML = 'PREVIEW<br>' + (isOn ? 'ON' : 'OFF');
                }
                try { updateGigViewPreview(); } catch(_) {}
            };

            function getGigPreviewColorRef(idx, fallbackIdx) {
                if (typeof PERFIS_CORES_WEB === 'undefined') return { value: 0xFFFFFF };
                const safeIdx = (!isNaN(idx) && idx >= 0) ? idx : fallbackIdx;
                return PERFIS_CORES_WEB[safeIdx] || PERFIS_CORES_WEB[fallbackIdx] || PERFIS_CORES_WEB[6] || { value: 0xFFFFFF };
            }

            function toCssRgb(c) {
                if (!c) return 'rgb(255,255,255)';
                if (typeof c.r === 'number' && typeof c.g === 'number' && typeof c.b === 'number') {
                    return `rgb(${c.r},${c.g},${c.b})`;
                }
                const v = (typeof c.value === 'number') ? c.value : 0xFFFFFF;
                return `rgb(${(v >> 16) & 0xFF},${(v >> 8) & 0xFF},${v & 0xFF})`;
            }

            function createLinearGradientFromCss(ctx, cssText, width, height) {
                if (!ctx || !cssText || typeof cssText !== 'string') return null;
                const match = cssText.match(/linear-gradient\((.+)\)$/i);
                if (!match) return null;

                const parts = match[1].split(',').map(part => part.trim()).filter(Boolean);
                if (parts.length < 2) return null;

                let angleDeg = 180;
                let stopStartIndex = 0;
                if (/deg$/i.test(parts[0])) {
                    angleDeg = parseFloat(parts[0]);
                    stopStartIndex = 1;
                }

                const stops = parts.slice(stopStartIndex).map((part, index, arr) => {
                    const tokens = part.split(/\s+/);
                    const color = tokens[0];
                    const stopToken = tokens[1];
                    let pos = null;
                    if (stopToken && stopToken.endsWith('%')) {
                        const parsed = parseFloat(stopToken);
                        if (!Number.isNaN(parsed)) pos = parsed / 100;
                    }
                    if (pos === null) {
                        pos = arr.length <= 1 ? 0 : (index / (arr.length - 1));
                    }
                    return { color, pos };
                }).filter(stop => /^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(stop.color));

                if (!stops.length) return null;

                const radians = ((angleDeg - 90) * Math.PI) / 180;
                const dx = Math.cos(radians);
                const dy = Math.sin(radians);
                const cx = width / 2;
                const cy = height / 2;
                const radius = Math.sqrt(width * width + height * height) / 2;
                const gradient = ctx.createLinearGradient(
                    cx - dx * radius,
                    cy - dy * radius,
                    cx + dx * radius,
                    cy + dy * radius
                );

                stops.forEach(stop => {
                    const clamped = Math.max(0, Math.min(1, stop.pos));
                    gradient.addColorStop(clamped, stop.color);
                });
                return gradient;
            }

            function getGigPreviewPaint(ctx, colorRef, width, height) {
                if (!ctx) return '#ffffff';
                if (colorRef && typeof colorRef === 'object' && colorRef.previewCss) {
                    const gradient = createLinearGradientFromCss(ctx, colorRef.previewCss, width, height);
                    if (gradient) return gradient;
                }
                return (typeof getColorHex === 'function') ? getColorHex(colorRef) : toCssRgb(colorRef);
            }

            function updateGigViewPreview() {
                const frame = document.getElementById('gigViewPreviewFrame');
                const canvas = document.getElementById('gigViewPreviewCanvas');
                if (!frame || !canvas) return;

                const rect = canvas.getBoundingClientRect();
                if (rect.width <= 0 || rect.height <= 0) {
                    requestAnimationFrame(updateGigViewPreview);
                    return;
                }

                const dpr = window.devicePixelRatio || 1;
                const W = Math.round(rect.width * dpr);
                const H = Math.round(rect.height * dpr);
                canvas.width = W;
                canvas.height = H;

                const ctx = canvas.getContext('2d');
                if (!ctx) return;
                ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
                ctx.imageSmoothingEnabled = true;
                ctx.imageSmoothingQuality = 'high';

                const cw = rect.width;
                const ch = rect.height;

                // Determine slot suffix
                const slotSuffix = window.activeGigSlot === 2 ? '2' : '';
                const btnSuffix = window.activeGigSlot === 2 ? '2' : '1';

                const previewIsOn = gigViewPreviewState === 'on';

                // Icon color
                const iconOnIdx = parseInt(document.getElementById(`switchIconColor${slotSuffix}Value`)?.value || '6', 10);
                const iconOffIdx = parseInt(document.getElementById(`switchIconColor${slotSuffix}OffValue`)?.value || '6', 10);
                const iconColor = getGigPreviewColorRef(previewIsOn ? iconOnIdx : iconOffIdx, 6);

                // Background color
                const backOnIdx = parseInt(document.getElementById(`switchBackColorOn${slotSuffix}Value`)?.value || '0', 10);
                const backOffIdx = parseInt(document.getElementById(`switchBackColorOff${slotSuffix}Value`)?.value || '0', 10);
                const backColor = getGigPreviewColorRef(previewIsOn ? backOnIdx : backOffIdx, 0);

                // Border color
                const borderOnIdx = parseInt(document.getElementById(`switchBorderColorOn${slotSuffix}Value`)?.value || '9', 10);
                const borderOffIdx = parseInt(document.getElementById(`switchBorderColorOff${slotSuffix}Value`)?.value || '9', 10);
                const borderColor = getGigPreviewColorRef(previewIsOn ? borderOnIdx : borderOffIdx, 9);

                const iconFxId = normalizeFxIconId(document.getElementById(`switchIconFx${slotSuffix}Value`)?.value || '0');
                const fxModeBtn = document.getElementById(`fxModeToggle${btnSuffix}`);
                const isIconMode = !!(fxModeBtn && fxModeBtn.dataset.mode === 'icon' && iconFxId > 0);
                const siglaFx = (document.getElementById(`switchSiglaFx${slotSuffix}`)?.value || 'FX').toUpperCase();
                // Slot 2 doesn't have an iconName input
                const iconNameEl = window.activeGigSlot === 2 ? null : document.getElementById('switchIconName');
                const iconName = iconNameEl ? iconNameEl.value.toUpperCase() : '';

                // Draw background and border (inner frame)
                ctx.clearRect(0, 0, cw, ch);
                const bw = 5;
                ctx.fillStyle = getGigPreviewPaint(ctx, backColor, cw, ch);
                ctx.strokeStyle = getGigPreviewPaint(ctx, borderColor, cw, ch);
                ctx.lineWidth = bw;
                
                // Draw rounded rectangle for both background and border
                ctx.beginPath();
                if (ctx.roundRect) {
                    ctx.roundRect(bw / 2, bw / 2, cw - bw, ch - bw, 16);
                } else {
                    // Fallback if roundRect is not supported
                    const x = bw / 2, y = bw / 2, w = cw - bw, h = ch - bw, r = 16;
                    ctx.moveTo(x + r, y);
                    ctx.arcTo(x + w, y, x + w, y + h, r);
                    ctx.arcTo(x + w, y + h, x, y + h, r);
                    ctx.arcTo(x, y + h, x, y, r);
                    ctx.arcTo(x, y, x + w, y, r);
                    ctx.closePath();
                }
                ctx.fill();
                ctx.stroke();

                if (isIconMode) {
                    let nativeCanvas = iconCanvasCache.get(iconFxId);
                    if (!nativeCanvas) {
                        const tmp = document.createElement('canvas');
                        renderIconToCanvas(iconFxId, tmp);
                        nativeCanvas = iconCanvasCache.get(iconFxId);
                    }
                    if (nativeCanvas) {
                        const iw = nativeCanvas.width;
                        const ih = nativeCanvas.height;
                        const reserveName = iconName ? (ch * 0.22) : 0;
                        const scale = Math.min((cw * 0.88) / iw, ((ch - reserveName) * 0.88) / ih);
                        const dw = iw * scale;
                        const dh = ih * scale;
                        const dx = (cw - dw) / 2;
                        const dy = iconName ? ((ch - dh - reserveName) / 2 + 6) : ((ch - dh) / 2);

                        const tint = document.createElement('canvas');
                        tint.width = iw;
                        tint.height = ih;
                        const tctx = tint.getContext('2d');
                        if (tctx) {
                            tctx.imageSmoothingEnabled = true;
                            tctx.imageSmoothingQuality = 'high';
                            tctx.fillStyle = getGigPreviewPaint(tctx, iconColor, iw, ih);
                            tctx.fillRect(0, 0, iw, ih);
                            tctx.globalCompositeOperation = 'destination-in';
                            tctx.drawImage(nativeCanvas, 0, 0);
                            ctx.imageSmoothingEnabled = true;
                            ctx.imageSmoothingQuality = 'high';
                            ctx.drawImage(tint, dx, dy, dw, dh);
                        }
                    }
                    if (iconName) {
                        const nm = iconName.substring(0, 6);
                        const nameSize = Math.max(11, Math.min(22, ch * 0.15));
                        ctx.fillStyle = getGigPreviewPaint(ctx, iconColor, cw, ch);
                        ctx.globalAlpha = 0.95;
                        ctx.textAlign = 'center';
                        ctx.textBaseline = 'bottom';
                        // Move label slightly up by changing -4 to -8
                        ctx.font = `800 ${nameSize}px 'Segoe UI', sans-serif`;
                        ctx.fillText(nm, cw / 2, ch - 8);
                        ctx.globalAlpha = 1;
                    }
                } else {
                    const txt = (siglaFx || 'FX').substring(0, 3);
                    const fontSize = Math.max(22, Math.min(ch * 0.44, cw * 0.44));
                    ctx.fillStyle = getGigPreviewPaint(ctx, iconColor, cw, ch);
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'middle';
                    ctx.font = `800 ${fontSize}px 'Segoe UI', sans-serif`;
                    ctx.fillText(txt, cw / 2, ch / 2);
                }
            }

            function b64ToBytes(b64) {
                const bin = atob(b64);
                const out = new Uint8Array(bin.length);
                for (let i = 0; i < bin.length; i++) out[i] = bin.charCodeAt(i) & 0xFF;
                return out;
            }

            function renderIconToCanvas(iconId, canvas) {
                if (!canvas) return;
                const ctx = canvas.getContext('2d');
                if (!ctx) return;
                iconId = normalizeFxIconId(iconId);

                // "Nenhum (Texto)"
                if (!iconId || iconId <= 0) {
                    canvas.width = 95;
                    canvas.height = 72;
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    ctx.fillStyle = '#000';
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                    return;
                }

                const meta = iconMetaById.get(iconId);
                if (!meta || !meta.a4 || !meta.w || !meta.h) {
                    canvas.width = 95;
                    canvas.height = 72;
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    ctx.fillStyle = '#000';
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                    return;
                }

                // Reuse cached native canvas
                let nativeCanvas = iconCanvasCache.get(iconId);
                if (!nativeCanvas) {
                    nativeCanvas = document.createElement('canvas');
                    nativeCanvas.width = meta.w;
                    nativeCanvas.height = meta.h;
                    const nctx = nativeCanvas.getContext('2d');
                    const img = nctx.createImageData(meta.w, meta.h);
                    const bytes = b64ToBytes(meta.a4);
                    const data = img.data;
                    const pxCount = meta.w * meta.h;
                    for (let p = 0; p < pxCount; p++) {
                        const bi = (p / 2) | 0;
                        const b = bytes[bi] || 0;
                        const nib = (p % 2 === 0) ? ((b >> 4) & 0x0F) : (b & 0x0F);
                        const a = nib * 17; // 0..255
                        const di = p * 4;
                        data[di + 0] = 255;
                        data[di + 1] = 255;
                        data[di + 2] = 255;
                        data[di + 3] = a;
                    }
                    nctx.putImageData(img, 0, 0);
                    iconCanvasCache.set(iconId, nativeCanvas);
                }

                // Draw scaled into target canvas (keep aspect)
                canvas.width = meta.w;
                canvas.height = meta.h;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                ctx.imageSmoothingEnabled = true;
                ctx.imageSmoothingQuality = 'high';
                ctx.drawImage(nativeCanvas, 0, 0);
            }

            function setIconValue(slot, iconId, opts) {
                const silent = !!(opts && opts.silent);
                iconId = normalizeFxIconId(iconId);
                const hiddenId = slot === 1 ? 'switchIconFxValue' : 'switchIconFx2Value';
                const selectId = slot === 1 ? 'switchIconFx' : 'switchIconFx2';
                const labelId = slot === 1 ? 'fxIconLabel1' : 'fxIconLabel2';
                const canvasId = slot === 1 ? 'fxIconCanvas1' : 'fxIconCanvas2';

                const hidden = document.getElementById(hiddenId);
                if (hidden) hidden.value = String(iconId || 0);

                const select = document.getElementById(selectId);
                if (select) select.value = String(iconId || 0);

                const label = document.getElementById(labelId);
                if (label) label.textContent = iconId > 0 ? `ICO${iconId}` : 'ICO0';

                renderIconToCanvas(iconId, document.getElementById(canvasId));
                if (slot === 1) {
                    try { updateGigViewPreview(); } catch(_) {}
                }

                if (!silent) {
                    try { updateLocalPresetDataFromUI(); } catch(_) {}
                }
            }

            function ensureIconPickerGridBuilt() {
                const grid = document.getElementById('iconPickerGrid');
                if (!grid) return;
                if (grid.dataset.built === '1') return;

                // "Nenhum (Texto)"
                const makeItem = (id) => {
                    const item = document.createElement('button');
                    item.type = 'button';
                    item.className = 'icon-picker-item';
                    item.dataset.iconId = String(id);

                    const cv = document.createElement('canvas');
                    cv.width = 80;
                    cv.height = 69;
                    item.appendChild(cv);

                    renderIconToCanvas(id, cv);
                    return item;
                };

                grid.appendChild(makeItem(0));
                for (let i = 1; i <= MAX_FX_ICON_ID; i++) {
                    grid.appendChild(makeItem(i));
                }

                grid.addEventListener('click', (ev) => {
                    const btn = ev.target && ev.target.closest ? ev.target.closest('.icon-picker-item') : null;
                    if (!btn) return;
                    const overlay = document.getElementById('iconPickerOverlay');
                    const slot = overlay ? parseInt(overlay.dataset.slot || '1', 10) : 1;
                    const iconId = normalizeFxIconId(btn.dataset.iconId || '0');
                    setIconValue(slot, iconId);
                    if (overlay) overlay.classList.remove('active');
                });

                grid.dataset.built = '1';
            }

            window.openIconPicker = function(slot) {
                const overlay = document.getElementById('iconPickerOverlay');
                if (!overlay) return;
                overlay.dataset.slot = String(slot || 1);
                ensureIconPickerGridBuilt();
                overlay.classList.add('active');
            };

            (function initIconPickerOverlay() {
                const overlay = document.getElementById('iconPickerOverlay');
                if (!overlay) return;
                const closeBtn = document.getElementById('iconPickerCloseBtn');
                if (closeBtn) closeBtn.addEventListener('click', () => overlay.classList.remove('active'));
                overlay.addEventListener('click', (ev) => {
                    if (ev.target === overlay) overlay.classList.remove('active');
                });
            })();

            // Toggle between SIGLA (text) and ICON mode
            // Toggle between SIGLA (text) and ICON mode
            window.activeGigSlot = 1;

            window.refreshGigSlotUI = function() {
                const btn = document.getElementById('gigSlotToggleBtn');
                if (btn) btn.textContent = `SLOTE ${window.activeGigSlot}`;
                
                const mode1 = document.getElementById('fxModeToggle1')?.getAttribute('data-mode') || 'sigla';
                const mode2 = document.getElementById('fxModeToggle2')?.getAttribute('data-mode') || 'sigla';

                const displayState = function(elId, show) {
                    const el = document.getElementById(elId);
                    if (el) el.style.display = show ? 'block' : 'none';
                };

                const effectiveMode1 = mode1;
                const effectiveMode2 = mode2;

                // SLOT 1
                displayState('switchSiglaFx', window.activeGigSlot === 1 && effectiveMode1 === 'sigla');
                displayState('switchIconName', window.activeGigSlot === 1 && effectiveMode1 === 'icon');
                displayState('fxIconSelect1', window.activeGigSlot === 1 && effectiveMode1 === 'icon');
                const fGroup1 = document.getElementById('fxModeToggle1');
                if (fGroup1) fGroup1.style.display = (window.activeGigSlot === 1) ? 'inline-block' : 'none';

                // SLOT 2
                displayState('switchSiglaFx2', window.activeGigSlot === 2);
                displayState('fxIconSelect2', false);
                const fGroup2 = document.getElementById('fxModeToggle2');
                if (fGroup2) fGroup2.style.display = (window.activeGigSlot === 2) ? 'inline-block' : 'none';

                // COLOR PICKERS (Shared Container)
                const cGroupShared = document.getElementById('iconColorGroup');
                if (cGroupShared) cGroupShared.style.display = '';
                document.querySelectorAll('.slot1-color').forEach(el => el.style.display = (window.activeGigSlot === 1) ? '' : 'none');
                document.querySelectorAll('.slot2-color').forEach(el => el.style.display = (window.activeGigSlot === 2) ? '' : 'none');

                const iconNameGroup = document.getElementById('iconNameGroup');
                if (iconNameGroup) iconNameGroup.style.display = '';

                const iconColorLabel = document.getElementById('iconColorLabel');
                if (iconColorLabel) {
                    iconColorLabel.textContent = 'ICON';
                }

                const lbl = document.getElementById('iconNameGroupLabel');
                if (lbl) {
                    lbl.textContent = window.activeGigSlot === 1 ? 'NOME:' : 'NOME 2:';
                }
                
                try { updateGigViewPreview(); } catch(_) {}
            };

            window.toggleGigSlot = function() {
                window.activeGigSlot = window.activeGigSlot === 1 ? 2 : 1;
                window.refreshGigSlotUI();
            };

            // Toggle between SIGLA (text) and ICON mode
            window.toggleFxMode = function(fxNum) {
                const btn = document.getElementById(`fxModeToggle${fxNum}`);
                const iconValueInput = document.getElementById(fxNum === 1 ? 'switchIconFxValue' : 'switchIconFx2Value');

                if (!btn) return;

                const currentMode = btn.getAttribute('data-mode');

                if (currentMode === 'sigla') {
                    // Switching to ICON
                    btn.setAttribute('data-mode', 'icon');
                    btn.textContent = 'ICONE';
                    
                    const currentVal = normalizeFxIconId(iconValueInput?.value || '0');
                    const nextVal = currentVal > 0 ? currentVal : 1;
                    if (iconValueInput) iconValueInput.value = String(nextVal);
                    setIconValue(fxNum, nextVal);
                } else {
                    // Switching to SIGLA
                    btn.setAttribute('data-mode', 'sigla');
                    btn.textContent = 'SIGLA';
                    
                    if (iconValueInput) iconValueInput.value = '0';
                    setIconValue(fxNum, 0);
                }
                
                window.refreshGigSlotUI();
            };

            window.setFxModeFromData = function(fxNum, iconValue) {
                const btn = document.getElementById(`fxModeToggle${fxNum}`);
                const iconValueInput = document.getElementById(fxNum === 1 ? 'switchIconFxValue' : 'switchIconFx2Value');

                if (!btn) return;

                const normalizedIconValue = normalizeFxIconId(iconValue);
                const useIcon = (normalizedIconValue > 0);

                if (useIcon) {
                    btn.setAttribute('data-mode', 'icon');
                    btn.textContent = 'ICONE';
                    
                    if (iconValueInput) iconValueInput.value = String(normalizedIconValue);
                    setIconValue(fxNum, normalizedIconValue, { silent: true });
                } else {
                    btn.setAttribute('data-mode', 'sigla');
                    btn.textContent = 'SIGLA';
                    
                    if (iconValueInput) iconValueInput.value = '0';
                    setIconValue(fxNum, 0, { silent: true });
                }
                
                window.refreshGigSlotUI();
            };

            // Initial thumb render
            try {
                const v1 = normalizeFxIconId(document.getElementById('switchIconFxValue')?.value || '0');
                const v2 = normalizeFxIconId(document.getElementById('switchIconFx2Value')?.value || '0');
                setIconValue(1, v1, { silent: true });
                setIconValue(2, v2, { silent: true });
            } catch (_) {}

            try { updateGigViewPreview(); } catch(_) {}

            const _siglaInput = document.getElementById('switchSiglaFx');
            if (_siglaInput) {
                _siglaInput.addEventListener('input', () => { try { updateGigViewPreview(); } catch(_) {} });
                _siglaInput.addEventListener('change', () => { try { updateGigViewPreview(); } catch(_) {} });
            }
            const _iconNameInput = document.getElementById('switchIconName');
            if (_iconNameInput) {
                _iconNameInput.addEventListener('input', () => { try { updateGigViewPreview(); } catch(_) {} });
                _iconNameInput.addEventListener('change', () => { try { updateGigViewPreview(); } catch(_) {} });
            }

            [
                'switchIconColorValue',
                'switchIconColorOffValue',
                'switchBackColorOnValue',
                'switchBackColorOffValue',
                'switchBorderColorOnValue',
                'switchBorderColorOffValue'
            ].forEach((id) => {
                const el = document.getElementById(id);
                if (!el) return;
                el.addEventListener('change', () => { try { updateGigViewPreview(); } catch(_) {} });
                const obs = new MutationObserver(() => { try { updateGigViewPreview(); } catch(_) {} });
                obs.observe(el, { attributes: true, attributeFilter: ['value'] });
            });

            // ========== END FX ICON PICKER ==========

            initializePage();
        });

    </script>
  </div>
  </body>
  </html>

