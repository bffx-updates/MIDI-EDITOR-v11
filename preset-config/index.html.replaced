                                        <!-- SLOT 1 -->
                                        <input type="text" id="switchSiglaFx" name="switchSiglaFx" maxlength="3" placeholder="FX" style="text-transform: uppercase;" />
                                        <input type="text" id="switchIconName" name="switchIconName" maxlength="8" placeholder="STOMP" style="display:none; text-transform: uppercase;" />
                                        <div class="fx-icon-select" id="fxIconSelect1" style="display:none;">
                                            <button type="button" class="fx-icon-thumb-btn" id="fxIconThumb1" onclick="openIconPicker(1)" aria-label="Selecionar ícone FX">
                                                <canvas id="fxIconCanvas1" width="95" height="72"></canvas>
                                            </button>
                                            <select id="switchIconFx" class="original-select" style="display:none;">
                                                <option value="0">Nenhum (Texto)</option>
