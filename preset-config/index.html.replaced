function getCC_KEMPER_PLAYER_Names(v) {
    switch(v) {
        case 1: return "Wah Pedal";
        case 4: return "Pitch Pedal";
        case 7: return "Volume Pedal";
        case 10: return "Panorama";
        case 11: return "Morph Pedal";

        // Stomps A-D
        case 17: return "Stomp A On/Off";
        case 18: return "Stomp B On/Off";
        case 19: return "Stomp C On/Off";
        case 20: return "Stomp D On/Off";

        // Slot X e MOD
        case 22: return "Effect Slot X On/Off";
        case 24: return "MOD Slot On/Off";

        // Delay e Reverb
        case 26: return "Delay On/Off (Corta Cauda)";
        case 27: return "Delay On/Off (Mantém Cauda)";
        case 28: return "Reverb On/Off (Corta Cauda)";
        case 29: return "Reverb On/Off (Mantém Cauda)";

        case 30: return "Tap Tempo";
        case 31: return "Tuner Select";
        case 33: return "Rotary Speaker Slow/Fast";

        case 34: return "Delay Infinity";

        // PERFORMANCE – Slots
        case 50: return "Carrega Slot 1";
        case 51: return "Carrega Slot 2";
        case 52: return "Carrega Slot 3";
        case 53: return "Carrega Slot 4";
        case 54: return "Carrega Slot 5";

        // Parâmetros contínuos
        case 68: return "Delay Mix";
        case 69: return "Delay Feedback";
        case 70: return "Reverb Mix";
        case 71: return "Reverb Time";
        case 72: return "Gain";
        case 73: return "Monitor Volume";

        case 75: return "Emulate Effect 1";
        case 76: return "Emulate Effect 2";
        case 77: return "Emulate Effect 3";
        case 78: return "Emulate Effect 4";

        case 80: return "Morph Layer 1";
        case 81: return "Looper Start";
        case 82: return "Looper Stop";

        default: return "?";
    }
}

