                    <div class="form-group" id="gigView1Group">
                        <div class="gig-live-row">
                            <div id="gigViewPreviewFrame" class="gig-live-preview-frame" onclick="if(document.getElementById('fxModeToggle' + (window.activeGigSlot || 1))?.dataset.mode==='icon') openIconPicker(window.activeGigSlot || 1)">
                                <canvas id="gigViewPreviewCanvas" class="gig-live-preview-canvas"></canvas>
                            </div>
                            <div class="gig-live-controls">
