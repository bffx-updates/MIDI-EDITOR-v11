                                        <span class="gig-color-title">BORDER</span>
                                        <span class="gig-color-state">OFF - ON</span>
                                    </div>
                                    <div class="gig-color-dots">
                                        <!-- SLOT 1 -->
                                        <div class="custom-color-selector slot1-color">
                                            <div id="selectedBorderColorOffPreview" class="selected-color-preview gig-dot-preview" tabindex="0">
                                                <div id="selectedBorderColorOffPreviewBox" class="selected-color-preview-box"></div>
                                            </div>
                                            <input type="hidden" id="switchBorderColorOffValue" name="switchBorderColorOffValue" value="9">
                                        </div>
                                        <div class="custom-color-selector slot1-color">
                                            <div id="selectedBorderColorOnPreview" class="selected-color-preview gig-dot-preview" tabindex="0">
                                                <div id="selectedBorderColorOnPreviewBox" class="selected-color-preview-box"></div>
                                            </div>
                                            <input type="hidden" id="switchBorderColorOnValue" name="switchBorderColorOnValue" value="9">
                                        </div>
                                        <!-- SLOT 2 -->
                                        <div class="custom-color-selector slot2-color" style="display:none;">
                                            <div id="selectedBorderColorOff2Preview" class="selected-color-preview gig-dot-preview" tabindex="0">
                                                <div id="selectedBorderColorOff2PreviewBox" class="selected-color-preview-box"></div>
                                            </div>
                                            <input type="hidden" id="switchBorderColorOff2Value" name="switchBorderColorOff2Value" value="9">
                                        </div>
                                        <div class="custom-color-selector slot2-color" style="display:none;">
                                            <div id="selectedBorderColorOn2Preview" class="selected-color-preview gig-dot-preview" tabindex="0">
                                                <div id="selectedBorderColorOn2PreviewBox" class="selected-color-preview-box"></div>
                                            </div>
                                            <input type="hidden" id="switchBorderColorOn2Value" name="switchBorderColorOn2Value" value="9">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> <!-- Closes gig-slot-wrapper -->
                <!-- REMOVED gigView2Group as it is now integrated into gigViewSlot1 -->
                <!-- We must add a dummy gigView2Group div so external JS code changing its display doesn't error out -->
                <div id="gigView2Group" style="display:none;"></div>
            </div> <!-- Closes display-config-grid -->
        </div> <!-- Closes display-config-card -->

        <div class="switch-config-area" id="switchConfigArea">
            <div class="form-group" id="switchModeGroup">
                <label for="switchMode">Modo:</label>
                <div class="custom-select-wrapper" data-select-id="switchMode">
                    <div class="custom-select-trigger" tabindex="0">
                        <span class="custom-select-selected-value"></span>
                        <span class="custom-select-arrow-down"></span>
                    </div>
                    <div class="custom-select-options"></div>
                    <select id="switchMode" name="switchMode" class="original-select"></select>
                </div>
            </div>
            <div class="switch-config-grid-led-start">
                <div class="form-group led-group">
                    <label for="switchLedColorValue">LED:</label>
                    <div class="custom-color-selector">
                        <div id="selectedLedColorPreview" class="selected-color-preview" style="width:100%;" tabindex="0">
                                <div id="selectedLedColorPreviewBox" class="selected-color-preview-box"></div>
                        </div>
                        <input type="hidden" id="switchLedColorValue" name="switchLedColorValue">
                    </div>
                </div>
                <div class="form-group start-group-inline">
                    <input type="checkbox" id="switchStart" name="switchStart" style="display:none;">
                    <button type="button" id="startToggleBtn" class="single-toggle-button" aria-pressed="false">INICIAR DESLIGADO</button>
                </div>
            </div>
            <div class="switch-config-grid-cc-ch">
                <div class="form-group" style="flex: 3; min-width: 0;">
                    <label for="switchCC">CC:</label>
                    <div class="custom-select-wrapper" data-select-id="switchCC">
                        <div class="custom-select-trigger" tabindex="0">
                            <span class="custom-select-selected-value"></span>
                            <span class="custom-select-arrow-down"></span>
                        </div>
                        <div class="custom-select-options"></div>
                        <select id="switchCC" name="switchCC" class="original-select"></select>
                    </div>
                </div>
                <div class="form-group ch-group" style="flex: 2; min-width: 0;">
                    <label for="switchChannel">CH:</label>
                    <div class="custom-select-wrapper" data-select-id="switchChannel">
                        <div class="custom-select-trigger" tabindex="0">
                            <span class="custom-select-selected-value"></span>
                            <span class="custom-select-arrow-down"></span>
                        </div>
                        <div class="custom-select-options"></div>
                        <select id="switchChannel" name="switchChannel" class="original-select"></select>
                    </div>
                </div>
            </div>
            <div id="dynamicModeConfigArea" style="display:none; margin-top: 15px;"></div>
        </div>
        
        <!-- Old PC&CC Extras Button container removed. Hidden section remains: -->

        <div id="statusMessage"></div>
    </div>

