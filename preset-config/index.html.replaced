                                        <div id="gigSlotToggleContainer" class="gig-slot-toggle-container" style="display:none;">
                                            <button type="button" id="gigSlotToggleBtn" class="gig-slot-toggle-btn" onclick="toggleGigSlot()">SLOTE 1</button>
                                        </div>
