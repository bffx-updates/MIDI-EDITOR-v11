// Auto-generated from ICONS_BFM3.h
window.BFMIDI_ICONS_WEB = { fmt: "a4", icons: [{"id":1,"w":95,"h":72,"a4":""},{"id":2,"w":95,"h":72,"a4":""},{"id":3,"w":95,"h":72,"a4":""},{"id":4,"w":95,"h":72,"a4":""},{"id":5,"w":95,"h":72,"a4":""},{"id":6,"w":95,"h":72,"a4":""},{"id":7,"w":95,"h":72,"a4":""},{"id":8,"w":95,"h":72,"a4":""},{"id":9,"w":95,"h":72,"a4":""},{"id":10,"w":95,"h":72,"a4":""},{"id":11,"w":95,"h":72,"a4":""},{"id":12,"w":95,"h":72,"a4":""},{"id":13,"w":95,"h":72,"a4":""},{"id":14,"w":95,"h":72,"a4":""},{"id":15,"w":95,"h":72,"a4":""},{"id":16,"w":95,"h":72,"a4":""},{"id":17,"w":95,"h":72,"a4":""},{"id":18,"w":95,"h":72,"a4":""},{"id":19,"w":95,"h":72,"a4":""},{"id":20,"w":95,"h":72,"a4":""},{"id":21,"w":95,"h":72,"a4":""},{"id":22,"w":95,"h":72,"a4":""},{"id":23,"w":95,"h":72,"a4":""},{"id":24,"w":95,"h":72,"a4":""},{"id":25,"w":95,"h":72,"a4":""},{"id":26,"w":95,"h":72,"a4":""},{"id":27,"w":95,"h":72,"a4":""},{"id":28,"w":95,"h":72,"a4":""},{"id":29,"w":95,"h":72,"a4":""},{"id":30,"w":95,"h":72,"a4":""},{"id":31,"w":95,"h":72,"a4":""},{"id":32,"w":95,"h":72,"a4":""},{"id":33,"w":95,"h":72,"a4":""},{"id":34,"w":95,"h":72,"a4":""},{"id":35,"w":95,"h":72,"a4":""},{"id":36,"w":95,"h":72,"a4":""},{"id":37,"w":95,"h":72,"a4":""},{"id":38,"w":95,"h":72,"a4":""},{"id":39,"w":95,"h":72,"a4":""},{"id":40,"w":95,"h":72,"a4":""},{"id":41,"w":95,"h":72,"a4":""},{"id":42,"w":95,"h":72,"a4":""},{"id":43,"w":95,"h":72,"a4":""},{"id":44,"w":95,"h":72,"a4":""},{"id":45,"w":95,"h":72,"a4":""},{"id":46,"w":95,"h":72,"a4":""},{"id":47,"w":95,"h":72,"a4":""},{"id":48,"w":95,"h":72,"a4":""},{"id":49,"w":95,"h":72,"a4":""},{"id":50,"w":95,"h":72,"a4":""},{"id":51,"w":95,"h":72,"a4":""}] };

        document.addEventListener('DOMContentLoaded', () => {
            let suppressModelUpdate = false;
            let isLayerSwitching = false; // Flag para indicar que estamos trocando de layer (evita save duplicado)
            const NUM_PRESET_COLUMNS = 6;
            const NUM_PRESET_ROWS = 5;    // Deve corresponder a PRESET_LEVELS no firmware    
            const TOTAL_PRESETS = NUM_PRESET_COLUMNS * NUM_PRESET_ROWS;
            const TOTAL_LIVE_LAYERS = 2;

            let currentPresetColumnIndex = 0;
            let currentPresetRowIndex = 0;
            let currentSwitchIndex = -1; // -1 = nenhum switch selecionado   
            let currentLiveLayer = 1; // 1 ou 2

            let globalMidiMode = "GLOBAL";
            let advMidiChData = [0,0,0,0,0]; // mode indices for MODO AVANCADO channels
            let advMidiChNumData = [1,2,3,4,5]; // MIDI channel numbers for each row
            const advMidiModeOptions = ["GLOBAL", "AMPERO AS2", "AMPERO MINI", "HX STOMP", "A. STAGE 2", "GP-200LT", "VALETON GP5", "POCKET MASTER", "TONEX", "KEMPER PLAYER", "AMPERO MP350", "MX5", "NANO CORTEX", "QUAD CORTEX", "SYNERGY AMPS", "BigSky", "BlueSky", "TimeLine", "ELCAPISTAN", "FLINT", "HX-ONE", "VTR NARCISO", "VTR LOKI", "VTR KAILANI"];

            window.updateCustomSelect = (id) => {
                const sel = document.getElementById(id);
                if (!sel) return;
                const wrapper = sel.closest('.custom-select-wrapper');
                if (!wrapper) return;
                const sv = wrapper.querySelector('.custom-select-selected-value');
                if (!sv) return;
                const selectedOpt = sel.options[sel.selectedIndex];
                sv.textContent = selectedOpt ? selectedOpt.text : '';
            };
            window.wrapSelect = (originalSelect, id) => {
                const wrapper = document.createElement('div');
                wrapper.className = 'custom-select-wrapper';
                wrapper.dataset.selectId = id;
                const trigger = document.createElement('div');
                trigger.className = 'custom-select-trigger';
                trigger.tabIndex = 0;
                const sv = document.createElement('span');
                sv.className = 'custom-select-selected-value';
                const ar = document.createElement('span');
                ar.className = 'custom-select-arrow-down';
                trigger.appendChild(sv);
                trigger.appendChild(ar);
                const optionsDiv = document.createElement('div');
                optionsDiv.className = 'custom-select-options';
                wrapper.appendChild(trigger);
                wrapper.appendChild(optionsDiv);
                wrapper.appendChild(originalSelect);
                originalSelect.style.display = 'none';
                window.updateCustomSelect(id);
                originalSelect.addEventListener('change', () => {
                    window.updateCustomSelect(id);
                    updateLocalPresetDataFromUI();
                });
                return wrapper;
            };

            // Initialize trigger text for all hardcoded custom-selects
            setTimeout(() => {
                document.querySelectorAll('.custom-select-wrapper select').forEach(sel => {
                    if (sel.id) window.updateCustomSelect(sel.id);
                });
            }, 0);

            // Retorna o modo amigavel efetivo: se MODO AVANCADO, usa item 1 (principal)
            function getEffectiveMidiMode() {
                if (globalMidiMode === "MODO AVANCADO") {
                    const idx = advMidiChData[0] || 0;
                    return advMidiModeOptions[idx] || "GLOBAL";
                }
                return globalMidiMode;
            }

            // Retorna o modo amigavel para um canal MIDI especifico (1-16)
            // Percorre os 5 canais configurados; se encontrar match, retorna aquele modo
            // Se nao encontrar, assume GLOBAL para canais ainda nao mapeados
            function getModeForChannel(channel) {
                if (globalMidiMode !== "MODO AVANCADO") return globalMidiMode;
                const ch = parseInt(channel, 10);
                for (let i = 0; i < 5; i++) {
                    if (advMidiChNumData[i] === ch) {
                        return advMidiModeOptions[advMidiChData[i] || 0] || "GLOBAL";
                    }
                }
                // Fallback: canais sem mapeamento explicito permanecem GLOBAL
                return "GLOBAL";
            }

            // Repopula os selects de CC do switch com labels baseados no canal atual
            // Em MODO AVANCADO, cada canal pode ter um modo amigavel diferente
            function repopulateSwitchCCForChannel() {
                if (globalMidiMode !== "MODO AVANCADO") return;
                const chEl = document.getElementById('switchChannel');
                if (!chEl) return;
                const ch = parseInt(chEl.value, 10);
                const mode = getModeForChannel(ch);
                // Repopula switchCC preservando valor atual
                const ccEl = document.getElementById('switchCC');
                if (ccEl) {
                    const currentCC = parseInt(ccEl.value, 10) || 0;
                    populateNumericSelect('switchCC', 0, 127, currentCC, mode);
                    updateCustomSelect('switchCC');
                }
                // Repopula switchCCHold se existir e estiver visivel
                const ccHoldEl = document.getElementById('switchCCHold');
                if (ccHoldEl && ccHoldEl.closest('.form-group')?.style.display !== 'none') {
                    const currentCCHold = parseInt(ccHoldEl.value, 10) || 0;
                    populateNumericSelect('switchCCHold', 0, 127, currentCCHold, mode);
                    updateCustomSelect('switchCCHold');
                }
            }

            // Repopula o bank/PC select baseado no canal do preset
            function repopulateBankForChannel() {
                if (globalMidiMode !== "MODO AVANCADO") return;
                const chEl = document.getElementById('presetChannelInput');
                if (!chEl) return;
                const ch = parseInt(chEl.value, 10);
                const mode = getModeForChannel(ch);
                const bankSelectId = 'presetBankInput';
                const currentBank = parseInt(document.getElementById(bankSelectId)?.value, 10) || 0;
                if (mode === "GLOBAL" || mode === "MX5" || mode === "NANO CORTEX" || mode === "QUAD CORTEX" || mode === "SYNERGY AMPS" || mode === "VTR NARCISO" || mode === "VTR LOKI" || mode === "VTR KAILANI") {
                    populateNumericSelect(bankSelectId, 0, 299, currentBank, mode);
                } else if (mode === "AMPERO AS2") populateBankLabels(bankSelectId, bank_AS2_Names, currentBank);
                else if (mode === "HX STOMP") populateBankLabels(bankSelectId, bank_HX_STOMP_Names, currentBank);
                else if (mode === "AMPERO MINI") populateBankLabels(bankSelectId, bank_AMPERO_MINI_Names, currentBank);
                else if (mode === "A. STAGE 2") populateBankLabels(bankSelectId, bank_ASTG2_Names, currentBank);
                else if (mode === "GP-200LT") populateBankLabels(bankSelectId, bank_GP200LT_Names, currentBank);
                else if (mode === "VALETON GP5") populateBankLabels(bankSelectId, bank_VALETON_GP5_Names, currentBank);
                else if (mode === "POCKET MASTER") populateBankLabels(bankSelectId, bank_POCKET_MASTER_Names, currentBank);
                else if (mode === "KEMPER PLAYER") populateBankLabels(bankSelectId, bank_KEMPER_PLAYER_Names, currentBank);
                else if (mode === "TONEX") populateBankLabels(bankSelectId, bank_TONEX_Names, currentBank);
                else if (mode === "AMPERO MP350") populateBankLabels(bankSelectId, bank_AMPERO_MP350_Names, currentBank);
                else if (mode === "BigSky") populateBankLabels(bankSelectId, bank_BIGSKY_Names, currentBank);
                else if (mode === "BlueSky") populateBankLabels(bankSelectId, bank_BLUESKY_Names, currentBank);
                else if (mode === "TimeLine") populateBankLabels(bankSelectId, bank_TIMELINE_Names, currentBank);
                else populateNumericSelect(bankSelectId, 0, 299, currentBank, mode);
                updateCustomSelect(bankSelectId);
            }

            let kemperGetNamesEnabled = false;
            let currentKemperRigName = "";
            let lastAutoFilledKemperRigName = "";
            let kemperRigNamePollTimer = null;
            let presetNameIsAutoManaged = true;

            // Cores globais do LIVE MODE (1 e 2), vindas da GLOBAL_CONFIG
            let liveModeColorLayer1 = 0xFFFFFF;
            let liveModeColorLayer2 = 0xFFFFFF;
            let liveLayer2Enabled = true; // Se false, oculta Layer 2

            let presetClipboard = null;

            let globalFaderWrap = null;
            let globalFaderRange = null;
            let activeKnobSelectId = null;
            let activeKnobProgressEl = null;
            const TRANSPARENT_COLOR_INDEX = 255;
            const DIRECT_COLOR_TRANSPARENT = 0xFFFFFFFF;
            const TRANSPARENT_SWATCH_CSS = 'linear-gradient(45deg, rgba(255,255,255,0.14) 25%, rgba(255,255,255,0.03) 25%, rgba(255,255,255,0.03) 50%, rgba(255,255,255,0.14) 50%, rgba(255,255,255,0.14) 75%, rgba(255,255,255,0.03) 75%, rgba(255,255,255,0.03) 100%)';
            const TRANSPARENT_COLOR_WEB = {
                name: "Sem Cor",
                value: 0x000000,
                actualIndex: TRANSPARENT_COLOR_INDEX,
                storedValue: TRANSPARENT_COLOR_INDEX,
                swatchCss: TRANSPARENT_SWATCH_CSS,
                previewCss: TRANSPARENT_SWATCH_CSS
            };

            const PERFIS_CORES_LED_WEB = [
                { name: "Vermelho",   value: 0xFF0000 },   // 0
                { name: "Verde",      value: 0x00FF00 },   // 1
                { name: "Azul",       value: 0x0000FF },   // 2
                { name: "Amarelo",    value: 0xFFFF00 },   // 3
                { name: "Roxo",       value: 0x800080 },   // 4
                { name: "Ciano",      value: 0x00FFFF },   // 5
                { name: "Branco",     value: 0xFFFFFF },   // 6
                { name: "Laranja",    value: 0xFF5000 },   // 7
                { name: "Magenta",    value: 0xFF0080 },   // 8
                { name: "Coral",      value: 0xFF1414 },   // 9
                { name: "Azul Celeste", value: 0x0096FF }, // 10
                { name: "Violeta",    value: 0xB400FF },   // 11
                { name: "Rosa",       value: 0xFF64C8 },   // 12
                { name: "Menta",      value: 0x32FF64 },   // 13
                { name: "Preto",      value: 0x000000 }    // 14
            ];

            const PRESET_GRADIENT_RED = 0x01000001;
            const PRESET_GRADIENT_PURPLE = 0x01000002;
            const PRESET_GRADIENT_BLUE = 0x01000003;
            const PRESET_GRADIENT_GREEN = 0x01000004;
            const PRESET_GRADIENT_SUNSET_H = 0x01000005;
            const PRESET_GRADIENT_OCEAN_H = 0x01000006;
            const PRESET_GRADIENT_LIME_H = 0x01000007;
            const PRESET_GRADIENT_FIRE_D1 = 0x01000008;
            const PRESET_GRADIENT_ICE_D1 = 0x01000009;
            const PRESET_GRADIENT_CANDY_D2 = 0x0100000A;
            const PRESET_GRADIENT_NEON_D1 = 0x0100000B;
            const PRESET_GRADIENT_STEEL_V = 0x0100000C;
            const PRESET_GRADIENT_AURORA_V = 0x0100000D;
            const PRESET_GRADIENT_EMBER_H = 0x0100000E;
            const PRESET_GRADIENT_SKY_D2 = 0x0100000F;
            const PRESET_GRADIENT_BERRY_D1 = 0x01000010;
            const PRESET_GRADIENT_TOXIC_H = 0x01000011;
            const PRESET_GRADIENT_GOLD_V = 0x01000012;
            const PRESET_GRADIENT_AQUA_D1 = 0x01000013;
            const PRESET_GRADIENT_GRAPE_H = 0x01000014;
            const PRESET_GRADIENT_LAVA_V = 0x01000015;
            const PRESET_GRADIENT_FLORESTA_H = 0x01000016;
            const PRESET_GRADIENT_AMETISTA_D1 = 0x01000017;
            const PRESET_GRADIENT_POR_DO_SOL_V = 0x01000018;
            const PRESET_GRADIENT_OCEANO_PROFUNDO_D1 = 0x01000019;
            const PRESET_GRADIENT_FLAMINGO_H = 0x0100001A;
            const PRESET_GRADIENT_NOITE_V = 0x0100001B;
            const PRESET_GRADIENT_COBRE_H = 0x0100001C;
            const PRESET_CUSTOM_GRADIENT_BASE = 0x01000100;

            function makeSection(title) {
                return { type: 'section', title };
            }

            function makeGradientSwatch(name, value, actualIndex, storedValue, swatchCss, previewCss = swatchCss) {
                return {
                    name,
                    value,
                    actualIndex,
                    storedValue,
                    swatchCss,
                    previewCss
                };
            }

            function makeBlackCoreGradientSwatch(name, value, actualIndex, storedValue) {
                return makeGradientSwatch(
                    name,
                    value,
                    actualIndex,
                    storedValue,
                    `linear-gradient(180deg, #000000 0%, #${value.toString(16).padStart(6, '0')} 48%, #000000 100%)`
                );
            }

            function buildCustomPresetGradientValue(baseIndex) {
                return PRESET_CUSTOM_GRADIENT_BASE + baseIndex;
            }

            
            const SOLID_COLORS_WEB = [
                // Row 1 - Neutros
                { name: "Preto",          value: 0x000000 }, // 0
                { name: "Cinza Escuro",   value: 0x555555 }, // 1
                { name: "Cinza Claro",    value: 0xAAAAAA }, // 2
                { name: "Branco",         value: 0xFFFFFF }, // 3
                // Row 2 - Amarelos/Oliva
                { name: "Oliva Escuro",   value: 0x666600 }, // 4
                { name: "Oliva",          value: 0xAAAA00 }, // 5
                { name: "Amarelo",        value: 0xFFFF00 }, // 6
                { name: "Amarelo Claro",  value: 0xFFFF88 }, // 7
                // Row 3 - Laranjas/Marrons
                { name: "Marrom",         value: 0x8B4513 }, // 8
                { name: "Ocre",           value: 0xD2691E }, // 9
                { name: "Laranja",        value: 0xFF8C00 }, // 10
                { name: "Pêssego",        value: 0xFFDAB9 }, // 11
                // Row 4 - Vermelhos
                { name: "Bordô",          value: 0x800000 }, // 12
                { name: "Vermelho Escuro",value: 0xCC0000 }, // 13
                { name: "Vermelho",       value: 0xFF0000 }, // 14
                { name: "Salmão",         value: 0xFA8072 }, // 15
                // Row 5 - Rosas/Magenta
                { name: "Púrpura",        value: 0x800080 }, // 16
                { name: "Magenta Escura", value: 0xCC00CC }, // 17
                { name: "Magenta",        value: 0xFF00FF }, // 18
                { name: "Rosa Claro",     value: 0xFFB6C1 }, // 19
                // Row 6 - Roxos
                { name: "Índigo",         value: 0x4B0082 }, // 20
                { name: "Roxo",           value: 0x8A2BE2 }, // 21
                { name: "Violeta",        value: 0x9932CC }, // 22
                { name: "Lilás",          value: 0xDDA0DD }, // 23
                // Row 7 - Azuis
                { name: "Azul Marinho",   value: 0x000080 }, // 24
                { name: "Azul Escuro",    value: 0x0000CC }, // 25
                { name: "Azul",           value: 0x0000FF }, // 26
                { name: "Azul Claro",     value: 0x87CEFA }, // 27
                // Row 8 - Verdes
                { name: "Verde Escuro",   value: 0x006400 }, // 28
                { name: "Verde Médio",    value: 0x00A000 }, // 29
                { name: "Verde",          value: 0x00FF00 }, // 30
                { name: "Verde Claro",    value: 0x98FB98 }  // 31
            ];

            // Mapeamento: posição i → índice firmware 86+i (WEB_PRETO..WEB_VERDE_CLA)
            const SOLID_TO_PERFIS_MAP = Array.from({ length: 32 }, (_, i) => i + 86);
            // Gradientes preto-cor: índices 118+i → firmware usa PERFIS_CORES[86+i]
            const CUSTOM_BLACK_GRADIENT_INDEXES = Array.from({ length: 32 }, (_, i) => i + 118);

            const GRADIENT1_BASE = 0x02000000;
            const GRADIENT2_BASE = 0x03000000;
            const GRADIENT3_BASE = 0x04000000;

            const GRADIENT1_COLORS_WEB = SOLID_COLORS_WEB.map((col, i) => {
                const hex = '#' + col.value.toString(16).padStart(6, '0');
                const gradCss = `linear-gradient(180deg, rgba(255,255,255,0.4) 0%, transparent 40%, rgba(0,0,0,0.4) 100%), ${hex}`;
                return makeGradientSwatch('G1 ' + col.name, col.value, 150 + i, GRADIENT1_BASE | col.value, gradCss, gradCss);
            });

            const GRADIENT2_COLORS_WEB = SOLID_COLORS_WEB.map((col, i) => {
                const hex = '#' + col.value.toString(16).padStart(6, '0');
                const gradCss = `radial-gradient(ellipse at 50% 10%, rgba(255,255,255,0.6) 0%, transparent 60%), linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.5) 100%), ${hex}`;
                return makeGradientSwatch('G2 ' + col.name, col.value, 200 + i, GRADIENT2_BASE | col.value, gradCss, gradCss);
            });

            const CUSTOM_COLORS_WEB = SOLID_COLORS_WEB.map((col, i) => {
                const hex = '#' + col.value.toString(16).padStart(6, '0');
                const gradCss = `linear-gradient(180deg, #000000 0%, ${hex} 48%, #000000 100%)`;
                return makeGradientSwatch('Custom ' + col.name, col.value, 118 + i, GRADIENT3_BASE | col.value, gradCss, gradCss);
            });


            const MIX_FORMAT_GRADIENTS_WEB = [

                // Row 1 - Fogo/Vermelho
                makeGradientSwatch("Sunset Horizontal", 0xFF7846, 27, PRESET_GRADIENT_SUNSET_H, "linear-gradient(90deg, #ff2d55 0%, #ffb347 52%, #ff6a00 100%)"),
                makeGradientSwatch("Fire Diagonal", 0xFF5A00, 30, PRESET_GRADIENT_FIRE_D1, "linear-gradient(135deg, #3b0000 0%, #ff4d00 52%, #ffd000 100%)"),
                makeGradientSwatch("Ember Horizontal", 0xFF5A2A, 55, PRESET_GRADIENT_EMBER_H, "linear-gradient(90deg, #4a0900 0%, #ff5a2a 52%, #ffd26a 100%)"),
                makeGradientSwatch("Lava Vertical", 0xFF3C00, 78, PRESET_GRADIENT_LAVA_V, "linear-gradient(180deg, #3b0000 0%, #ff3c00 48%, #ffd000 100%)"),
                // Row 2 - Rosa/Quente
                makeGradientSwatch("Berry Diagonal", 0xFF4B8D, 57, PRESET_GRADIENT_BERRY_D1, "linear-gradient(135deg, #32002b 0%, #ff4b8d 52%, #ffd0ef 100%)"),
                makeGradientSwatch("Flamingo Horizontal", 0xFF6E96, 83, PRESET_GRADIENT_FLAMINGO_H, "linear-gradient(90deg, #5a0020 0%, #ff6e96 52%, #ffd0e0 100%)"),
                makeGradientSwatch("Candy Diagonal", 0xFF50B4, 32, PRESET_GRADIENT_CANDY_D2, "linear-gradient(45deg, #7a00ff 0%, #ff4fb3 52%, #ffd1f0 100%)"),
                makeGradientSwatch("Pôr do Sol Vertical", 0xFF7832, 81, PRESET_GRADIENT_POR_DO_SOL_V, "linear-gradient(180deg, #4a0500 0%, #ff7832 48%, #ffe0a0 100%)"),
                // Row 3 - Ouro/Terra
                makeGradientSwatch("Gold Vertical", 0xFFC247, 59, PRESET_GRADIENT_GOLD_V, "linear-gradient(180deg, #5a3900 0%, #ffc247 48%, #fff2b0 100%)"),
                makeGradientSwatch("Cobre Horizontal", 0xC87832, 85, PRESET_GRADIENT_COBRE_H, "linear-gradient(90deg, #3a1800 0%, #c87832 52%, #ffd0a0 100%)"),
                makeGradientSwatch("Steel Vertical", 0xA5B0C4, 34, PRESET_GRADIENT_STEEL_V, "linear-gradient(180deg, #454b57 0%, #a5b0c4 48%, #edf3ff 100%)"),
                makeGradientSwatch("Noite Vertical", 0x191970, 84, PRESET_GRADIENT_NOITE_V, "linear-gradient(180deg, #000010 0%, #191970 48%, #6080c0 100%)"),
                // Row 4 - Verde
                makeGradientSwatch("Lima Horizontal", 0xA0FF00, 29, PRESET_GRADIENT_LIME_H, "linear-gradient(90deg, #355c00 0%, #a0ff00 52%, #efff7a 100%)"),
                makeGradientSwatch("Toxic Horizontal", 0x76FF03, 58, PRESET_GRADIENT_TOXIC_H, "linear-gradient(90deg, #142400 0%, #76ff03 52%, #00e5a8 100%)"),
                makeGradientSwatch("Aurora Vertical", 0x44FFB0, 54, PRESET_GRADIENT_AURORA_V, "linear-gradient(180deg, #004225 0%, #44ffb0 52%, #d7fff4 100%)"),
                makeGradientSwatch("Floresta Horizontal", 0x00B43C, 79, PRESET_GRADIENT_FLORESTA_H, "linear-gradient(90deg, #002200 0%, #00b43c 52%, #a0ff00 100%)"),
                // Row 5 - Ciano/Agua
                makeGradientSwatch("Neon Diagonal", 0x00FFB4, 33, PRESET_GRADIENT_NEON_D1, "linear-gradient(135deg, #001b2e 0%, #00ffb4 52%, #c8ff00 100%)"),
                makeGradientSwatch("Aqua Diagonal", 0x00D8FF, 60, PRESET_GRADIENT_AQUA_D1, "linear-gradient(135deg, #003a46 0%, #00d8ff 52%, #ddfeff 100%)"),
                makeGradientSwatch("Ice Diagonal", 0x78F0FF, 31, PRESET_GRADIENT_ICE_D1, "linear-gradient(135deg, #102a5c 0%, #63d8ff 52%, #dfffff 100%)"),
                makeGradientSwatch("Ocean Horizontal", 0x00B4FF, 28, PRESET_GRADIENT_OCEAN_H, "linear-gradient(90deg, #003b8e 0%, #00c6ff 52%, #7cf7ff 100%)"),
                // Row 6 - Azul/Roxo
                makeGradientSwatch("Sky Diagonal", 0x62BEFF, 56, PRESET_GRADIENT_SKY_D2, "linear-gradient(45deg, #11224f 0%, #62beff 52%, #eef9ff 100%)"),
                makeGradientSwatch("Oceano Profundo Diagonal", 0x0050A0, 82, PRESET_GRADIENT_OCEANO_PROFUNDO_D1, "linear-gradient(135deg, #000a28 0%, #0050a0 52%, #60c0ff 100%)"),
                makeGradientSwatch("Grape Horizontal", 0x9B4DFF, 61, PRESET_GRADIENT_GRAPE_H, "linear-gradient(90deg, #22003a 0%, #9b4dff 52%, #f3b7ff 100%)"),
                makeGradientSwatch("Ametista Diagonal", 0x823CFF, 80, PRESET_GRADIENT_AMETISTA_D1, "linear-gradient(135deg, #1a0040 0%, #823cff 52%, #d4b0ff 100%)")
            ];

            // Cores sólidas originais do firmware (usadas pelo preview de LED e compatibilidade)
            const FIRMWARE_SOLID_BASE_WEB = [
                { name: "Vermelho",    value: 0xFF0000 }, // 0
                { name: "Verde",       value: 0x00FF00 }, // 1
                { name: "Azul",        value: 0x0000FF }, // 2
                { name: "Amarelo",     value: 0xFFFF00 }, // 3
                { name: "Roxo",        value: 0x800080 }, // 4
                { name: "Ciano",       value: 0x00FFFF }, // 5
                { name: "Branco",      value: 0xFFFFFF }, // 6
                { name: "Laranja",     value: 0xFF5000 }, // 7
                { name: "Magenta",     value: 0xFF0080 }, // 8
                { name: "Coral",       value: 0xFF1414 }, // 9
                { name: "Azul Celeste",value: 0x0096FF }, // 10
                { name: "Violeta",     value: 0xB400FF }, // 11
                { name: "Rosa",        value: 0xFF64C8 }, // 12
                { name: "Menta",       value: 0x32FF64 }, // 13
                { name: "Preto",       value: 0x000000 }, // 14
                { name: "Lilás",       value: 0xD6AAFF }, // 15
                { name: "Rosê",        value: 0xFFAAD2 }, // 16
                { name: "Prata",       value: 0xD6E0EC }, // 17
                { name: "Royal",       value: 0x285CDC }, // 18
                { name: "Âmbar",       value: 0xFFAA28 }, // 19
                { name: "Lima",        value: 0x8ADE4A }, // 20
                { name: "Turquesa",    value: 0x34C6FF }, // 21
                { name: "Petróleo",    value: 0x0098A8 }  // 22
            ];
            const FIRMWARE_SOLID_EXT_WEB = [
                { index: 62, name: "Ouro",       value: 0xFFD700 },
                { index: 63, name: "Salmão",     value: 0xFF6B6B },
                { index: 64, name: "Lavanda",    value: 0xB48EFF },
                { index: 65, name: "Índigo",     value: 0x4B0082 },
                { index: 66, name: "Pêssego",    value: 0xFFBB98 },
                { index: 67, name: "Marfim",     value: 0xFFF0D0 },
                { index: 68, name: "Oliva",      value: 0x6B8E23 },
                { index: 69, name: "Chocolate",  value: 0xD2691E }
            ];

            const PERFIS_CORES_WEB = Array(256).fill(null);
            // 1. Baseline: cores sólidas originais do firmware (para preview de LED e legado)
            FIRMWARE_SOLID_BASE_WEB.forEach((col, i) => {
                PERFIS_CORES_WEB[i] = { ...col, actualIndex: i, storedValue: col.value };
            });
            FIRMWARE_SOLID_EXT_WEB.forEach(({ index, name, value }) => {
                PERFIS_CORES_WEB[index] = { name, value, actualIndex: index, storedValue: value };
            });
            // 2. Gradientes primeiro (índices espalhados, incluindo 27-31)
            MIX_FORMAT_GRADIENTS_WEB.forEach((color) => {
                PERFIS_CORES_WEB[color.actualIndex] = color;
            });
            GRADIENT1_COLORS_WEB.forEach((color) => {
                PERFIS_CORES_WEB[color.actualIndex] = color;
            });
            GRADIENT2_COLORS_WEB.forEach((color) => {
                PERFIS_CORES_WEB[color.actualIndex] = color;
            });
            CUSTOM_COLORS_WEB.forEach((color) => {
                PERFIS_CORES_WEB[color.actualIndex] = color;
            });
            // Sólidos por último — sobrescrevem índices 0-31 (ganham sobre MIX nos índices 27-31)
            SOLID_COLORS_WEB.forEach((col, i) => {
                const idx = SOLID_TO_PERFIS_MAP[i];
                PERFIS_CORES_WEB[idx] = { ...col, actualIndex: idx, storedValue: col.value };
            });
            // Custom preto-cor por último — sobrescrevem índices 32-63
            SOLID_COLORS_WEB.forEach((color, i) => {
                const custIdx = CUSTOM_BLACK_GRADIENT_INDEXES[i];
                PERFIS_CORES_WEB[custIdx] = makeBlackCoreGradientSwatch(
                    `Custom ${color.name}`, color.value, custIdx, color.value
                );
            });

            function paletteColor(index) {
                const color = PERFIS_CORES_WEB[index];
                return color ? { ...color, actualIndex: index } : null;
            }

            const SOLID_CHOOSER_COLORS_WEB = [
                makeSection("SOLID COLORS"),
                ...SOLID_TO_PERFIS_MAP.map(index => paletteColor(index))
            ];

            const CUSTOM_CHOOSER_COLORS_WEB = [
                makeSection("CUSTOM"),
                ...CUSTOM_BLACK_GRADIENT_INDEXES.map(index => paletteColor(index))
            ];

            const MIX_FORMAT_CHOOSER_COLORS_WEB = [
                makeSection("MIX & FORMAT"),
                ...MIX_FORMAT_GRADIENTS_WEB.map(color => paletteColor(color.actualIndex))
            ];

            const EXPANDED_CHOOSER_COLORS_WEB = [
                makeSection("TRANSPARÊNCIA"),
                TRANSPARENT_COLOR_WEB,
                ...SOLID_CHOOSER_COLORS_WEB,
                ...CUSTOM_CHOOSER_COLORS_WEB,
                ...MIX_FORMAT_CHOOSER_COLORS_WEB
            ].filter(Boolean);

            const PRESET_DIRECT_COLORS_WEB = [
                makeSection("TRANSPARÊNCIA"),
                { ...TRANSPARENT_COLOR_WEB, storedValue: DIRECT_COLOR_TRANSPARENT },
                makeSection("SOLID COLORS"),
                ...SOLID_COLORS_WEB.map((col, i) => ({ ...col, actualIndex: SOLID_TO_PERFIS_MAP[i], storedValue: col.value })),
                makeSection("GRADIENT 1"),
                ...GRADIENT1_COLORS_WEB,
                makeSection("GRADIENT 2"),
                ...GRADIENT2_COLORS_WEB,
                makeSection("CUSTOM"),
                ...CUSTOM_COLORS_WEB,
                makeSection("MISCELÂNEAS"),
                ...MIX_FORMAT_GRADIENTS_WEB
            ];

            function getLegacyDirectGradientPreview(colorValue) {
                switch (colorValue) {
                    case PRESET_GRADIENT_RED:
                        return makeBlackCoreGradientSwatch("Custom Vermelho", 0xFF0000, 23, colorValue);
                    case PRESET_GRADIENT_PURPLE:
                        return makeBlackCoreGradientSwatch("Custom Roxo", 0x800080, 24, colorValue);
                    case PRESET_GRADIENT_BLUE:
                        return makeBlackCoreGradientSwatch("Custom Azul", 0x0000FF, 25, colorValue);
                    case PRESET_GRADIENT_GREEN:
                        return makeBlackCoreGradientSwatch("Custom Verde", 0x00FF00, 26, colorValue);
                    default:
                        return null;
                }
            }

            function getPaletteColorByValue(palette, colorValue) {
                if (!Array.isArray(palette)) return colorValue;
                const foundColor = palette.find(color =>
                    color && ((color.storedValue !== undefined ? color.storedValue : color.value) === colorValue)
                );
                if (foundColor) return foundColor;
                if (palette === PRESET_DIRECT_COLORS_WEB) {
                    return getLegacyDirectGradientPreview(colorValue) || colorValue;
                }
                return colorValue;
            }

            function getColorHex(colorRef) {
                const colorValue = (colorRef && typeof colorRef === 'object') ? colorRef.value : colorRef;
                const safeValue = (typeof colorValue === 'number') ? colorValue : 0x000000;
                return `#${safeValue.toString(16).padStart(6, '0')}`;
            }

            function isTransparentColorRef(colorRef) {
                if (colorRef && typeof colorRef === 'object') {
                    return colorRef.actualIndex === TRANSPARENT_COLOR_INDEX
                        || colorRef.storedValue === DIRECT_COLOR_TRANSPARENT;
                }
                return colorRef === TRANSPARENT_COLOR_INDEX || colorRef === DIRECT_COLOR_TRANSPARENT;
            }

            function getColorPreviewCss(colorRef, variant = 'bar') {
                if (isTransparentColorRef(colorRef)) {
                    return TRANSPARENT_SWATCH_CSS;
                }
                if (colorRef && typeof colorRef === 'object' && colorRef.previewCss) {
                    return colorRef.previewCss;
                }
                const hex = getColorHex(colorRef);
                return variant === 'dot'
                    ? 'none'
                    : `linear-gradient(to right, black 2%, ${hex} 50%, black 98%)`;
            }

            function applyColorPreview(box, colorRef, variant = 'bar') {
                if (!box) return;
                const hex = getColorHex(colorRef);
                box.style.backgroundColor = isTransparentColorRef(colorRef) ? 'transparent' : hex;
                box.style.backgroundImage = getColorPreviewCss(colorRef, variant);
            }

            // Base de API robusta: tenta origem atual, mDNS e IP do AP
            const API_CANDIDATES = [];
            try {
                if (location && typeof location.origin === 'string' && location.origin.startsWith('http')) {
                    API_CANDIDATES.push(location.origin);
                }
            } catch (_) {}
            API_CANDIDATES.push('http://192.168.4.1');

            function ensurePath(path) {
                if (!path) return '/';
                return path.startsWith('/') ? path : ('/' + path);
            }

            async function apiFetch(path, options) {
                const p = ensurePath(path);
                let lastError = null;
                for (const base of API_CANDIDATES) {
                    try {
                        const res = await fetch(base + p, options);
                        if (res && (res.ok || res.status === 202)) return res;
                        lastError = new Error('HTTP ' + res.status + ' em ' + base + p);
                    } catch (e) {
                        lastError = e;
                    }
                }
                throw lastError || new Error('Falha de rede em ' + p);
            }

            function toggleFooterOptions() {
                const footerMain = document.getElementById('footer-main');
                const footerCopyPaste = document.getElementById('footer-copy-paste');
                footerMain.classList.toggle('hidden');
                footerCopyPaste.classList.toggle('hidden');
            }

            function persistPresetClipboard() {
                try {
                    localStorage.setItem('bfmidiPresetClipboard', JSON.stringify(presetClipboard));
                    document.getElementById('btnColar').disabled = false;
                } catch (_) {}
            }

            function handleCopyLayer1() {
                const globalIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const defaultPreset = getSingleDefaultPresetData(currentPresetColumnIndex, currentPresetRowIndex);
                const layer1Data = allPresetsData[0][globalIndex] || defaultPreset;

                presetClipboard = {
                    layer1: JSON.parse(JSON.stringify(layer1Data)),
                    hasLayer2: false,
                    copyMode: 'layer1',
                    copyVersion: 2
                };

                document.getElementById('statusMessage').textContent =
                    `Preset ${String.fromCharCode(65 + currentPresetRowIndex)}${currentPresetColumnIndex + 1} copiado (Layer 1)!`;
                persistPresetClipboard();
                try { showCopyPasteBanner('COPIADO'); } catch (_) {}
                toggleFooterOptions();
            }

            function handleCopyLayer2() {
                const globalIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const defaultPreset = getSingleDefaultPresetData(currentPresetColumnIndex, currentPresetRowIndex);
                const layer2Data = allPresetsData[1][globalIndex] || defaultPreset;

                presetClipboard = {
                    layer2: JSON.parse(JSON.stringify(layer2Data)),
                    hasLayer2: true,
                    copyMode: 'layer2',
                    copyVersion: 2
                };

                document.getElementById('statusMessage').textContent =
                    `Preset ${String.fromCharCode(65 + currentPresetRowIndex)}${currentPresetColumnIndex + 1} copiado (Layer 2)!`;
                persistPresetClipboard();
                try { showCopyPasteBanner('COPIADO'); } catch (_) {}
                toggleFooterOptions();
            }

            function handleCopyPreset() {
                const globalIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const defaultPreset = getSingleDefaultPresetData(currentPresetColumnIndex, currentPresetRowIndex);
                const layer1Data = allPresetsData[0][globalIndex] || defaultPreset;
                const layer2Data = allPresetsData[1][globalIndex] || defaultPreset;

                presetClipboard = {
                    layer1: JSON.parse(JSON.stringify(layer1Data)),
                    layer2: JSON.parse(JSON.stringify(layer2Data)),
                    hasLayer2: true,
                    copyMode: 'preset',
                    copyVersion: 2
                };

                document.getElementById('statusMessage').textContent =
                    `Preset ${String.fromCharCode(65 + currentPresetRowIndex)}${currentPresetColumnIndex + 1} copiado (Preset completo)!`;
                persistPresetClipboard();
                try { showCopyPasteBanner('COPIADO'); } catch (_) {}
                toggleFooterOptions();
            }

            function handlePaste() {
                if (!presetClipboard) {
                    try {
                        const st = localStorage.getItem('bfmidiPresetClipboard');
                        if (st) presetClipboard = JSON.parse(st);
                    } catch (_) {}
                }
                if (!presetClipboard) return;

                const col = currentPresetColumnIndex;
                const row = currentPresetRowIndex;
                const globalIndex = col * NUM_PRESET_ROWS + row;
                const defaultPreset = getSingleDefaultPresetData(col, row);

                // Verificar se o clipboard tem o formato novo (com layer1/layer2) ou antigo
                const isNewFormat = presetClipboard.hasLayer2 !== undefined;

                if (isNewFormat) {
                    let clipMode = presetClipboard.copyMode || (presetClipboard.layer2 ? 'preset' : 'layer1');
                    // Compatibilidade com clipboard antigo da fase anterior (layer2 = ambos os layers).
                    if (
                        clipMode === 'layer2' &&
                        presetClipboard.layer1 &&
                        presetClipboard.layer2 &&
                        !presetClipboard.copyVersion
                    ) {
                        clipMode = 'preset';
                    }

                    if (clipMode === 'preset') {
                        const originalNameLayer1 = allPresetsData[0][globalIndex]?.nomePreset || defaultPreset.nomePreset;
                        const originalFontLayer1 = allPresetsData[0][globalIndex]?.nomePresetFont || defaultPreset.nomePresetFont;
                        const layer1Source = presetClipboard.layer1 || defaultPreset;
                        allPresetsData[0][globalIndex] = JSON.parse(JSON.stringify(layer1Source));
                        allPresetsData[0][globalIndex].nomePreset = originalNameLayer1;
                        allPresetsData[0][globalIndex].nomePresetFont = originalFontLayer1;

                        const originalNameLayer2 = allPresetsData[1][globalIndex]?.nomePreset || defaultPreset.nomePreset;
                        const originalFontLayer2 = allPresetsData[1][globalIndex]?.nomePresetFont || defaultPreset.nomePresetFont;
                        const layer2Source = presetClipboard.layer2 || defaultPreset;
                        allPresetsData[1][globalIndex] = JSON.parse(JSON.stringify(layer2Source));
                        allPresetsData[1][globalIndex].nomePreset = originalNameLayer2;
                        allPresetsData[1][globalIndex].nomePresetFont = originalFontLayer2;
                    } else if (clipMode === 'layer2') {
                        const originalNameLayer2 = allPresetsData[1][globalIndex]?.nomePreset || defaultPreset.nomePreset;
                        const originalFontLayer2 = allPresetsData[1][globalIndex]?.nomePresetFont || defaultPreset.nomePresetFont;
                        const layer2Source = presetClipboard.layer2 || presetClipboard.layer1 || defaultPreset;
                        allPresetsData[1][globalIndex] = JSON.parse(JSON.stringify(layer2Source));
                        allPresetsData[1][globalIndex].nomePreset = originalNameLayer2;
                        allPresetsData[1][globalIndex].nomePresetFont = originalFontLayer2;
                    } else {
                        const originalNameLayer1 = allPresetsData[0][globalIndex]?.nomePreset || defaultPreset.nomePreset;
                        const originalFontLayer1 = allPresetsData[0][globalIndex]?.nomePresetFont || defaultPreset.nomePresetFont;
                        const layer1Source = presetClipboard.layer1 || defaultPreset;
                        allPresetsData[0][globalIndex] = JSON.parse(JSON.stringify(layer1Source));
                        allPresetsData[0][globalIndex].nomePreset = originalNameLayer1;
                        allPresetsData[0][globalIndex].nomePresetFont = originalFontLayer1;
                    }
                } else {
                    // Formato antigo (compatibilidade): colar apenas no layer atual
                    const layerIdx = currentLiveLayer - 1;
                    const originalName = allPresetsData[layerIdx][globalIndex]?.nomePreset || defaultPreset.nomePreset;
                    const originalFont = allPresetsData[layerIdx][globalIndex]?.nomePresetFont || defaultPreset.nomePresetFont;
                    allPresetsData[layerIdx][globalIndex] = JSON.parse(JSON.stringify(presetClipboard));
                    allPresetsData[layerIdx][globalIndex].nomePreset = originalName;
                    allPresetsData[layerIdx][globalIndex].nomePresetFont = originalFont;
                }

                // Atualizar UI
                loadPresetDataToUI(col, row);
                if (currentSwitchIndex >= 0) {
                    loadSwitchDataToUI(col, row, currentSwitchIndex);
                }
                const pcCcGrid = document.getElementById('extrasPcCcSection')?.querySelector('.extras-grid');
                const layerIdx = currentLiveLayer - 1;
                if (pcCcGrid && allPresetsData[layerIdx][globalIndex]?.extras?.pc) {
                    generatePcCcFields(pcCcGrid, allPresetsData[layerIdx][globalIndex].extras);
                }
                updateAllFootButtonsUI();
                initCustomSelects();

                let layersMsg = '';
                if (isNewFormat) {
                    let clipMode = presetClipboard.copyMode || (presetClipboard.layer2 ? 'preset' : 'layer1');
                    if (
                        clipMode === 'layer2' &&
                        presetClipboard.layer1 &&
                        presetClipboard.layer2 &&
                        !presetClipboard.copyVersion
                    ) {
                        clipMode = 'preset';
                    }
                    if (clipMode === 'preset') layersMsg = ' (Preset completo)';
                    else if (clipMode === 'layer2') layersMsg = ' (Layer 2)';
                    else layersMsg = ' (Layer 1)';
                }
                document.getElementById('statusMessage').textContent = `Preset colado em ${String.fromCharCode(65 + row)}${col + 1}${layersMsg}!`;
                try { schedulePresetAutoSave(120); } catch (_) {}
                try { showCopyPasteBanner('COLADO'); } catch (_) {}
                toggleFooterOptions();
            }

            // Expose footer handlers globally for inline onclick attributes
            window.toggleFooterOptions = toggleFooterOptions;
            window.handleCopy = handleCopyPreset;
            window.handleCopyLayer1 = handleCopyLayer1;
            window.handleCopyLayer2 = handleCopyLayer2;
            window.handleCopyPreset = handleCopyPreset;
            window.handlePaste = handlePaste;

            const MODE_OPTIONS_WEB = [
                { value: 99, text: "MUTE" },
                { value: 0, text: "STOMP" },
                { value: 1, text: "SPIN" },
                { value: 2, text: "SPIN" },
                { value: 3, text: "SPIN" },
                { value: 4, text: "RAMPA" },
                { value: 7, text: "CONTROL" },
                { value: 8, text: "CONTROL" },
                { value: 9, text: "CONTROL" },
                { value: 47, text: "CONTROL" },
                { value: 48, text: "CONTROL" },
                { value: 49, text: "CONTROL" },
                { value: 10, text: "CUSTOM1" },
                { value: 11, text: "CUSTOM2" },
                { value: 12, text: "CUSTOM3" },
                { value: 13, text: "CUSTOM4" },
                { value: 14, text: "CUSTOM5" },
                { value: 15, text: "CUSTOM6" },
                { value: 16, text: "SINGLE" },
                { value: 51, text: "MOMENTARY" },
                { value: 17, text: "FAVORITE" },
                { value: 18, text: "TAP TEMPO" },
                { value: 28, text: "DUAL STOMP" },
                { value: 29, text: "STOMP RAMPA" },
                { value: 50, text: "DUAL STOMP RAMPA" },
                { value: 35, text: "SPIN" },
                { value: 36, text: "SPIN" },
                { value: 37, text: "SPIN" },
                { value: 38, text: "SPIN" },
                { value: 39, text: "SPIN" },
                { value: 40, text: "SPIN" },
                { value: 44, text: "SPIN" },
                { value: 45, text: "SPIN" },
                { value: 46, text: "SPIN" },
                { value: 53, text: "MACROS" }
            ];
            
            // allPresetsData[layerIndex][globalIndex] => dados do preset por layer do LIVE
            let allPresetsData = Array.from({ length: TOTAL_LIVE_LAYERS }, () => []);
            // Marca quais presets (por layer) jÃ¡ foram carregados do ESP
            let presetsLoadedFromServer = Array.from(
                { length: TOTAL_LIVE_LAYERS },
                () => Array(TOTAL_PRESETS).fill(false)
            );

            function copySharedPresetFields(sourcePreset, targetPreset) {
                if (!sourcePreset || !targetPreset) return targetPreset;
                targetPreset.nomePreset = sourcePreset.nomePreset;
                targetPreset.nomePresetTextColor = sourcePreset.nomePresetTextColor;
                targetPreset.nomePresetFont = sourcePreset.nomePresetFont;
                targetPreset.backgroundColorConfig = sourcePreset.backgroundColorConfig;
                targetPreset.backTagColor = sourcePreset.backTagColor;
                targetPreset.bank = sourcePreset.bank;
                targetPreset.canal = sourcePreset.canal;
                return targetPreset;
            }

            function ensurePresetDataForLayer(globalIndex, layerIdx, colIndex, rowIndex) {
                if (!allPresetsData[layerIdx]) {
                    allPresetsData[layerIdx] = [];
                }
                if (!allPresetsData[layerIdx][globalIndex]) {
                    allPresetsData[layerIdx][globalIndex] = getSingleDefaultPresetData(colIndex, rowIndex);
                }
                return allPresetsData[layerIdx][globalIndex];
            }

            function syncSharedPresetFieldsForIndex(globalIndex, colIndex, rowIndex) {
                const sharedPreset = ensurePresetDataForLayer(globalIndex, 0, colIndex, rowIndex);
                for (let layerIdx = 1; layerIdx < TOTAL_LIVE_LAYERS; layerIdx++) {
                    const targetPreset = ensurePresetDataForLayer(globalIndex, layerIdx, colIndex, rowIndex);
                    copySharedPresetFields(sharedPreset, targetPreset);
                }
            }

            function getSharedPresetDataForIndex(globalIndex, colIndex, rowIndex) {
                const sharedPreset = allPresetsData[0]?.[globalIndex];
                if (sharedPreset) return sharedPreset;
                const currentLayerIdx = currentLiveLayer - 1;
                const currentPreset = allPresetsData[currentLayerIdx]?.[globalIndex];
                if (currentPreset) return currentPreset;
                return getSingleDefaultPresetData(colIndex, rowIndex);
            }

            function getDefaultExtrasData() {
                return {
                    spin: Array(6).fill(null).map(() => ({ v1: 0, v2: 64, v3: 127, spin_count: 1, cc2: 0, v1cc2: 0, v2cc2: 64, v3cc2: 127, cc3: 0, v1cc3: 0, v2cc3: 64, v3cc3: 127 })),
                    control: Array(6).fill(null).map(() => ({ cc: 48, modo_invertido: false })),
                    custom: Array(6).fill(null).map((_, i) => ({ cc: 48 + i, valor_off: 0, valor_on: 127, canal: 1 })),
                    pc: Array(4).fill(null).map(() => ({ valor: 0, canal: 1 })),
                    cc: Array(2).fill(null).map(() => ({ cc: 0, valor: 0, canal: 1 })),
                    enviar_extras: false
                };
            }

            function normalizeModesClient(sw, extras) {
                if (!sw || typeof sw.modo !== 'number') return sw;
                // SW COMBO removido: backups/firmwares antigos podem trazer modo 30-34; descartar.
                if (sw.modo >= 30 && sw.modo <= 34) {
                    sw.modo = 0;
                }
                const isSpinP1_3 = sw.modo >= 19 && sw.modo <= 21;
                const isSpinP4_6 = sw.modo >= 41 && sw.modo <= 43;
                if (isSpinP1_3) {
                    sw.modo = sw.modo - 18; // 19->1, 20->2, 21->3
                    sw.spin_send_pc = true;
                } else if (isSpinP4_6) {
                    sw.modo = sw.modo - 3;  // 41->38, 42->39, 43->40
                    sw.spin_send_pc = true;
                }
                // SPIN â†’ SPIN HOLD (com HOLD desabilitado por default)
                if (sw.modo >= 1 && sw.modo <= 3) {
                    sw.modo = sw.modo + 34; // 1â†’35, 2â†’36, 3â†’37
                    if (sw.start_value_cc2 === undefined) sw.start_value_cc2 = true;
                } else if (sw.modo >= 38 && sw.modo <= 40) {
                    sw.modo = sw.modo + 6; // 38â†’44, 39â†’45, 40â†’46
                    if (sw.start_value_cc2 === undefined) sw.start_value_cc2 = true;
                }
                if (sw.modo >= 22 && sw.modo <= 27) {
                    const idx = sw.modo - 22;
                    const customArr = extras?.custom || [];
                    const valorOn = customArr[idx]?.valor_on ?? 127;
                    const ccCustom = (customArr[idx]?.cc ?? sw.cc) || 0;
                    sw.modo = 16;
                    sw.start_value = true;
                    sw.single_value = typeof valorOn === 'number' ? valorOn : 127;
                    sw.cc = ccCustom;
                }
                if (sw.spin_send_pc === undefined) sw.spin_send_pc = false;
                if (sw.spin_start_on_preset === undefined) sw.spin_start_on_preset = true;
                if (sw.spin_show_pos === undefined) sw.spin_show_pos = false;
                if (sw.single_value === undefined) sw.single_value = 127;
                {
                    const rawCc2Ch = (sw.cc2_ch !== undefined) ? parseInt(sw.cc2_ch, 10)
                                    : (sw.canal_cc2 !== undefined) ? parseInt(sw.canal_cc2, 10)
                                    : NaN;
                    if (!Number.isNaN(rawCc2Ch)) {
                        sw.canal_cc2 = rawCc2Ch;
                        sw.cc2_ch = rawCc2Ch;
                    }
                }
                return sw;
            }

            function getCc2ChannelValue(sw) {
                const raw = (sw && sw.cc2_ch !== undefined) ? sw.cc2_ch
                          : (sw && sw.canal_cc2 !== undefined) ? sw.canal_cc2
                          : 1;
                const val = parseInt(raw, 10);
                return (!Number.isNaN(val) && val >= 0 && val <= 16) ? val : 1;
            }

            function getCc3ChannelValue(sw) {
                const raw = (sw && sw.cc3_ch !== undefined) ? sw.cc3_ch
                          : (sw && sw.canal_cc3 !== undefined) ? sw.canal_cc3
                          : 1;
                const val = parseInt(raw, 10);
                return (!Number.isNaN(val) && val >= 0 && val <= 16) ? val : 1;
            }

            function getSingleDefaultPresetData(colIndex, rowIndex) {
                const presetName = String.fromCharCode(65 + colIndex) + (rowIndex + 1);
                return {
                    nomePreset: presetName,
                    nomePresetTextColor: 0xFFFFFF,
                    nomePresetFont: 2,
                    backgroundColorConfig: 0x000000,
                    backTagColor: 0x1E1E23,
                    bank: 0,
                    canal: 1,
                    rampTimes: { sw1: 1000, sw2: 1000, sw3: 1000, sw4: 1000, sw5: 1000, sw6: 1000 },
                        switches: Array(6).fill(null).map((_, i) => ({
                            modo: 0,
                            cc: 48 + i,
                            cc2: 0, 
                            cc_hold: 0, 
                            start_value: true,
                            start_value_cc2: false, 
                            canal_cc2: 1,
                            single_value: 127,
                            spin_send_pc: false,
                            spin_start_on_preset: true,
                            spin_show_pos: false,
                            canal: 1,
                            led: (colIndex + i) % PERFIS_CORES_LED_WEB.length,
                            sigla_fx: "",
                            
                            autoRamp: false,
                            led2: 0,
                            favoriteAutoLive: false, tap2_cc: 0, tap2_ch: 0, tap3_cc: 0, tap3_ch: 0, tap_mode2: false,
                            sigla_fx_2: "",
                            ds_custom_enabled: false,
                            ds_cc1_off: 0,
                            ds_cc1_on: 127,
                            ds_cc2_off: 0,
                            ds_cc2_on: 127,
                            stomp_custom: false,
                            stomp_val_on: 127,
                            stomp_val_off: 0,
                            reclick_enabled: false,
                            cc3: 0,
                            canal_cc3: 1,
                            led3: 0,
                            start_value_cc3: false,
                            reclick_custom_enabled: false,
                            reclick_val_off: 0,
                            reclick_val_on: 127
                        })),
                    extras: getDefaultExtrasData()
                };
            }

            function initializeFullDefaultPresets() {
                for (let layer = 0; layer < TOTAL_LIVE_LAYERS; layer++) {
                    allPresetsData[layer] = [];
                    presetsLoadedFromServer[layer] = Array(TOTAL_PRESETS).fill(false);
                    for (let col = 0; col < NUM_PRESET_COLUMNS; col++) {
                        for (let row = 0; row < NUM_PRESET_ROWS; row++) {
                            allPresetsData[layer].push(getSingleDefaultPresetData(col, row));
                        }
                    }
                }
            }

            const LAYER2_FETCH_SETTLE_MS = 80;

            async function waitBeforeFetchingPresetLayer(layer) {
                if (layer < 2) return;
                await new Promise(resolve => setTimeout(resolve, LAYER2_FETCH_SETTLE_MS));
            }
            
            async function fetchAndLoadSinglePreset(colIndex, rowIndex, activateEsp = false) {
                const statusMessage = document.getElementById('statusMessage');
                statusMessage.textContent = `Carregando preset ${String.fromCharCode(65 + rowIndex)}${colIndex + 1}...`;
                
                if (window.isPresetLoadInProgress) {
                    console.warn('Preset load ignored: already in progress');
                    return;
                }
                window.isPresetLoadInProgress = true;

                try {
                    const globalIndex = colIndex * NUM_PRESET_ROWS + rowIndex;

                    // Carregar dados APENAS do layer atual (layer 2 sera carregado sob demanda)
                    const fetchLayerIdx = currentLiveLayer - 1;
                    let presetDataFromServer = null;
                    try {
                        await waitBeforeFetchingPresetLayer(currentLiveLayer);
                        const r = await apiFetch(`/get-single-preset-data?btn=${colIndex}&lvl=${rowIndex}&layer=${currentLiveLayer}`);
                        if (r.ok) presetDataFromServer = await r.json();
                    } catch (_) {}

                    // Processar resultado do layer
                    if (presetDataFromServer && globalIndex < allPresetsData[fetchLayerIdx].length) {
                        const defaultPreset = getSingleDefaultPresetData(colIndex, rowIndex);
                        const mergedPreset = Object.assign({}, defaultPreset, presetDataFromServer);
                        if (presetDataFromServer.switches) {
                            mergedPreset.switches = presetDataFromServer.switches.map((sw, i) => {
                                const normalizedSw = normalizeModesClient({ ...(sw || {}) }, presetDataFromServer.extras || {});
                                return Object.assign({}, defaultPreset.switches[i], normalizedSw);
                            });
                        }
                        if (presetDataFromServer.extras) {
                            mergedPreset.extras = Object.assign({}, defaultPreset.extras, presetDataFromServer.extras);
                            // SW COMBO removido: se vier em backup antigo, descartar.
                            if (mergedPreset.extras && mergedPreset.extras.combo) delete mergedPreset.extras.combo;
                            if (presetDataFromServer.extras.spin) {
                                mergedPreset.extras.spin = presetDataFromServer.extras.spin.map((s, i) => Object.assign({}, defaultPreset.extras.spin[i], s));
                            }
                            if (presetDataFromServer.extras.control) {
                                mergedPreset.extras.control = presetDataFromServer.extras.control.map((c, i) => Object.assign({}, defaultPreset.extras.control[i], c));
                            }
                            if (presetDataFromServer.extras.custom) {
                                mergedPreset.extras.custom = presetDataFromServer.extras.custom.map((cu, i) => Object.assign({}, defaultPreset.extras.custom[i], cu));
                            }
                            if (presetDataFromServer.extras.pc) {
                                mergedPreset.extras.pc = presetDataFromServer.extras.pc.map((p, i) => Object.assign({}, defaultPreset.extras.pc[i], p));
                            }
                            if (presetDataFromServer.extras.cc) {
                                mergedPreset.extras.cc = presetDataFromServer.extras.cc.map((cce, i) => Object.assign({}, defaultPreset.extras.cc[i], cce));
                            }
                        }
                        if (fetchLayerIdx === 0) {
                            allPresetsData[fetchLayerIdx][globalIndex] = mergedPreset;
                            syncSharedPresetFieldsForIndex(globalIndex, colIndex, rowIndex);
                        } else {
                            const sharedPreset = allPresetsData[0]?.[globalIndex];
                            if (sharedPreset) {
                                copySharedPresetFields(sharedPreset, mergedPreset);
                            }
                            allPresetsData[fetchLayerIdx][globalIndex] = mergedPreset;
                        }
                        presetsLoadedFromServer[fetchLayerIdx][globalIndex] = true;
                    }
                    
                    // Carregar nome/bank/canal primeiro para feedback visual imediato
                    const layerIdx = currentLiveLayer - 1;
                    loadPresetDataToUI(colIndex, rowIndex);

                    // Yield ao browser para pintar o nome antes do trabalho pesado
                    await new Promise(r => requestAnimationFrame(() => setTimeout(r, 0)));

                    // Trabalho pesado apÃ³s o browser pintar
                    updateAllFootButtonsUI();
                    if (currentSwitchIndex >= 0) {
                        loadSwitchDataToUI(colIndex, rowIndex, currentSwitchIndex);
                    } else {
                        hideSwitchConfigArea();
                    }

                    const pcCcGrid = document.getElementById('extrasPcCcSection')?.querySelector('.extras-grid');
                    if (pcCcGrid && allPresetsData[layerIdx][globalIndex]?.extras?.pc) {
                        generatePcCcFields(pcCcGrid, allPresetsData[layerIdx][globalIndex].extras);
                    }
                    updateLiveLayerButtonColorFromCurrentSwitch();

                    initCustomSelects();

                    statusMessage.textContent = `Preset ${String.fromCharCode(65 + rowIndex)}${colIndex + 1} carregado. Selecione um FOOT para editar.`;

                    if (activateEsp) {
                        try {
                            await apiFetch(`/refresh-display-only?btn=${colIndex}&lvl=${rowIndex}&layer=${currentLiveLayer}`);
                        } catch (refreshError) {
                            console.warn('Falha ao atualizar display/LEDs do ESP apos carregar preset:', refreshError);
                        }
                    }

                } catch (error) {
                    console.error('Erro ao carregar dados do preset:', error);
                    statusMessage.textContent = 'Erro ao carregar preset: ' + error.message;
                } finally {
                    window.isPresetLoadInProgress = false;
                }
            }

            async function reloadPresetExtrasFromServer(colIndex, rowIndex) {
                try {
                    await waitBeforeFetchingPresetLayer(currentLiveLayer);
                    const response = await apiFetch(`/get-single-preset-data?btn=${colIndex}&lvl=${rowIndex}&layer=${currentLiveLayer}`);
                    if (!response.ok) return null;
                    const serverData = await response.json();
                    const globalIndex = colIndex * NUM_PRESET_ROWS + rowIndex;
                    const layerIdx = currentLiveLayer - 1;
                    if (!allPresetsData[layerIdx][globalIndex]) {
                        allPresetsData[layerIdx][globalIndex] = getSingleDefaultPresetData(colIndex, rowIndex);
                    }
                    const defaults = getDefaultExtrasData();
                    const extras = serverData?.extras || {};
                    if (!allPresetsData[layerIdx][globalIndex].extras) {
                        allPresetsData[layerIdx][globalIndex].extras = getDefaultExtrasData();
                    }
                    if (Array.isArray(extras.spin)) {
                        const mergedSpin = extras.spin.map((s, i) => ({ ...(defaults.spin[i] || {}), ...(s || {}) }));
                        allPresetsData[layerIdx][globalIndex].extras.spin = mergedSpin;
                    }
                    if (Array.isArray(extras.custom)) {
                        const mergedCustom = extras.custom.map((c, i) => ({ ...(defaults.custom[i] || {}), ...(c || {}) }));
                        allPresetsData[layerIdx][globalIndex].extras.custom = mergedCustom;
                    }
                    if (Array.isArray(extras.control)) {
                        const mergedControl = extras.control.map((c, i) => ({ ...(defaults.control[i] || {}), ...(c || {}) }));
                        allPresetsData[layerIdx][globalIndex].extras.control = mergedControl;
                    }
                    if (Array.isArray(serverData?.switches)) {
                        const currentModeSelected = (function() {
                            const sel = document.getElementById('switchMode');
                            if (!sel) return null;
                            if (sel.value === 'custom_placeholder') return 10 + currentSwitchIndex;
                            const v = parseInt(sel.value, 10);
                            return isNaN(v) ? null : v;
                        })();
                        if (!Array.isArray(allPresetsData[layerIdx][globalIndex].switches)) {
                            allPresetsData[layerIdx][globalIndex].switches = getSingleDefaultPresetData(colIndex, rowIndex).switches;
                        }
                        serverData.switches.forEach((sw, idx) => {
                            const existing = allPresetsData[layerIdx][globalIndex].switches[idx] || {};
                            const merged = { ...existing, ...normalizeModesClient({ ...(sw || {}) }, serverData.extras || {}) };
                            if (idx === currentSwitchIndex && currentModeSelected !== null) {
                                merged.modo = currentModeSelected;
                            }
                            allPresetsData[layerIdx][globalIndex].switches[idx] = merged;
                        });
                    }
                    return serverData;
                } catch (err) {
                    console.error('Erro ao recarregar EXTRAS do servidor:', err);
                    return null;
                }
            }

            // Track which layer is currently visible in the UI (1 or 2)
            let currentUiLayer = 1;

            function updateLayerUiState() {
                // Determine which layer to show
                const layer1Div = document.getElementById('layer1Switches');
                const layer2Div = document.getElementById('layer2Switches');
                const toggleBtn = document.getElementById('layerToggleBtn');

                if (currentUiLayer === 1) {
                    if (layer1Div) layer1Div.style.display = 'grid';
                    if (layer2Div) layer2Div.style.display = 'none';
                    if (toggleBtn) toggleBtn.textContent = 'LAYER 1';
                } else {
                    if (layer1Div) layer1Div.style.display = 'none';
                    if (layer2Div) layer2Div.style.display = 'grid';
                    if (toggleBtn) toggleBtn.textContent = 'LAYER 2';
                }
                updateLayerButtonAppearance();
            }

            async function syncEspDisplayAfterLayerToggle(colIndex, rowIndex) {
                try {
                    await new Promise(resolve => requestAnimationFrame(() => setTimeout(resolve, 0)));
                    await apiFetch(`/refresh-display-only?btn=${colIndex}&lvl=${rowIndex}&layer=${currentLiveLayer}`);
                } catch (error) {
                    console.warn('Falha ao atualizar display do ESP apos trocar layer:', error);
                }
            }

            async function toggleLayerUi() {
                // IMPORTANTE: Salvar dados do layer atual ANTES de trocar
                // Isso evita que os dados do layer antigo sejam salvos no layer novo
                try {
                    const prevSuppress = suppressModelUpdate;
                    suppressModelUpdate = false;
                    updateLocalPresetDataFromUI();
                    suppressModelUpdate = prevSuppress;
                } catch (_) {}

                // Alternar layer
                if (currentUiLayer === 1) currentUiLayer = 2;
                else currentUiLayer = 1;

                // Sincronizar currentLiveLayer com o layer visÃ­vel na UI
                currentLiveLayer = currentUiLayer;

                // Atualizar visibilidade dos divs de layer
                updateLayerUiState();

                // Lazy load: se dados do layer ainda nao foram buscados do ESP, buscar agora
                const _gi = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                const _li = currentLiveLayer - 1;
                if (!presetsLoadedFromServer[_li] || !presetsLoadedFromServer[_li][_gi]) {
                    try {
                        await fetchAndLoadSinglePreset(currentPresetColumnIndex, currentPresetRowIndex, true);
                    } catch (e) {
                        console.warn('Erro ao carregar layer sob demanda:', e);
                    }
                    try { updateAllFootButtonsUI(); } catch (_) {}
                    return; // fetchAndLoadSinglePreset ja atualizou toda a UI
                }

                // IMPORTANTE: Carregar dados do novo layer na UI
                // Suprimir atualizaÃ§Ãµes de modelo durante o carregamento para evitar loops
                const prevSuppressForLoad = suppressModelUpdate;
                suppressModelUpdate = true;

                try {
                    // Carregar dados do preset (nome, bank, canal) para o novo layer
                    loadPresetDataToUI(currentPresetColumnIndex, currentPresetRowIndex);

                    // Se hÃ¡ switch selecionado, carregar seus dados do novo layer
                    if (currentSwitchIndex >= 0) {
                        try { populateModeOptions(currentSwitchIndex); } catch (_) {}
                        loadSwitchDataToUI(currentPresetColumnIndex, currentPresetRowIndex, currentSwitchIndex);
                        try { initCustomSelects(); } catch (_) {}
                    }

                    // Atualizar seleÃ§Ã£o visual do botÃ£o correspondente no novo layer
                    const selector = `#layer${currentUiLayer}Switches .grid-btn[data-switch-index-in-layer="${currentSwitchIndex}"]`;
                    const targetBtn = document.querySelector(selector);

                    // Remover seleÃ§Ã£o de todos os botÃµes
                    document.querySelectorAll('#switchSelection .grid-btn').forEach(b => {
                        b.classList.remove('active');
                        b.setAttribute('aria-pressed', 'false');
                    });

                    // Selecionar o botÃ£o correspondente no novo layer
                    if (targetBtn) {
                        targetBtn.classList.add('active');
                        targetBtn.setAttribute('aria-pressed', 'true');
                    }
                } catch (e) {
                    console.warn('Erro ao carregar dados do novo layer:', e);
                }

                // Restaurar estado de supressÃ£o
                suppressModelUpdate = prevSuppressForLoad;

                // Atualizar previews de todos os foot buttons
                try {
                    updateAllFootButtonsUI();
                } catch (_) {}

                await syncEspDisplayAfterLayerToggle(currentPresetColumnIndex, currentPresetRowIndex);
            }

            function toggleLayer2Visibility() {
                // Determines if the toggle button should be active/visible
                try {
                    const toggleBtn = document.getElementById('layerToggleBtn');
                    const layer1Div = document.getElementById('layer1Switches');
                    
                    if (liveLayer2Enabled) {
                        // Layer 2 enabled: Show button, update state
                        if (toggleBtn) {
                            toggleBtn.style.display = 'inline-block';
                            toggleBtn.onclick = toggleLayerUi;
                        }
                        updateLayerUiState();
                    } else {
                        // Layer 2 disabled: Hide button (or show static), force Layer 1 view
                        currentUiLayer = 1;
                        if (toggleBtn) {
                            // Option: Hide button entirely or show as static label
                            // User request: "alterna entre layer 1 e 2". If disabled, no toggle.
                            // Let's hide the toggle capability but keep the label "LAYER 1"
                            toggleBtn.style.display = 'none'; // Or just disable
                        }
                        if (layer1Div) layer1Div.style.display = 'grid';
                        // Ensure Layer 2 is hidden
                        const layer2Div = document.getElementById('layer2Switches');
                        if (layer2Div) layer2Div.style.display = 'none';
                        
                        // If we hide the button, we might need a header? 
                        // The user said "onde esta escrito LAYER 1 faÃ§a isso virar um botÃ£o".
                        // If Layer 2 is OFF, maybe just show "LAYER 1" text?
                        // For now, if L2 is off, we hide the button, meaning it looks like just grid.
                        // But wait, "LAYER 1" header was removed.
                        // So if L2 is disabled, we should probably still show "LAYER 1" label.
                        if (toggleBtn) {
                           toggleBtn.style.display = 'inline-block';
                           toggleBtn.onclick = null; // Disable toggle
                           toggleBtn.style.cursor = 'default';
                           toggleBtn.textContent = 'LAYER 1';
                           updateLayerButtonAppearance();
                        }
                    }
                } catch (e) {
                    console.warn('Erro ao alternar visibilidade do Layer 2:', e);
                }
            }

            function updateLayerButtonAppearance() {
                // Update button style based on current layer color
                try {
                    const toggleBtn = document.getElementById('layerToggleBtn');
                    if (!toggleBtn) return;

                    let colorVal = 0;
                    if (currentUiLayer === 1) {
                         colorVal = (typeof liveModeColorLayer1 === 'number') ? liveModeColorLayer1 : 0x39a0ff;
                    } else {
                         colorVal = (typeof liveModeColorLayer2 === 'number') ? liveModeColorLayer2 : 0xff00aa;
                    }

                    const r = (colorVal >> 16) & 0xFF;
                    const g = (colorVal >> 8) & 0xFF;
                    const b = (colorVal) & 0xFF;
                    const hex = `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
                    
                    toggleBtn.style.borderColor = hex;
                    toggleBtn.style.color = hex;
                    // Box shadow color logic
                    toggleBtn.style.boxShadow = `0 0 12px ${hex}80`; // 50% opacity

                } catch (e) {
                    console.warn('Erro ao atualizar aparencia do botao layer:', e);
                }
            }

            function getPresetNameMaxLengthForFont(fontValue) {
                return (parseInt(fontValue, 10) === 1) ? 18 : 10;
            }

            function getCurrentPresetNameMaxLength() {
                return getPresetNameMaxLengthForFont(document.getElementById('presetNameFontValue')?.value || 2);
            }

            function getKemperRigNameForUi(fontValue = null) {
                if (getEffectiveMidiMode() !== "KEMPER PLAYER" || !kemperGetNamesEnabled || !currentKemperRigName) {
                    return "";
                }
                const resolvedFontValue = (fontValue ?? document.getElementById('presetNameFontValue')?.value) || 2;
                const maxLen = getPresetNameMaxLengthForFont(resolvedFontValue);
                return String(currentKemperRigName).substring(0, maxLen);
            }

            function resolvePresetNameForEditor(fallbackName, fontValue = null) {
                const resolvedFontValue = (fontValue ?? document.getElementById('presetNameFontValue')?.value) || 2;
                const maxLen = getPresetNameMaxLengthForFont(resolvedFontValue);
                const savedName = (fallbackName || "").substring(0, maxLen);
                if (savedName.trim() !== "") {
                    lastAutoFilledKemperRigName = "";
                    presetNameIsAutoManaged = false;
                    return savedName;
                }
                const kemperName = getKemperRigNameForUi(fontValue);
                if (kemperName) {
                    lastAutoFilledKemperRigName = kemperName;
                    presetNameIsAutoManaged = true;
                    return kemperName;
                }
                lastAutoFilledKemperRigName = "";
                presetNameIsAutoManaged = false;
                return savedName;
            }

            function applyKemperRigNameToPresetInput() {
                const input = document.getElementById('presetNameInput');
                if (!input) return;
                const kemperName = getKemperRigNameForUi();
                if (!kemperName) return;
                const currentValue = input.value || "";
                const trimmedValue = currentValue.trim();
                if (trimmedValue === "" || (presetNameIsAutoManaged && currentValue === lastAutoFilledKemperRigName)) {
                    input.value = kemperName;
                    lastAutoFilledKemperRigName = kemperName;
                    presetNameIsAutoManaged = true;
                }
            }

            function syncPresetNameFontButton(fontValue) {
                const btn = document.getElementById('presetNameFontBtn');
                const label = document.getElementById('presetNameFontLabel');
                const hidden = document.getElementById('presetNameFontValue');
                const normalized = (parseInt(fontValue, 10) === 1) ? 1 : 2;
                const input = document.getElementById('presetNameInput');
                const maxLen = getPresetNameMaxLengthForFont(normalized);
                if (hidden) hidden.value = String(normalized);
                if (input) {
                    input.maxLength = maxLen;
                    if ((input.value || "").length > maxLen) {
                        input.value = input.value.substring(0, maxLen);
                    }
                }
                if (!btn || !label) return;
                btn.classList.remove('rect-toggle-fx-on', 'rect-toggle-fx-live');
                btn.classList.add(normalized === 1 ? 'rect-toggle-fx-live' : 'rect-toggle-fx-on');
                label.textContent = String(normalized);
            }

            function syncKemperRigNameState(configData) {
                kemperGetNamesEnabled = !!configData.kemperGetNames;
                currentKemperRigName = (configData.currentRigName || "").toString();
                applyKemperRigNameToPresetInput();
            }

            function stopKemperRigNamePolling() {
                if (kemperRigNamePollTimer) {
                    clearInterval(kemperRigNamePollTimer);
                    kemperRigNamePollTimer = null;
                }
            }

            function startKemperRigNamePolling() {
                stopKemperRigNamePolling();
                if (getEffectiveMidiMode() !== "KEMPER PLAYER" || !kemperGetNamesEnabled) return;
                kemperRigNamePollTimer = setInterval(() => {
                    apiFetch('/api/global-config/read')
                        .then(response => response.ok ? response.json() : Promise.reject('Falha rig name'))
                        .then(configData => {
                            syncKemperRigNameState(configData);
                        })
                        .catch(() => {});
                }, 1500);
            }

            function initializePage() { 
                console.log("Inicializando pagina...");
                document.getElementById('btnColar').disabled = true;

                apiFetch('/api/global-config/read')
                    .then(response => response.ok ? response.json() : Promise.reject('Falha config globais'))
                    .then(configData => {
                        // Processa configs globais primeiro
                        const modoMidiIndex = configData.modoMidiIndex || 0;
                        const modoMidiOpcoes = ["GLOBAL", "AMPERO AS2", "AMPERO MINI", "HX STOMP", "A. STAGE 2", "GP-200LT", "VALETON GP5", "POCKET MASTER", "TONEX", "KEMPER PLAYER", "AMPERO MP350", "MX5", "NANO CORTEX", "QUAD CORTEX", "MODO AVANCADO", "SYNERGY AMPS", "BigSky", "BlueSky", "TimeLine", "ELCAPISTAN", "FLINT", "HX-ONE", "VTR NARCISO", "VTR LOKI", "VTR KAILANI"];
                        globalMidiMode = modoMidiOpcoes[modoMidiIndex] || "GLOBAL";
                        // Carrega dados do MODO AVANCADO
                        if (configData.advMidiCh && Array.isArray(configData.advMidiCh)) {
                            for (let i = 0; i < 5; i++) {
                                advMidiChData[i] = (typeof configData.advMidiCh[i] === 'number') ? configData.advMidiCh[i] : 0;
                            }
                        }
                        if (configData.advMidiChNum && Array.isArray(configData.advMidiChNum)) {
                            for (let i = 0; i < 5; i++) {
                                advMidiChNumData[i] = (typeof configData.advMidiChNum[i] === 'number') ? configData.advMidiChNum[i] : (i + 1);
                            }
                        }
                        syncKemperRigNameState(configData);
                        startKemperRigNamePolling();
                        document.getElementById('currentMidiMode').textContent = globalMidiMode;

                        // Cores globais de LIVE MODE 1 e 2 (0xRRGGBB)
                        if (typeof configData.corLiveModeConfig === 'number') {
                            liveModeColorLayer1 = configData.corLiveModeConfig;
                        } else {
                            liveModeColorLayer1 = 0xFFFFFF;
                        }
                        if (typeof configData.corLiveMode2Config === 'number') {
                            liveModeColorLayer2 = configData.corLiveMode2Config;
                        } else {
                            liveModeColorLayer2 = liveModeColorLayer1;
                        }
                        
                        // Verificar se Layer 2 estÃ¡ habilitado
                        if (typeof configData.liveLayer2Enabled === 'boolean') {
                            liveLayer2Enabled = configData.liveLayer2Enabled;
                        } else {
                            liveLayer2Enabled = true; // padrÃ£o
                        }
                        
                        // Atualizar previews de cor dos layers
                        updateLayerButtonAppearance();
                        
                        // Mostrar/ocultar Layer 2 baseado na configuraÃ§Ã£o
                        toggleLayer2Visibility();
                        
                        const bankSelectId = 'presetBankInput';
                        const effectiveMode = getEffectiveMidiMode();
                        if (effectiveMode === "GLOBAL") populateNumericSelect(bankSelectId, 0, 299, 0);
                        else if (effectiveMode === "AMPERO AS2") populateBankLabels(bankSelectId, bank_AS2_Names, 0);
                        else if (effectiveMode === "HX STOMP") populateBankLabels(bankSelectId, bank_HX_STOMP_Names, 0);
                        else if (effectiveMode === "AMPERO MINI") populateBankLabels(bankSelectId, bank_AMPERO_MINI_Names, 0);
                        else if (effectiveMode === "A. STAGE 2") populateBankLabels(bankSelectId, bank_ASTG2_Names, 0);
                        else if (effectiveMode === "GP-200LT") populateBankLabels(bankSelectId, bank_GP200LT_Names, 0);
                        else if (effectiveMode === "VALETON GP5") populateBankLabels(bankSelectId, bank_VALETON_GP5_Names, 0);
                        else if (effectiveMode === "POCKET MASTER") populateBankLabels(bankSelectId, bank_POCKET_MASTER_Names, 0);
                        else if (effectiveMode === "KEMPER PLAYER") populateBankLabels(bankSelectId, bank_KEMPER_PLAYER_Names, 0);
                        else if (effectiveMode === "TONEX") populateBankLabels(bankSelectId, bank_TONEX_Names, 0);
                        else if (effectiveMode === "AMPERO MP350") populateBankLabels(bankSelectId, bank_AMPERO_MP350_Names, 0);
                        else if (effectiveMode === "BigSky") populateBankLabels(bankSelectId, bank_BIGSKY_Names, 0);
                        else if (effectiveMode === "BlueSky") populateBankLabels(bankSelectId, bank_BLUESKY_Names, 0);
                        else if (effectiveMode === "TimeLine") populateBankLabels(bankSelectId, bank_TIMELINE_Names, 0);
                        else if (effectiveMode === "MX5") populateNumericSelect(bankSelectId, 0, 299, 0);
                        else if (effectiveMode === "NANO CORTEX") populateNumericSelect(bankSelectId, 0, 299, 0);
                        else if (effectiveMode === "QUAD CORTEX") populateNumericSelect(bankSelectId, 0, 299, 0);
                        else if (effectiveMode === "SYNERGY AMPS") populateNumericSelect(bankSelectId, 0, 299, 0);
                        else if (effectiveMode === "VTR NARCISO") populateNumericSelect(bankSelectId, 0, 299, 0);
                        else if (effectiveMode === "VTR LOKI") populateNumericSelect(bankSelectId, 0, 299, 0);
                        else if (effectiveMode === "VTR KAILANI") populateNumericSelect(bankSelectId, 0, 299, 0);
                        populateNumericSelect('switchCC', 0, 127, 48);

                        const boardName = configData.boardName || 'default';
                        generateSwitchButtons(boardName);

                        initializeFullDefaultPresets(); 
                        generatePresetButtons();
                        populateModeOptions(currentSwitchIndex);
                        populateNumericSelect('switchChannel', 0, 16, 1);
                        populatePresetChannelSelect('presetChannelInput', 1);
                        initializeColorPickers();

                        // Esconde a Ã¡rea de configuraÃ§Ã£o do switch na inicializaÃ§Ã£o (nenhum switch selecionado)
                        hideSwitchConfigArea();

                        const initialGlobalIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                        const initialPcCcGrid = document.getElementById('extrasPcCcSection')?.querySelector('.extras-grid');
                        const initialLayerIdx = currentLiveLayer - 1;
                        if (initialPcCcGrid &&
                            allPresetsData[initialLayerIdx] &&
                            allPresetsData[initialLayerIdx][initialGlobalIndex] &&
                            allPresetsData[initialLayerIdx][initialGlobalIndex].extras?.pc) {
                             generatePcCcFields(initialPcCcGrid, allPresetsData[initialLayerIdx][initialGlobalIndex].extras);
                        }
                        initCustomSelects(); 

                        fetchAndLoadSinglePreset(currentPresetColumnIndex, currentPresetRowIndex).then(() => { 
                             setupEventListeners(); 
                        }).catch(error => {
                            console.error("Erro inicializacao:", error);
                            document.getElementById('statusMessage').textContent = "Erro critico na inicializacao.";
                        });
                    })
                    .catch(error => {
                        console.error('Erro MIDI ou de config:', error);
                        document.getElementById('currentMidiMode').textContent = 'GLOBAL (padrao)';
                        populateNumericSelect('presetBankInput', 0, 299, 0);
                        populateNumericSelect('switchCC', 0, 127, 48); 

                        // Setup de fallback em caso de erro
                        generateSwitchButtons('default'); // Usa 6 botoes como padrao
                        initializeFullDefaultPresets(); 
                        generatePresetButtons();
                        populateModeOptions(currentSwitchIndex);
                        populateNumericSelect('switchChannel', 0, 16, 1); 
                        populatePresetChannelSelect('presetChannelInput', 1);
                        initializeColorPickers();
                        initCustomSelects();
                        fetchAndLoadSinglePreset(currentPresetColumnIndex, currentPresetRowIndex).then(() => { 
                             setupEventListeners(); 
                        });
                    });
            }

            function generatePresetButtons() {
                // NÃƒÂ£o gera mais grade A1..E6. Mantido vazio para compatibilidade.
            }

            /* legacy (unused): kept for reference; active setupEventListeners is defined later */
            function generateSwitchButtons(boardName) {
                const layer1Div = document.getElementById('layer1Switches');
                const layer2Div = document.getElementById('layer2Switches');
                
                if (!layer1Div || !layer2Div) {
                    console.error('Layer divs not found');
                    return;
                }
                
                layer1Div.innerHTML = '';
                layer2Div.innerHTML = '';
                const numButtons = (boardName === 'BFMIDI-1 4S' || boardName === 'BFMIDI-2 4S' || boardName === 'BFMIDI-2 MICRO') ? 4 : 6;

                // Criar botÃµes para ambos os layers
                for (let layer = 1; layer <= TOTAL_LIVE_LAYERS; layer++) {
                    const targetDiv = (layer === 1) ? layer1Div : layer2Div;
                    
                    for (let i = 0; i < numButtons; i++) {
                        const btn = document.createElement('button');
                        btn.className = 'grid-btn foot-button';
                        btn.dataset.layer = layer;
                        btn.dataset.switchIndexInLayer = i;

                        btn.innerHTML = `
                            <span class=\"foot-label\">SW${i + 1}-XXX</span>
                            <hr class=\"foot-led-divider\">
                            <span class=\"foot-mode-label\">--</span>
                        `;

                        btn.addEventListener('click', async () => {
                            const selectedLayer = parseInt(btn.dataset.layer, 10);
                            const selectedSwitchIndexInLayer = parseInt(btn.dataset.switchIndexInLayer, 10);

                            // Salva o estado atual do switch ativo antes de trocar
                            // IMPORTANTE: Pula se isLayerSwitching=true (toggleLayerUi jÃ¡ salvou o layer anterior)
                            const prevSuppress = suppressModelUpdate;
                            if (!isLayerSwitching) {
                                try { suppressModelUpdate = false; } catch (_) {}
                                try { updateLocalPresetDataFromUI(); } catch (_) {}
                                try { suppressModelUpdate = true; } catch (_) {}
                            }

                            currentLiveLayer = selectedLayer;
                            currentSwitchIndex = selectedSwitchIndexInLayer;
                            try { populateModeOptions(currentSwitchIndex); } catch (_) {}

                            // Mostra a Ã¡rea de configuraÃ§Ã£o do switch
                            try { showSwitchConfigArea(); } catch (_) {}

                            // OTIMIZAÃ‡ÃƒO: SÃ³ busca do servidor se os dados ainda nÃ£o foram carregados
                            const globalIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                            const layerIdx = currentLiveLayer - 1;
                            const hasValidCache = presetsLoadedFromServer[layerIdx] && presetsLoadedFromServer[layerIdx][globalIndex];

                            if (!hasValidCache) {
                                try { await fetchAndLoadSinglePreset(currentPresetColumnIndex, currentPresetRowIndex, false); } catch (e) { console.warn('fetchAndLoadSinglePreset falhou:', e); }
                            }

                            try { initCustomSelects(); } catch (_) {}

                            try {
                                loadSwitchDataToUI(currentPresetColumnIndex, currentPresetRowIndex, currentSwitchIndex);
                            } catch(err) { console.warn('FOOT apply error:', err); }

                            // Aplicar seleÃ§Ã£o visual NO FINAL de todas as operaÃ§Ãµes
                            document.querySelectorAll('#switchSelection .grid-btn').forEach(b => {
                                b.classList.remove('active');
                                b.setAttribute('aria-pressed', 'false');
                            });
                            btn.classList.add('active');
                            btn.setAttribute('aria-pressed', 'true');

                            try { suppressModelUpdate = prevSuppress; } catch (_) {}
                        });
                        targetDiv.appendChild(btn);
                    }
                }
            }

            function updateAllFootButtonsUI() {
                const modeMap = new Map(MODE_OPTIONS_WEB.map(m => [m.value, m.text]));

                // Iterar sobre todos os 12 botÃµes (6 de cada layer)
                document.querySelectorAll('#switchSelection .grid-btn').forEach(button => {
                    const layer = parseInt(button.dataset.layer, 10);
                    const switchIndexInLayer = parseInt(button.dataset.switchIndexInLayer, 10);
                    
                    if (isNaN(layer) || isNaN(switchIndexInLayer)) return;
                    
                    // Buscar dados do preset correto para este layer
                    const layerIdx = layer - 1;
                    const globalIndex = currentPresetColumnIndex * NUM_PRESET_ROWS + currentPresetRowIndex;
                    const currentPresetData = allPresetsData[layerIdx]?.[globalIndex];

                    if (!currentPresetData || !currentPresetData.switches || !currentPresetData.switches[switchIndexInLayer]) return;

                    const switchData = currentPresetData.switches[switchIndexInLayer];

                    // Atualizar label principal: "SWn-XXX" usando sigla_fx ou "ICO" se icon_fx > 0
                    const mainLabel = button.querySelector('.foot-label');
                    if (mainLabel) {
                        let siglaOut = '---';
                        const iconFx = parseInt(switchData.icon_fx, 10) || 0;
                        if (iconFx > 0) {
                            siglaOut = 'ICO';
                        } else {
                            const sigla = (switchData.sigla_fx || '').toString().trim().toUpperCase().substring(0,3);
                            siglaOut = sigla && sigla.length > 0 ? sigla : '---';
                        }
                        mainLabel.textContent = `SW${switchIndexInLayer + 1}-${siglaOut}`;
                    }

                    const divider = button.querySelector('.foot-led-divider');
                    if (divider) {
                        // Sempre usar led principal para o preview do foot button
                        // led_hold sÃ³ Ã© usado no bloco secundÃ¡rio de SPIN HOLD no display do dispositivo
                        let ledIndex = switchData.led;
                        if (typeof ledIndex !== 'number' || ledIndex < 0 || ledIndex >= PERFIS_CORES_WEB.length) {
                            ledIndex = 0; // Fallback para vermelho se Ã­ndice invÃ¡lido
                        }
                        if (PERFIS_CORES_WEB[ledIndex]) {
                            const hexColor = `#${PERFIS_CORES_WEB[ledIndex].value.toString(16).padStart(6, '0')}`;
                            divider.style.backgroundColor = hexColor;
                        }
                    }

                    const modeLabel = button.querySelector('.foot-mode-label');
                    if (modeLabel) {
                        const modeValue = switchData.modo;
                        modeLabel.textContent = modeMap.get(modeValue) || '--';
                    }
                });
            }

            function populateModeOptions(switchIndex = currentSwitchIndex) {
                const select = document.getElementById('switchMode');
                select.innerHTML = '';
                select.dataset.dirty = '1';
                let customAdded = false;

                MODE_OPTIONS_WEB.forEach(mode => {
                    const isCustom = (mode.value >= 10 && mode.value <= 15);
                    const isSpin1_3 = (mode.value >= 1 && mode.value <= 3);
                    const isSpinHold1_3 = (mode.value >= 35 && mode.value <= 37);
                    const isSpin4_6 = (mode.value >= 38 && mode.value <= 40);
                    const isSpinHold4_6 = (mode.value >= 44 && mode.value <= 46);
                    const isSpin = isSpin1_3 || isSpinHold1_3 || isSpin4_6 || isSpinHold4_6;
                    const isControl = (mode.value >= 7 && mode.value <= 9) || (mode.value >= 47 && mode.value <= 49);

                    if (isSpin) {
                        // SPIN modes hidden - integrated into SPIN HOLD via HOLD toggle
                        if (isSpin1_3 || isSpin4_6) return;
                        let shouldShowSpin = false;
                        if (switchIndex >= 0 && switchIndex <= 2) {
                            if (isSpinHold1_3) shouldShowSpin = (mode.value === 35 + switchIndex);
                        } else if (switchIndex >= 3 && switchIndex <= 5) {
                            if (isSpinHold4_6) shouldShowSpin = (mode.value === 44 + (switchIndex - 3));
                        }
                        if (shouldShowSpin) {
                            const opt = document.createElement('option');
                            opt.value = mode.value;
                            opt.textContent = mode.text;
                            select.appendChild(opt);
                        }
                        return;
                    }

                    if (isControl) {
                        let shouldShowControl = false;
                        if (switchIndex >= 0 && switchIndex <= 2) {
                            if (mode.value === switchIndex + 7) {
                                shouldShowControl = true;
                            }
                        } else if (switchIndex >= 3 && switchIndex <= 5) {
                            if (mode.value === switchIndex + 44) {
                                shouldShowControl = true;
                            }
                        }
                        if (shouldShowControl) {
                            const opt = document.createElement('option');
                            opt.value = mode.value;
                            opt.textContent = mode.text;
                            select.appendChild(opt);
                        }
                        return;
                    }

                    if (isCustom) {
                        // CUSTOM modes hidden - integrated into STOMP via stomp_custom toggle
                        return;
                    }

                    // DUAL STOMP / STOMP RAMPA modes hidden - integrated into STOMP
                    if (mode.value === 28 || mode.value === 29 || mode.value === 50) {
                        return;
                    }

                    {
                        const opt = document.createElement('option');
                        opt.value = mode.value;
                        opt.textContent = mode.text;
                        select.appendChild(opt);
                    }
                });
            }

